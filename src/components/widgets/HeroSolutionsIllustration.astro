---

<div class="ab-wrap">
  <div class="orb o1"></div>
  <div class="orb o2"></div>
  <div class="orb o3"></div>

  <svg class="ab-svg" viewBox="0 0 700 460" fill="none" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern id="abgrid" width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(99,102,241,0.07)" stroke-width="0.5"/>
      </pattern>
    </defs>
    <rect width="700" height="460" fill="url(#abgrid)"/>
    <circle cx="620" cy="80" r="180" stroke="rgba(99,102,241,0.08)" stroke-width="1" fill="none"/>
    <circle cx="620" cy="80" r="220" stroke="rgba(99,102,241,0.05)" stroke-width="0.5" fill="none"/>
    <circle cx="80" cy="380" r="160" stroke="rgba(52,211,153,0.1)" stroke-width="1" fill="none"/>
    <line x1="0" y1="160" x2="220" y2="0" stroke="rgba(99,102,241,0.06)" stroke-width="1"/>
    <line x1="480" y1="460" x2="700" y2="280" stroke="rgba(99,102,241,0.06)" stroke-width="1"/>
    <!-- animated dashed connectors left -->
    <line x1="180" y1="87"  x2="312" y2="200" stroke="rgba(99,102,241,0.14)" stroke-width="0.75" stroke-dasharray="4 3"><animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2s"   repeatCount="indefinite"/></line>
    <line x1="155" y1="177" x2="312" y2="220" stroke="rgba(99,102,241,0.14)" stroke-width="0.75" stroke-dasharray="4 3"><animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2.4s" repeatCount="indefinite"/></line>
    <line x1="175" y1="270" x2="312" y2="248" stroke="rgba(52,211,153,0.16)" stroke-width="0.75" stroke-dasharray="4 3"><animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2.2s" repeatCount="indefinite"/></line>
    <line x1="165" y1="363" x2="320" y2="270" stroke="rgba(99,102,241,0.12)" stroke-width="0.75" stroke-dasharray="4 3"><animate attributeName="stroke-dashoffset" from="0" to="-14" dur="1.9s" repeatCount="indefinite"/></line>
    <!-- animated dashed connectors right -->
    <line x1="520" y1="103" x2="396" y2="200" stroke="rgba(167,139,250,0.16)" stroke-width="0.75" stroke-dasharray="4 3"><animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2.1s" repeatCount="indefinite"/></line>
    <line x1="535" y1="196" x2="396" y2="225" stroke="rgba(99,102,241,0.14)" stroke-width="0.75" stroke-dasharray="4 3"><animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2.5s" repeatCount="indefinite"/></line>
    <line x1="525" y1="288" x2="396" y2="248" stroke="rgba(52,211,153,0.16)" stroke-width="0.75" stroke-dasharray="4 3"><animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2s"   repeatCount="indefinite"/></line>
    <line x1="530" y1="374" x2="395" y2="270" stroke="rgba(99,102,241,0.12)" stroke-width="0.75" stroke-dasharray="4 3"><animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2.3s" repeatCount="indefinite"/></line>
    <!-- floating diamonds -->
    <g transform="translate(260,60) rotate(45)"><rect width="10" height="10" fill="rgba(99,102,241,0.15)" rx="1"/></g>
    <g transform="translate(440,380) rotate(45)"><rect width="8"  height="8"  fill="rgba(52,211,153,0.18)"  rx="1"/></g>
    <g transform="translate(80,200)  rotate(45)"><rect width="6"  height="6"  fill="rgba(167,139,250,0.2)"  rx="1"/></g>
    <g transform="translate(620,300) rotate(45)"><rect width="7"  height="7"  fill="rgba(99,102,241,0.15)"  rx="1"/></g>
  </svg>

  <!-- left tags -->
  <div class="ab-tag at1"><div class="ab-dot" style="background:#6366f1"></div><span class="ab-t">Manufacturing</span></div>
  <div class="ab-tag at2"><div class="ab-dot" style="background:#34d399"></div><span class="ab-t">Warehouse</span></div>
  <div class="ab-tag at3"><div class="ab-dot" style="background:#f97316"></div><span class="ab-t">Field Service</span></div>
  <div class="ab-tag at4"><div class="ab-dot" style="background:#a78bfa"></div><span class="ab-t">Sales & Distribution</span></div>
  <!-- right tags -->
  <div class="ab-tag at5"><div class="ab-dot" style="background:#6366f1"></div><span class="ab-t">Clean Core</span></div>
  <div class="ab-tag at6"><div class="ab-dot" style="background:#34d399"></div><span class="ab-t">Mobile-First</span></div>
  <div class="ab-tag at7"><div class="ab-dot" style="background:#f97316"></div><span class="ab-t">Real-Time Sync</span></div>
  <div class="ab-tag at8"><div class="ab-dot" style="background:#a78bfa"></div><span class="ab-t">Upgrade-Safe</span></div>

  <!-- centre card -->
  <div class="ab-centre">
    <div class="ab-pulse"></div>
    <div class="ab-icon">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5">
        <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
        <path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12"/>
      </svg>
    </div>
    <div class="ab-ctitle">UpBuff</div>
    <div class="ab-csub">ERP Execution Layer</div>
  </div>
</div>

<style>
  .ab-wrap {
    width: 100%;
    height: 100%;
    min-height: 420px;
    background: #f8f9fb;
    position: relative;
    overflow: hidden;
    border-radius: 16px;
  }
  .ab-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #f0f4ff 0%, #f8f9fb 50%, #f0f8f4 100%);
  }
  .ab-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    opacity: .18;
    pointer-events: none;
  }
  .o1 {
    width: 320px; height: 320px;
    background: radial-gradient(circle, #6366f1, transparent);
    top: -80px; right: -60px;
    animation: drift1 8s ease-in-out infinite;
  }
  .o2 {
    width: 200px; height: 200px;
    background: radial-gradient(circle, #a78bfa, transparent);
    bottom: -40px; left: 40px;
    animation: drift2 10s ease-in-out infinite;
  }
  .o3 {
    width: 140px; height: 140px;
    background: radial-gradient(circle, #34d399, transparent);
    top: 50%; left: 55%;
    animation: drift3 7s ease-in-out infinite;
  }
  .ab-tag {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    background: #fff;
    border: 0.5px solid rgba(99,102,241,.2);
    border-radius: 99px;
    padding: 6px 12px;
    box-shadow: 0 1px 8px rgba(0,0,0,.06);
    z-index: 2;
  }
  .ab-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  .ab-t   { font-size: 11px; font-weight: 600; color: #374151; white-space: nowrap; }

  .at1 { top: 18%; left: 8%;  animation: tagf 6s ease-in-out infinite 0s; }
  .at2 { top: 38%; left: 5%;  animation: tagf 6s ease-in-out infinite .8s; }
  .at3 { top: 58%; left: 10%; animation: tagf 6s ease-in-out infinite 1.6s; }
  .at4 { top: 78%; left: 7%;  animation: tagf 6s ease-in-out infinite 2.4s; }
  .at5 { top: 22%; right: 7%; animation: tagf 6s ease-in-out infinite .4s; }
  .at6 { top: 42%; right: 5%; animation: tagf 6s ease-in-out infinite 1.2s; }
  .at7 { top: 62%; right: 8%; animation: tagf 6s ease-in-out infinite 2s; }
  .at8 { top: 80%; right: 6%; animation: tagf 6s ease-in-out infinite 2.8s; }

  .ab-centre {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: #fff;
    border: 0.5px solid rgba(99,102,241,.15);
    border-radius: 20px;
    padding: 28px 36px;
    text-align: center;
    box-shadow: 0 4px 32px rgba(99,102,241,.08);
    min-width: 180px;
    z-index: 2;
  }
  .ab-pulse {
    position: absolute;
    inset: -6px;
    border-radius: 26px;
    border: 1px solid rgba(99,102,241,.2);
    animation: cpulse 3s ease-in-out infinite;
  }
  .ab-icon {
    width: 52px; height: 52px;
    border-radius: 14px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px;
  }
  .ab-ctitle { font-size: 15px; font-weight: 700; color: #1e293b; letter-spacing: -.02em; }
  .ab-csub   { font-size: 10px; color: #94a3b8; margin-top: 3px; font-weight: 500; }

  @keyframes drift1  { 0%,100% { transform: translate(0,0); }    50% { transform: translate(-20px,15px); } }
  @keyframes drift2  { 0%,100% { transform: translate(0,0); }    50% { transform: translate(15px,-20px); } }
  @keyframes drift3  { 0%,100% { transform: translate(0,0); }    50% { transform: translate(-12px,18px); } }
  @keyframes tagf    { 0%,100% { opacity:.7; transform:translateY(0); } 50% { opacity:1; transform:translateY(-3px); } }
  @keyframes cpulse  { 0%,100% { opacity:.2; transform:scale(1); }     50% { opacity:.6; transform:scale(1.03); } }
</style>