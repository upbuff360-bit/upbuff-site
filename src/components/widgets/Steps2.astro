---
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Button from '~/components/ui/Button.astro';
import type { Steps as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  callToAction = await Astro.slots.render('callToAction'),
  items = [],
  isReversed = false,
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<!-- FULL WIDTH BACKGROUND WRAPPER -->
<WidgetWrapper
  id={id}
  isDark={isDark}
  containerClass={`w-full bg-blue-50 dark:bg-transparent ${classes?.container ?? ''}`}
  bg={bg}
>
  <!-- CONTENT CONTAINER (MAX WIDTH CONTROLLED HERE) -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class={`flex flex-col gap-8 md:gap-12 md:flex-row ${isReversed ? 'md:flex-row-reverse' : ''}`}>

      <!-- LEFT SIDE -->
      <div class={`w-full lg:w-1/2 ${isReversed ? 'lg:ml-16 md:ml-8 ml-0' : 'lg:mr-16 md:mr-8 mr-0'}`}>

        <Headline
          title={title}
          subtitle={subtitle}
          tagline={tagline}
          classes={{
            container: 'text-center md:text-left rtl:md:text-right mb-4 md:mb-8',
            title: 'mb-4 text-3xl lg:text-4xl font-bold font-heading',
            subtitle: 'mb-8 text-xl text-muted dark:text-slate-400',
          }}
        />

        <div class="w-full text-center md:text-left rtl:md:text-right">
          {
            typeof callToAction === 'string' ? (
              <Fragment set:html={callToAction} />
            ) : (
              callToAction &&
              callToAction.text &&
              callToAction.href && (
                <Button
                  variant="primary"
                  {...callToAction}
                  class="mb-12 w-auto"
                />
              )
            )
          }
        </div>
      </div>

      <!-- RIGHT SIDE -->
      <div class="w-full lg:w-1/2">
        <ul class="space-y-8">
          {
            items && items.length
              ? items.map(({ title: title2, description, icon, href }, index) => (
                  <li class="flex md:-mx-4">

                    <!-- ICON -->
                    <div class="pr-3 sm:pl-3 rtl:pr-0 rtl:pl-3 rtl:sm:pl-0 rtl:sm:pr-3">
                      <span class="flex w-12 h-12 mx-auto items-center justify-center text-lg font-bold rounded-full bg-blue-100 text-primary">
                        {icon ? (
                          <Icon name={icon} class="w-5 h-5 icon-bold" />
                        ) : (
                          index + 1
                        )}
                      </span>
                    </div>

                    <!-- TEXT -->
                    <div class="pl-4 rtl:pl-0 rtl:pr-4">
                      <h3
                        class="mb-1 text-lg font-semibold font-heading leading-snug"
                        set:html={title2}
                      />

                      {href && (
                        <a
                          href={href}
                          class="inline-flex items-center gap-1 text-primary font-medium text-sm hover:underline"
                        >
                          <span>{description}</span>
                          <svg
                            class="w-3 h-3 mt-[1px]"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 18 18"
                            fill="currentColor"
                          >
                            <path d="M15 3.6c0-.4-.4-.6-.7-.6H4C2.7 3 2.7 5 4 5h7.6l-8.3 8.3c-.9 1 .6 2.4 1.5 1.3l8.3-8.2v7.5c0 1.4 1.9 1.4 1.9 0z"></path>
                          </svg>
                        </a>
                      )}
                    </div>

                  </li>
                ))
              : null
          }
        </ul>
      </div>

    </div>
  </div>
</WidgetWrapper>