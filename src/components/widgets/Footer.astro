---
import { Icon } from 'astro-icon/components';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  phone?: string;
  theme?: string;
}

const { socialLinks = [], links = [], footNote = '', phone } = Astro.props;
---

<footer class="relative bg-white border-t border-gray-100 not-prose overflow-hidden pb-0">

  <!-- Main footer content -->
  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 pt-14 pb-10">
    <div class="flex flex-col lg:flex-row lg:justify-between gap-12">

      <!-- Left column: logo, copyright, social icons -->
      <div class="flex flex-col gap-5 lg:w-56 shrink-0">

        <!-- Logo — place upbuff-logo.svg in /public/ -->
        <a href={getHomePermalink()} class="inline-flex items-center" aria-label="UpBuff home">
          <img
            src="/uploads/upbuff-logo-black.svg"
            alt="UpBuff"
            class="h-8 w-auto"
            loading="lazy"
          />
        </a>

        <!-- Copyright -->
        {footNote && (
          <p class="text-xs text-gray-500 leading-relaxed">
            <Fragment set:html={footNote} />
          </p>
        )}

        <!-- Social icon buttons — bordered squares like Chatbase -->
        {socialLinks?.length > 0 && (
          <div class="flex items-center gap-2 flex-wrap">
            {socialLinks.map(({ ariaLabel, href, icon }) => (
              <a
                href={href}
                aria-label={ariaLabel}
                target="_blank"
                rel="noopener noreferrer"
                class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-200 text-gray-500 hover:text-gray-900 hover:border-gray-400 transition-colors duration-150"
              >
                {icon && <Icon name={icon} class="w-4 h-4" />}
              </a>
            ))}
          </div>
        )}

        <!-- Contact phone -->
        {phone && (
          <a
            href={`tel:${phone.replace(/\s/g, '')}`}
            class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition-colors duration-150"
          >
            <Icon name="tabler:phone" class="w-4 h-4 shrink-0" />
            {phone}
          </a>
        )}

      </div>

      <!-- Right: nav columns -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 flex-1">
        {links.map(({ title, links: colLinks }) => (
          <div>
            <p class="text-[0.65rem] font-bold uppercase tracking-widest text-gray-900 mb-4">
              {title}
            </p>
            {colLinks?.length > 0 && (
              <ul class="flex flex-col gap-4">
                {colLinks.map(({ text, href, ariaLabel }) => (
                  <li class="leading-4">
                    <a
                      href={href}
                      aria-label={ariaLabel}
                      class="text-sm text-gray-500 hover:text-gray-900 transition-colors duration-150 leading-tight"
                    >
                      <Fragment set:html={text} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>

    </div>
  </div>

  <!-- Half-cut watermark logo — overflows the footer bottom -->
  <div
    class="relative max-w-5xl ml-auto px-4 sm:px-6 select-none pointer-events-none mt-8"
    aria-hidden="true"
    style="height: clamp(5rem, 14vw, 9rem); overflow: hidden;"
  >
    <img
      src="/uploads/upbuff-logo-black.svg"
      alt="upbuff logo"
      class="absolute bottom-0 right-0 w-auto opacity-[0.07]"
      style="height: clamp(10rem, 28vw, 18rem); transform: translateY(43%); filter: grayscale(1);"
    />
  </div>

</footer>