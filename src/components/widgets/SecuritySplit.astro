---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Image from '~/components/common/Image.astro';
import type { Widget } from '~/types';

export interface SecurityFeature {
  title: string;
  description?: string;
  illustration?: string;
  href?: string;      // optional link
  target?: string;    // optional target
}

export interface ComplianceBadge {
  image: string;
  alt?: string;
}

export interface Props extends Widget {
  tagline?: string;
  title?: string;
  subtitle?: string;
  badges?: Array<ComplianceBadge>;
  features?: Array<SecurityFeature>;
}

const {
  tagline,
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  badges = [],
  features = [],

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper
  id={id}
  isDark={isDark}
  containerClass={`max-w-5xl mx-auto ${(classes as Record<string, string>)?.container ?? ''}`}
  bg={bg}
>
  <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 items-start">

    <!-- Left column -->
    <div class="lg:w-5/12 shrink-0">

      {tagline && (
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 shadow-sm mb-5">
          <span class="w-2 h-2 rounded-full bg-pink-500 shrink-0" />
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300" set:html={tagline} />
        </div>
      )}

      {title && (
        <h2
          class="text-4xl md:text-5xl font-bold leading-tight tracking-tight font-heading text-heading dark:text-gray-100 mb-4"
          set:html={title}
        />
      )}

      {subtitle && (
        <p class="text-muted text-base leading-relaxed dark:text-slate-400 mb-6" set:html={subtitle} />
      )}

      {badges.length > 0 && (
        <div class="flex flex-wrap gap-4 items-center mt-2">
          {badges.map(({ image, alt = '' }) => (
            <div class="w-16 h-16 flex items-center justify-center">
              {image.startsWith('<')
                ? <Fragment set:html={image} />
                : <img src={image} alt={alt} class="w-full h-full object-contain grayscale" loading="lazy" />
              }
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Right panel -->
    {features.length > 0 && (
      <div class="flex-1 border border-gray-200 dark:border-gray-700 rounded-2xl overflow-hidden bg-white dark:bg-slate-900 shadow-sm divide-y divide-gray-200 dark:divide-gray-700">
        {features.map(({ title: ft, description, illustration, href, target }, i) => (
          <div
            class="flex items-center justify-between gap-6 px-7 py-6"
            style={`animation-delay: ${i * 80}ms`}
          >
            <!-- Text -->
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-bold text-heading dark:text-gray-100 mb-1">
                {ft}
              </h3>

              {description && (
                <p class="text-sm text-muted dark:text-slate-400 leading-relaxed mb-2" set:html={description} />
              )}

              {href && (
                <a
                  href={href}
                  target={target || '_self'}
                  class="inline-flex items-center gap-2 text-sm font-semibold text-purple-600 hover:text-purple-700 transition-colors group"
                >
                  Learn more
                  <span class="transition-transform group-hover:translate-x-1">→</span>
                </a>
              )}
            </div>

            <!-- Illustration (optional but unused in your case) -->
            {illustration && (
              <div class="shrink-0 w-24 h-20 flex items-center justify-end overflow-hidden">
                {illustration.startsWith('<')
                  ? <Fragment set:html={illustration} />
                  : <img src={illustration} alt={ft} class="w-full h-full object-contain" loading="lazy" />
                }
              </div>
            )}
          </div>
        ))}
      </div>
    )}

  </div>
</WidgetWrapper>