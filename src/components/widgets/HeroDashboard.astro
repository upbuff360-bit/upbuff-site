---
/**
 * HeroDashboard.astro
 * Animated dashboard illustration for the home page hero section.
 * Drop this directly into Hero2's image slot:
 *
 *   <Fragment slot="image">
 *     <HeroDashboard />
 *   </Fragment>
 */
---

<div class="hero-dashboard" aria-hidden="true">

  <!-- ── Floating integration badges ──────────────────────── -->

  <!-- SAP small — top-left -->
  <div class="badge badge-sm float-1" style="top:4%;left:8%">
    <div class="badge-inner" style="background:linear-gradient(135deg,#003f7c,#0070c0)">
      <span class="badge-text text-white font-bold text-xs">SAP</span>
    </div>
  </div>

  <!-- Epicor — top-center -->
  <div class="badge badge-lg float-2" style="top:1%;left:40%">
    <div class="badge-inner bg-white">
      <span class="badge-text font-bold text-sm" style="color:#e00000;letter-spacing:-0.5px">epicor</span>
    </div>
  </div>

  <!-- Outlook — top-right -->
  <div class="badge badge-sm float-3" style="top:5%;right:6%">
    <div class="badge-inner" style="background:linear-gradient(135deg,#0078d4,#00a4ef)">
      <span class="badge-text text-white font-bold text-sm">O</span>
    </div>
  </div>

  <!-- SAP S/4HANA — mid-left large -->
  <div class="badge badge-xl float-4" style="top:38%;left:0%">
    <div class="badge-inner bg-white">
      <div class="flex flex-col items-center justify-center gap-0">
        <span class="font-black text-sm leading-tight" style="color:#003f7c">SAP</span>
        <span class="font-bold text-[9px] leading-tight text-blue-800">S/4 HANA</span>
      </div>
    </div>
  </div>

  <!-- WhatsApp — bottom-left -->
  <div class="badge badge-sm float-5" style="bottom:12%;left:7%">
    <div class="badge-inner" style="background:#25d366">
      <svg class="w-5 h-5 text-white fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    </div>
  </div>

  <!-- SAP Business One — bottom-center -->
  <div class="badge badge-xl float-6" style="bottom:5%;left:37%">
    <div class="badge-inner bg-white">
      <div class="text-center">
        <span class="font-black text-sm leading-none" style="color:#003f7c">SAP</span><br>
        <span class="text-[8px] font-medium text-gray-500">Business One</span>
      </div>
    </div>
  </div>

  <!-- Oracle — bottom-right -->
  <div class="badge badge-lg float-7" style="bottom:9%;right:3%">
    <div class="badge-inner bg-white">
      <span class="font-black text-sm" style="color:#f80000">ORACLE</span>
    </div>
  </div>

  <!-- Google Calendar — bottom-center-left small -->
  <div class="badge badge-sm float-8" style="bottom:4%;left:22%">
    <div class="badge-inner bg-white">
      <span class="font-bold text-sm text-blue-600">31</span>
    </div>
  </div>

  <!-- Gmail — bottom-right small -->
  <div class="badge badge-sm float-9" style="bottom:4%;right:22%">
    <div class="badge-inner bg-white">
      <span class="font-bold text-sm" style="color:#EA4335">M</span>
    </div>
  </div>

  <!-- ── Main dashboard card ───────────────────────────────── -->
  <div class="dashboard-card">

    <!-- Sales bar chart panel -->
    <div class="panel panel-main">
      <div class="panel-header">
        <span class="panel-title">Sales</span>
        <div class="panel-tabs">
          <span class="tab active">Monthly</span>
          <span class="tab">Quarterly</span>
        </div>
      </div>

      <!-- Bar chart -->
      <div class="bar-chart">
        <div class="bars">
          <div class="bar-group" style="--d:0s">
            <div class="bar bar-1" style="--h:45%"></div>
            <div class="bar bar-2" style="--h:30%"></div>
          </div>
          <div class="bar-group" style="--d:0.15s">
            <div class="bar bar-1" style="--h:60%"></div>
            <div class="bar bar-2" style="--h:40%"></div>
          </div>
          <div class="bar-group" style="--d:0.3s">
            <div class="bar bar-1" style="--h:50%"></div>
            <div class="bar bar-2" style="--h:35%"></div>
          </div>
          <div class="bar-group" style="--d:0.45s">
            <div class="bar bar-1" style="--h:80%"></div>
            <div class="bar bar-2" style="--h:55%"></div>
          </div>
          <div class="bar-group" style="--d:0.6s">
            <div class="bar bar-1" style="--h:65%"></div>
            <div class="bar bar-2" style="--h:45%"></div>
          </div>
          <div class="bar-group" style="--d:0.75s">
            <div class="bar bar-1" style="--h:90%"></div>
            <div class="bar bar-2" style="--h:60%"></div>
          </div>
          <div class="bar-group" style="--d:0.9s">
            <div class="bar bar-1" style="--h:70%"></div>
            <div class="bar bar-2" style="--h:50%"></div>
          </div>
        </div>
        <div class="bar-labels">
          <span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span><span>May</span><span>Jun</span><span>Jul</span>
        </div>
      </div>

      <!-- Top products table -->
      <div class="table-section">
        <div class="table-header">
          <span>Top Products by <span class="text-blue-600">Sales</span></span>
          <span>by <span class="text-blue-600">Volume</span></span>
          <span class="text-gray-400">⋮</span>
        </div>
        <div class="table-row row-in"><span class="row-name">ERP-CRM Module</span><span class="row-val text-green-600">124k</span><span class="row-badge green">+12.4%</span></div>
        <div class="table-row row-in" style="animation-delay:.15s"><span class="row-name">Field Service</span><span class="row-val text-gray-700">74.9k</span><span class="row-badge red">-8.5%</span></div>
        <div class="table-row row-in" style="animation-delay:.3s"><span class="row-name">Warehouse Mgmt</span><span class="row-val text-green-600">52.1k</span><span class="row-badge green">+62.6%</span></div>
      </div>
    </div>

    <!-- Spinner panel (centre-right) -->
    <div class="panel panel-spinner">
      <div class="spinner-wrap">
        <div class="spinner"></div>
        <div class="spinner-inner"></div>
        <span class="spinner-label">Syncing<br>ERP</span>
      </div>
      <p class="spinner-sub">Real-time sync</p>
    </div>

  </div>

  <!-- ── Stocks card (floating right) ─────────────────────── -->
  <div class="stocks-card float-stocks">
    <div class="stocks-header">
      <span class="stocks-title">Stocks Today</span>
      <div class="stocks-accent"></div>
    </div>
    <div class="stocks-sub"><span class="text-gray-400 text-[10px]">By Trend</span></div>

    <!-- Donut chart — 3 segments, each continuously animating -->
    <div class="donut-wrap">
      <svg class="donut" viewBox="0 0 80 80">
        <circle class="donut-track" cx="40" cy="40" r="28" fill="none" stroke="#f3f4f6" stroke-width="12"/>
        <circle class="donut-green" cx="40" cy="40" r="28" fill="none" stroke="#22c55e" stroke-width="12"
          stroke-linecap="round" transform="rotate(-90 40 40)"/>
        <circle class="donut-red" cx="40" cy="40" r="28" fill="none" stroke="#ef4444" stroke-width="12"
          stroke-linecap="round" transform="rotate(-90 40 40)"/>
        <circle class="donut-blue" cx="40" cy="40" r="28" fill="none" stroke="#3b82f6" stroke-width="12"
          stroke-linecap="round" transform="rotate(-90 40 40)"/>
      </svg>
    </div>

    <div class="legend">
      <div class="legend-row"><span class="dot bg-green-500"></span><span>In Stock</span><span class="ml-auto font-semibold">500 Units</span></div>
      <div class="legend-row"><span class="dot bg-red-500"></span><span>Out of Stock</span><span class="ml-auto font-semibold">50</span></div>
      <div class="legend-row"><span class="dot bg-blue-500"></span><span>Low Stock</span><span class="ml-auto font-semibold">6</span></div>
    </div>
  </div>

</div>

<style>
  /* ── Container ───────────────────────────────────── */
  .hero-dashboard {
    position: relative;
    width: 100%;
    max-width: 560px;
    height: 440px;
    margin: 0 auto;
  }

  /* ── Floating badges ─────────────────────────────── */
  .badge {
    position: absolute;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 12px 12px rgba(0,0,0,0.16));
    z-index: 10;
  }
  .badge-sm  { width: 48px;  height: 48px;  }
  .badge-lg  { width: 80px;  height: 80px;  }
  .badge-xl  { width: 96px;  height: 96px;  }

  .badge-inner {
    width: 100%; height: 100%;
    border-radius: 9999px;
    display: flex; align-items: center; justify-content: center;
    border: 2px solid rgba(255,255,255,0.15);
  }
  .badge-text { line-height: 1; }

  /* Float animations */
  @keyframes float {
    0%,100% { transform: translateY(0px); }
    50%      { transform: translateY(-8px); }
  }
  .float-1 { animation: float 4.0s ease-in-out infinite; }
  .float-2 { animation: float 5.2s ease-in-out infinite 0.4s; }
  .float-3 { animation: float 3.8s ease-in-out infinite 1.1s; }
  .float-4 { animation: float 4.6s ease-in-out infinite 0.7s; }
  .float-5 { animation: float 5.0s ease-in-out infinite 1.5s; }
  .float-6 { animation: float 4.3s ease-in-out infinite 0.2s; }
  .float-7 { animation: float 3.9s ease-in-out infinite 0.9s; }
  .float-8 { animation: float 4.8s ease-in-out infinite 1.8s; }
  .float-9 { animation: float 5.1s ease-in-out infinite 0.5s; }

  /* ── Main dashboard card ─────────────────────────── */
  .dashboard-card {
    position: absolute;
    top: 14%; left: 14%; right: 26%; bottom: 14%;
    background: white;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    padding: 14px;
    display: flex;
    gap: 10px;
    overflow: hidden;
    z-index: 5;
    animation: cardIn 0.6s ease-out both;
  }
  @keyframes cardIn {
    from { opacity:0; transform: translateY(20px) scale(0.97); }
    to   { opacity:1; transform: translateY(0) scale(1); }
  }

  .panel-main    { flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .panel-spinner { width: 80px; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; gap: 6px; margin-bottom: 16px;}

  .panel-header { display: flex; align-items: center; justify-content: space-between; }
  .panel-title  { font-size: 11px; font-weight: 700; color: #111; }
  .panel-tabs   { display: flex; gap: 4px; }
  .tab          { font-size: 9px; padding: 2px 6px; border-radius: 4px; color: #9ca3af; cursor: pointer; }
  .tab.active   { background: #eff6ff; color: #2563eb; font-weight: 600; }

  /* ── Bar chart ───────────────────────────────────── */
  .bar-chart { flex: 1; display: flex; flex-direction: column; gap: 4px; }
  .bars { flex: 1; display: flex; align-items: flex-end; gap: 4px; padding-bottom: 2px; }
  .bar-group { flex: 1; display: flex; gap: 1px; align-items: flex-end; height: 110px; }
  .bar { flex: 1; border-radius: 3px 3px 0 0; }
  .bar-1 {
    background: linear-gradient(180deg, #22c55e, #16a34a);
    height: var(--h);
    animation: growBar 1s ease-out forwards 0.3s, pulseBar1 3s ease-in-out infinite calc(1.5s + var(--d, 0s));
  }
  .bar-2 {
    background: linear-gradient(180deg, #818cf8, #6366f1);
    height: var(--h);
    animation: growBar 1s ease-out forwards 0.5s, pulseBar2 3s ease-in-out infinite calc(2s + var(--d, 0s));
  }
  @keyframes growBar {
    from { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
    to   { transform: scaleY(1); transform-origin: bottom; opacity: 1; }
  }
  @keyframes pulseBar1 {
    0%,100% { transform: scaleY(1);    transform-origin: bottom; }
    50%      { transform: scaleY(1.18); transform-origin: bottom; }
  }
  @keyframes pulseBar2 {
    0%,100% { transform: scaleY(1);    transform-origin: bottom; }
    50%      { transform: scaleY(0.82); transform-origin: bottom; }
  }
  .bar-labels { display: flex; gap: 4px; }
  .bar-labels span { flex: 1; text-align: center; font-size: 7px; color: #9ca3af; }

  /* ── Table ───────────────────────────────────────── */
  .table-section { display: flex; flex-direction: column; gap: 3px; }
  .table-header  { display: flex; justify-content: space-between; font-size: 8px; color: #6b7280; padding: 2px 0; }
  .table-row {
    display: flex; align-items: center; gap: 4px;
    font-size: 8px; padding: 2px 0;
    opacity: 0;
    animation: rowIn 0.4s ease-out forwards 1.2s;
  }
  .row-in { animation: rowIn 0.4s ease-out forwards 1.2s; }
  @keyframes rowIn {
    from { opacity:0; transform: translateX(-8px); }
    to   { opacity:1; transform: translateX(0); }
  }
  .row-name { flex: 1; color: #374151; font-weight: 500; font-size: 10px;}
  .row-val  { width: 36px; text-align: right; font-weight: 600; font-size: 10px; }
  .row-badge { width: 36px; text-align: center; border-radius: 3px; font-size: 7px; font-weight: 600; padding: 1px 3px; }
  .row-badge.green { background: #dcfce7; color: #16a34a; }
  .row-badge.red   { background: #fee2e2; color: #dc2626; }

  /* ── Spinner ─────────────────────────────────────── */
  .spinner-wrap { position: relative; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; }
  .spinner {
    position: absolute; inset: 0; border-radius: 50%;
    border: 6px solid #e5e7eb;
    border-top-color: #6366f1;
    border-right-color: #3b82f6;
    animation: spin 1.8s linear infinite;
  }
  .spinner-inner {
    position: absolute; inset: 10px; border-radius: 50%;
    border: 4px solid transparent;
    border-bottom-color: #a78bfa;
    animation: spin 1.2s linear infinite reverse;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes stocksFloat {
    0%,100% { transform: translateY(0px); }
    50%      { transform: translateY(-8px); }
  }
  .spinner-label { font-size: 8px; font-weight: 600; color: #374151; text-align: center; line-height: 1.3; z-index: 1; }
  .spinner-sub   { font-size: 8px; color: #9ca3af; text-align: center; }

  /* ── Stocks card ─────────────────────────────────── */
  .stocks-card {
    position: absolute;
    top: 10%; right: 0;
    width: 44%;
    background: white;
    border-radius: 14px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    padding: 12px;
    z-index: 6;
  }
  .float-stocks {
    animation: stocksEntry 0.6s ease-out 0.2s both, stocksFloat 3.5s ease-in-out infinite 1s;
  }
  @keyframes stocksEntry {
    from { opacity: 0; transform: translateY(20px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0px) scale(1); }
  }

  .stocks-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; position: relative; }
  .stocks-title  { font-size: 11px; font-weight: 700; color: #111; }
  .stocks-accent {
    position: absolute; right: -12px; top: -12px;
    width: 40px; height: 40px; border-radius: 50%;
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    opacity: 0.6;
  }
  .stocks-sub { font-size: 9px; color: #374151; font-weight: 600; line-height: 1.4; margin-bottom: 6px; }

  /* ── Donut chart ─────────────────────────────────── */
  .donut-wrap { display: flex; justify-content: center; margin: 4px 0; }
  .donut { width: 80px; height: 80px; }

  /*
   * Total circumference of r=28 circle ≈ 176px.
   * Three segments: green=88, red=35, blue=18  (total=141, gap=35 hidden behind track)
   * Each segment gets:
   *   - initial draw-in animation (enters from 0)
   *   - then a continuous pulse that gently grows/shrinks its filled arc
   *   - offset animates in sync so segments stay butted up against each other
   */

  /* GREEN — starts at offset 0 (top of circle) */
  .donut-green {
    stroke-dasharray: 88 88;
    stroke-dashoffset: 0;
    animation:
      donutGreenIn    1.0s ease-out 0.5s both,
      donutGreenPulse 4.0s ease-in-out infinite 1.6s;
  }
  @keyframes donutGreenIn {
    from { stroke-dasharray: 0 176; stroke-dashoffset: 0; }
    to   { stroke-dasharray: 88 88; stroke-dashoffset: 0; }
  }
  /* Pulse: arc grows from 88→110 then shrinks back */
  @keyframes donutGreenPulse {
    0%,100% { stroke-dasharray:  88  88; }
    50%     { stroke-dasharray: 110  66; }
  }

  /* RED — starts right after green arc (offset = -88) */
  .donut-red {
    stroke-dasharray: 35 141;
    stroke-dashoffset: -88;
    animation:
      donutRedIn    1.0s ease-out 0.8s both,
      donutRedPulse 4.0s ease-in-out infinite 1.6s;
  }
  @keyframes donutRedIn {
    from { stroke-dasharray: 0 176; stroke-dashoffset: -88; }
    to   { stroke-dasharray: 35 141; stroke-dashoffset: -88; }
  }
  /* Pulse: arc grows from 35→55 then shrinks back */
  @keyframes donutRedPulse {
    0%,100% { stroke-dasharray:  35 141; stroke-dashoffset: -88; }
    50%     { stroke-dasharray:  55 121; stroke-dashoffset: -88; }
  }

  /* BLUE — starts right after red arc (offset = -(88+35) = -123) */
  .donut-blue {
    stroke-dasharray: 18 159;
    stroke-dashoffset: -123;
    animation:
      donutBlueIn    1.0s ease-out 1.1s both,
      donutBluePulse 4.0s ease-in-out infinite 1.6s;
  }
  @keyframes donutBlueIn {
    from { stroke-dasharray: 0 176;  stroke-dashoffset: -123; }
    to   { stroke-dasharray: 18 159; stroke-dashoffset: -123; }
  }
  /* Pulse: arc grows from 18→30 then shrinks back */
  @keyframes donutBluePulse {
    0%,100% { stroke-dasharray: 18 159; stroke-dashoffset: -123; }
    50%     { stroke-dasharray: 30 147; stroke-dashoffset: -123; }
  }

  .legend     { display: flex; flex-direction: column; gap: 3px; margin-top: 6px; }
  .legend-row { display: flex; align-items: center; gap: 4px; font-size: 8px; color: #374151; }
  .dot        { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
</style>