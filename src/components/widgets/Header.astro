---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ToggleTheme from '~/components/common/ToggleTheme.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import Button from '~/components/ui/Button.astro';

import { getHomePermalink } from '~/utils/permalinks';
import { trimSlash, getAsset } from '~/utils/permalinks';
import type { CallToAction } from '~/types';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
  description?: string;
}

interface MenuLink extends Link {
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  /**
   * Controls the header colour theme per page.
   *
   * - 'default'     → inherits page bg (existing behaviour, light/dark follows system)
   * - 'black'       → solid #000 background, white text & nav links
   * - 'white'       → solid #fff background, dark text & nav links
   * - 'transparent' → no background, text colour via isDark prop as before
   */
  theme?: 'default' | 'black' | 'white' | 'transparent';
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
  isDark = false,
  theme = 'default',
  isFullWidth = false,
  showToggleTheme = false,
  showRssFeed = false,
  position = 'center',
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;

// Derive classes from theme
const isBlackTheme       = theme === 'black';
const isWhiteTheme       = theme === 'white';
const isTransparentTheme = theme === 'transparent';

// Force dark mode class for themes that need it
const forceDark = isDark || isBlackTheme;

// Header background class
const headerBgClass =
  isBlackTheme       ? 'bg-black  text-white'  :
  isWhiteTheme       ? 'bg-white  text-gray-900' :
  isTransparentTheme ? 'bg-transparent'           :
  '';                                              // default: inherits page bg

// Nav link hover class
const navHoverClass =
  isBlackTheme  ? 'hover:text-gray-300' :
  isWhiteTheme  ? 'hover:text-gray-600' :
  'hover:text-link dark:hover:text-white';

// Dropdown menu background
const dropdownBgClass =
  isBlackTheme  ? 'md:bg-gray-900 border border-white/10' :
  isWhiteTheme  ? 'md:bg-white border border-gray-200' :
  'md:bg-white/90 dark:md:bg-dark';

// Dropdown item hover
const dropdownItemHoverClass =
  isBlackTheme  ? 'md:hover:bg-white/10 hover:text-white' :
  isWhiteTheme  ? 'md:hover:bg-gray-100 hover:text-gray-900' :
  'md:hover:bg-gray-100 hover:text-link dark:hover:text-white dark:hover:bg-gray-700';
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky, dark: forceDark },
    'top-0 z-40 flex-none mx-auto w-full border-t border-b border-gray-50/0 border-t-[rgb(48,48,48)] transition-[opacity] ease-in-out',
    headerBgClass,
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="absolute inset-0"></div>
  <div
    class:list={[
      'relative text-default py-1.5 px-4 sm:px-6 mx-auto w-full',
      { 'md:flex md:justify-between': position !== 'center' },
      { 'md:grid md:grid-cols-3 md:items-center': position === 'center' },
      { 'max-w-5xl': !isFullWidth },
    ]}
  >
    <div class:list={[{ 'mr-auto rtl:mr-0 rtl:ml-auto': position === 'right' }, 'flex justify-between']}>
      <a class="flex items-center" href={getHomePermalink()}>
        {isBlackTheme ? (
          <img src="/uploads/upbuff-logo-white.svg" alt="UpBuff" class="h-5 w-auto" loading="eager" />
        ) : (
          <Logo />
        )}
      </a>
      <div class="flex items-center md:hidden">
        <ToggleMenu />
      </div>
    </div>

    <nav
      class="items-center w-full md:w-auto hidden md:flex md:mx-5 text-default overflow-y-auto overflow-x-hidden md:overflow-y-visible md:overflow-x-auto md:justify-self-center"
      aria-label="Main navigation"
    >
      <ul
        class="flex flex-col md:flex-row md:self-center w-full md:w-auto text-base md:text-[0.75rem] tracking-[0.01rem] font-medium md:justify-center"
      >
        {
          links.map(({ text, href, links }) => (
            <li class={links?.length ? 'dropdown' : ''}>
              {links?.length ? (
                <>
                  <button
                    type="button"
                    class:list={['px-3 py-2 flex items-center whitespace-nowrap', navHoverClass]}
                  >
                    {text}{' '}
                    <Icon name="tabler:chevron-down" class="w-3.5 h-3.5 ml-0.5 rtl:ml-0 rtl:mr-0.5 hidden md:inline" />
                  </button>
                  <div class:list={[
                    'dropdown-menu md:backdrop-blur-md rounded-2xl md:absolute pl-4 md:pl-0 md:hidden border dropdown-animate',
                    isBlackTheme ? 'md:bg-[#111] border-white/10' : 'md:bg-white border-gray-300',
                  ]}
                    style={`min-width: ${links.length > 4 ? '640px' : '400px'}; left: 50%; transform: translateX(-50%);`}
                  >
                    <ul class:list={[
                      'p-3 grid gap-0.5',
                      links.length > 4 ? 'grid-cols-2' : 'grid-cols-1',
                    ]}>
                      {links.map(({ text: text2, href: href2, icon: icon2, description: desc2 }) => (
                        <li>
                          <a
                            href={href2}
                            class:list={[
                              'flex items-start gap-3 px-3 py-2 rounded-xl transition-colors duration-150',
                              isBlackTheme
                                ? 'hover:bg-white/10 text-white'
                                : 'hover:bg-gray-50 text-gray-900',
                              { 'aw-link-active': href2 === currentPath },
                            ]}
                          >
                            {icon2 && (
                              <span class:list={[
                                'w-7 h-7 rounded-lg flex items-center justify-center shrink-0 mt-0.5',
                                isBlackTheme ? 'bg-white/10' : 'bg-gray-100',
                              ]}>
                                <Icon name={icon2} class="w-3.5 h-3.5" />
                              </span>
                            )}
                            <span class="flex flex-col gap-0.5 min-w-0">
                              <span class="text-[0.75rem] font-semibold leading-snug">{text2}</span>
                              {desc2 && (
                                <span class:list={[
                                  'text-[0.65rem] font-normal leading-snug',
                                  isBlackTheme ? 'text-white/50' : 'text-gray-400',
                                ]}>
                                  {desc2}
                                </span>
                              )}
                            </span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </>
              ) : (
                <a
                  class:list={[
                    'px-3 py-2 flex items-center whitespace-nowrap',
                    navHoverClass,
                    { 'aw-link-active': href === currentPath },
                  ]}
                  href={href}
                >
                  {text}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <div
      class:list={[
        { 'ml-auto rtl:ml-0 rtl:mr-auto': position === 'left' },
        'hidden md:self-center md:flex items-center md:mb-0 fixed w-full md:w-auto md:static justify-end left-0 rtl:left-auto rtl:right-0 bottom-0 p-3 md:p-0 md:justify-self-end',
      ]}
    >
      <div class="items-center flex justify-between w-full md:w-auto">
        <!-- <div class="flex">
          {showToggleTheme && <ToggleTheme iconClass="w-6 h-6 md:w-5 md:h-5 md:inline-block" />}
          {showRssFeed && (
            <a
              class="text-muted dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 rounded-lg text-sm p-2.5 inline-flex items-center"
              aria-label="RSS Feed"
              href={getAsset('/rss.xml')}
            >
              <Icon name="tabler:rss" class="w-5 h-5" />
            </a>
          )}
        </div> -->
        {
          actions?.length ? (
            <span class="ml-4 rtl:ml-0 rtl:mr-4">
              {actions.map((btnProps) => (
                <Button {...btnProps} class="ml-2 py-2 px-4 md:px-5 font-semibold shadow-none text-xs w-auto" />
              ))}
            </span>
          ) : (
            ''
          )
        }
      </div>
    </div>
  </div>
</header>

<style>
  @keyframes dropdown-in {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(-10px) scaleY(0.95);
      transform-origin: top center;
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0) scaleY(1);
      transform-origin: top center;
    }
  }

  .dropdown-animate {
    animation: dropdown-in 0.2s cubic-bezier(0.16, 1, 0.3, 1) both;
    transform-origin: top center;
  }
</style>