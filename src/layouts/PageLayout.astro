---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import Announcement from '~/components/widgets/Announcement.astro';

import { headerData, footerData } from '~/navigation';
import type { MetaData, CallToAction } from '~/types';

export interface Props {
  metadata?: MetaData;
  /**
   * Header colour theme for this page.
   * 'black'  — dark hero pages (default)
   * 'white'  — light hero pages (index, integrations, industry, security)
   */
  headerTheme?: 'black' | 'white' | 'default' | 'transparent';
}

const { metadata, headerTheme = 'black' } = Astro.props;

// Cast actions to CallToAction[] so TypeScript accepts the narrow variant union
const headerActions = (headerData.actions ?? []) as CallToAction[];
---

<Layout metadata={metadata}>

  <Fragment slot="head">
    <slot name="head" />
  </Fragment>

  <slot name="announcement" />

  <!-- Common header — Announcement + nav bar together, both sticky -->
  <slot name="header">
    <div class="sticky top-0 z-40">
      <Announcement />
      <Header
        links={headerData.links}
        actions={headerActions}
        theme={headerTheme}
        isSticky={false}
      />
    </div>
  </slot>

  <main>
    <slot />
  </main>

  <slot name="footer">
    <Footer {...footerData} />
  </slot>

</Layout>