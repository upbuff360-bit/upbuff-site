---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import LogoBar from '~/components/widgets/LogoBar.astro';
import ProblemSplit from '~/components/widgets/ProblemSplit.astro';
import FeaturesHighlights from '~/components/widgets/FeaturesHighlights.astro';
import FeaturesGrid from '~/components/widgets/FeaturesGrid.astro';
import FeaturesCarousel from '~/components/widgets/FeaturesCarousel.astro';
import FeaturesBento from '~/components/widgets/FeaturesBento.astro';
import ContentSplitCard from '~/components/widgets/ContentSplitCard.astro';
import ToolsMarquee from '~/components/widgets/ToolsMarquee.astro';
import TestimonialsGrid from '~/components/widgets/TestimonialsGrid.astro';
import FaqAccordion from '~/components/widgets/FaqAccordion.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';

import HeroSolutionsIllustration from '~/components/widgets/HeroSolutionsIllustration.astro';

import { headerData } from '~/navigation';

const metadata = {
  title: 'ERP Execution Solutions by Industry | SAP Clean Core Extension Platform | UpBuff',
  description:
    'Industry-based ERP execution solutions for SAP S/4HANA, ECC, and Business One. Extend manufacturing, warehouse, field service, and sales operations without modifying your SAP core.',
  canonical: 'https://www.upbuff.com/solutions/',
  robots: { index: true, follow: true },
  openGraph: {
    type: 'website',
    url: 'https://www.upbuff.com/solutions/',
    title: 'ERP Execution Solutions for SAP Industries | UpBuff',
    description:
      'Extend SAP without customization. UpBuff enables manufacturing, warehouse, field service, and sales execution while keeping your ERP core clean.',
    image: 'https://www.upbuff.com/images/industry-execution-layer.png',
  },
  twitter: {
    cardType: 'summary_large_image',
    title: 'ERP Execution Solutions by Industry | UpBuff',
    description: 'Extend SAP without customization. Clean Core execution for manufacturing, warehouse, field service, and sales.',
  },
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <meta name="author" content="UpBuff Technologies" />

    <!-- Organization schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "UpBuff Technologies",
      "url": "https://www.upbuff.com",
      "logo": "https://www.upbuff.com/logo.png",
      "description": "UpBuff is an ERP Execution Platform extending SAP environments without modifying the ERP core.",
      "sameAs": ["https://www.linkedin.com/company/upbuff"]
    })} />

    <!-- WebSite schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": "https://www.upbuff.com",
      "name": "UpBuff ERP Execution Platform"
    })} />

    <!-- SoftwareApplication schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "UpBuff ERP Execution Platform",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web, Android, iOS",
      "description": "Industry-focused ERP execution platform extending SAP S/4HANA, ECC, and Business One without ERP customization.",
      "url": "https://www.upbuff.com/solutions/",
      "featureList": [
        "Manufacturing & Shopfloor Execution",
        "Warehouse & Inventory Management",
        "Field Service Management",
        "Sales & Distribution Execution",
        "Clean Core SAP Integration",
        "Mobile-First Operations"
      ],
      "softwareRequirements": "SAP S/4HANA, SAP ECC, SAP Business One, Epicor ERP, or Oracle ERP",
      "provider": {
        "@type": "Organization",
        "name": "UpBuff Technologies",
        "url": "https://www.upbuff.com"
      }
    })} />

    <!-- FAQPage schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Does UpBuff modify SAP core?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. UpBuff follows a Clean Core strategy and integrates via secure APIs without modifying SAP S/4HANA, ECC, or Business One." }
        },
        {
          "@type": "Question",
          "name": "Which industries benefit from UpBuff?",
          "acceptedAnswer": { "@type": "Answer", "text": "Manufacturing, distribution, warehouse-intensive enterprises, field service industries, SAP-driven sales organizations, plant maintenance teams, and retail/trade execution teams benefit from UpBuff's execution layer model." }
        },
        {
          "@type": "Question",
          "name": "How does UpBuff integrate with SAP?",
          "acceptedAnswer": { "@type": "Answer", "text": "UpBuff integrates via SAP Service Layer, OData, and BAPI — official API-based integration methods that require no ERP core modification and remain upgrade-safe." }
        },
        {
          "@type": "Question",
          "name": "Can UpBuff work offline?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. UpBuff supports offline scanning and execution for warehouse and field service workflows, syncing automatically when connectivity is restored." }
        }
      ]
    })} />
  </Fragment>

  <Fragment slot="header">
    <Header
      {...headerData}
      theme="white"
      actions={[
        { variant: 'secondary', text: 'Login', href: '#' },
        { variant: 'primary',   text: 'Request Demo', href: '/contact' },
      ]}
      isSticky
    />
  </Fragment>

  <!-- ══════════════════════════════════════════════════════════
       1. HERO — animated ERP execution layer
       ══════════════════════════════════════════════════════════ -->
  <Hero2
    tagline="Industry Solutions"
    actions={[
      { variant: 'primary', text: 'Request an ERP Execution Assessment', href: '/contact' },
      { text: 'Speak with Our SAP Experts', href: '/contact', icon: 'tabler:message-circle' },
    ]}
    image={{ src: 'http://4.151.8.142:4000/uploads/Industry-Solutions.png', alt: 'UpBuff ERP Execution Solutions by Industry' }}
  >
    <Fragment slot="title">
      Extend SAP. Transform Industry Execution. <span class="text-accent dark:text-white">Keep the Core Clean.</span>
    </Fragment>
    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        Enterprise SAP systems like SAP S/4HANA, SAP ECC, and SAP Business One are built as systems of record. They
        manage finance, compliance, and enterprise data integrity. But industry operations — shopfloors, warehouses,
        field teams, and sales mobility — require speed, mobility, and adaptability. UpBuff acts as an
        <strong>ERP Execution Layer</strong>, extending SAP environments without modifying the ERP core.
      </span>
    </Fragment>
  </Hero2>

  <!-- ══════════════════════════════════════════════════════════
       2. LOGO BAR
       ══════════════════════════════════════════════════════════ -->
  <LogoBar
    label="ERP Integration and Scalable Solutions for Industry Operations and Execution"
    logos={[
      { src: 'http://4.151.8.142:4000/uploads/logo/sap-s4-hanna-integration-with-upbuff-crm.png', alt: 'SAP S/4HANA' },
      { src: 'http://4.151.8.142:4000/uploads/logo/sap-integration-with-upbuff-crm.png',          alt: 'SAP Business One' },
      { src: 'http://4.151.8.142:4000/uploads/logo/oracle-integration-with-upbuff-crm.png',       alt: 'Oracle ERP' },
      { src: 'http://4.151.8.142:4000/uploads/logo/epicore-integration-with-upbuff-crm.png',      alt: 'Epicor ERP' },
      { src: 'http://4.151.8.142:4000/uploads/logo/zoho-integration-with-upbuff-crm.png',         alt: 'Zoho' },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       3. PROBLEM SPLIT — why SAP customization fails
       ══════════════════════════════════════════════════════════ -->
  <ProblemSplit
    tagline="The Problem"
    title="SAP customization blocks industry execution"
    subtitle="Most enterprises try to extend SAP for field, warehouse, and shopfloor operations by customizing the ERP core. That creates compounding risk at every upgrade cycle."
    items={[
      {
        title: 'Shopfloor & field teams lack mobile interfaces',
        description: 'SAP screens were designed for desk-based users. Operators, technicians, and field reps work from mobile devices in conditions where ERP complexity is a liability, not an asset.',
      },
      {
        title: 'Custom SAP modifications block upgrades',
        description: 'Every customization inside SAP becomes a regression risk at upgrade time. Routine upgrade cycles become multi-month re-implementation projects with significant consultant cost.',
      },
      {
        title: 'Industry operations need speed — ERP needs stability',
        description: 'Shopfloor confirmations, warehouse scans, and field service updates happen in real time. ERP governance requirements mean these workflows cannot live safely inside a customized SAP core.',
      },
      {
        title: 'Scaling to new sites means replicating fragile custom code',
        description: 'Custom SAP configurations do not scale cleanly across multiple plants, warehouses, or territories — each new location inherits the same technical debt and fragility.',
      },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       4. FEATURES HIGHLIGHTS — 4 industry verticals
       ══════════════════════════════════════════════════════════ -->
  <FeaturesHighlights
    tagline="Industry Verticals"
    title="Built for six industry execution challenges"
    subtitle="UpBuff delivers purpose-built execution workflows for each industry — all connecting to SAP without any ERP core modification."
    items={[
      {
        title: 'Manufacturing & Shopfloor Execution',
        description: 'Mobile production order execution, barcode-driven material issue, real-time WIP tracking, quality checkpoints at operator level, and instant synchronization with SAP PP and MM. Shopfloor operators get purpose-built interfaces — SAP stays the system of record.',
        image: '<style>.mf{width:100%;height:100%;background:#f0f9ff;display:flex;align-items:center;justify-content:center;gap:20px;padding:20px}.mf-line{display:flex;flex-direction:column;gap:8px}.mf-step{display:flex;align-items:center;gap:10px;background:#fff;border:0.5px solid #bfdbfe;border-radius:10px;padding:9px 14px;min-width:148px}.mf-ic{width:30px;height:30px;border-radius:8px;background:#1d4ed8;display:flex;align-items:center;justify-content:center;flex-shrink:0}.mf-t{font-size:11px;font-weight:600;color:#1e3a5f;flex:1}.mf-ok{width:18px;height:18px;border-radius:50%;background:#f0fdf4;border:0.5px solid #bbf7d0;display:flex;align-items:center;justify-content:center;flex-shrink:0}.mf-s1{animation:mfin 4s ease-in-out infinite 0s}.mf-s2{animation:mfin 4s ease-in-out infinite .5s}.mf-s3{animation:mfin 4s ease-in-out infinite 1s}.mf-s4{animation:mfin 4s ease-in-out infinite 1.5s}.mf-bar{width:6px;height:110px;background:#dbeafe;border-radius:3px;position:relative;overflow:hidden}.mf-bar::after{content:"";position:absolute;bottom:0;left:0;width:100%;background:#1d4ed8;border-radius:2px;animation:mfbar 3s ease-in-out infinite}.mf-b2::after{animation-delay:.8s;background:#0891b2}.mf-b3::after{animation-delay:1.6s}@keyframes mfin{0%,5%{opacity:.4;transform:translateX(-4px)}20%,80%{opacity:1;transform:translateX(0)}95%,100%{opacity:.4}}@keyframes mfbar{0%,100%{height:20%}50%{height:85%}}</style><div class="mf"><div style="display:flex;gap:4px;align-items:flex-end"><div class="mf-bar"></div><div class="mf-bar mf-b2"></div><div class="mf-bar mf-b3"></div></div><div class="mf-line"><div class="mf-step mf-s1"><div class="mf-ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 12v5M9.5 12v5M14.5 12v5"/></svg></div><span class="mf-t">Confirm order</span><div class="mf-ok"><svg width="9" height="9" viewBox="0 0 8 8" fill="none"><path d="M1.5 4l2 2 3-3" stroke="#16a34a" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></div></div><div class="mf-step mf-s2"><div class="mf-ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg></div><span class="mf-t">Scan material</span><div class="mf-ok"><svg width="9" height="9" viewBox="0 0 8 8" fill="none"><path d="M1.5 4l2 2 3-3" stroke="#16a34a" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></div></div><div class="mf-step mf-s3"><div class="mf-ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg></div><span class="mf-t">QC check</span><div class="mf-ok"><svg width="9" height="9" viewBox="0 0 8 8" fill="none"><path d="M1.5 4l2 2 3-3" stroke="#16a34a" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></div></div><div class="mf-step mf-s4"><div class="mf-ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v6c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/></svg></div><span class="mf-t">Post to SAP PP</span><div class="mf-ok"><svg width="9" height="9" viewBox="0 0 8 8" fill="none"><path d="M1.5 4l2 2 3-3" stroke="#16a34a" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></div></div></div></div>',
      },
      {
        title: 'Warehouse & Distribution Execution',
        description: 'Mobile GRPO and put-away, picking and packing workflows, batch and serial tracking, offline scanning capability, and direct SAP synchronization. Warehouse operators get scanning-friendly workflows — no custom SAP add-ons required.',
        image: '<style>.wh{width:100%;height:100%;background:#f0fdf4;display:flex;align-items:center;justify-content:center;padding:14px;gap:18px}.wh-phone{width:60px;height:96px;border-radius:12px;border:2.5px solid #15803d;background:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;position:relative}.wh-scan{width:42px;height:26px;border:1.5px solid #15803d;border-radius:4px;display:flex;align-items:center;justify-content:center}.wh-beam{width:30px;height:2px;background:#22c55e;animation:whbeam 1.2s ease-in-out infinite}.wh-home{width:11px;height:11px;border-radius:50%;border:2px solid #15803d;margin-top:2px}.wh-rows{display:flex;flex-direction:column;gap:7px}.wh-row{display:flex;align-items:center;gap:8px;background:#fff;border:0.5px solid #bbf7d0;border-radius:8px;padding:7px 11px}.wh-sku{font-size:11px;font-weight:700;color:#15803d;width:54px}.wh-tag{font-size:10px;color:#94a3b8;flex:1}.wh-ok{width:16px;height:16px;border-radius:50%;background:#f0fdf4;border:0.5px solid #bbf7d0;display:flex;align-items:center;justify-content:center;flex-shrink:0;animation:whok 3s ease-in-out infinite}.wh-ok2{animation-delay:.5s}.wh-ok3{animation-delay:1s}@keyframes whbeam{0%,100%{transform:translateY(-4px);opacity:.4}50%{transform:translateY(4px);opacity:1}}@keyframes whok{0%,30%{background:#f0fdf4}35%,100%{background:#dcfce7}}</style><div class="wh"><div class="wh-phone"><div class="wh-scan"><div class="wh-beam"></div></div><div class="wh-home"></div></div><div class="wh-rows"><div class="wh-row"><span class="wh-sku">SKU-4821</span><span class="wh-tag">Put-away</span><div class="wh-ok"><svg width="9" height="9" viewBox="0 0 8 8" fill="none"><path d="M1.5 4l2 2 3-3" stroke="#16a34a" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></div></div><div class="wh-row"><span class="wh-sku">SKU-0032</span><span class="wh-tag">Pick · B12</span><div class="wh-ok wh-ok2"><svg width="9" height="9" viewBox="0 0 8 8" fill="none"><path d="M1.5 4l2 2 3-3" stroke="#16a34a" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></div></div><div class="wh-row"><span class="wh-sku">SKU-1109</span><span class="wh-tag">GRPO</span><div class="wh-ok wh-ok3"><svg width="9" height="9" viewBox="0 0 8 8" fill="none"><path d="M1.5 4l2 2 3-3" stroke="#16a34a" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></div></div></div></div>',
      },
      {
        title: 'Field Service & Asset Management',
        description: 'Mobile work order management, geo-tagged job updates, parts consumption capture, digital signatures and proof-of-service, and direct SAP integration. Field technicians close jobs in the field — billing delays are eliminated.',
        image: '<style>.fs{width:100%;height:100%;background:#fff7ed;display:flex;align-items:center;justify-content:center;padding:20px;gap:18px}.fs-map{width:106px;height:120px;background:#fff;border:0.5px solid #fed7aa;border-radius:12px;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}.fs-pin{position:absolute;animation:fspin 3s ease-in-out infinite}.fs-p1{top:20%;left:25%}.fs-p2{top:52%;left:58%;animation-delay:.8s}.fs-p3{top:68%;left:18%;animation-delay:1.6s}.fs-info{display:flex;flex-direction:column;gap:7px}.fs-row{display:flex;align-items:center;gap:8px;background:#fff;border:0.5px solid #fed7aa;border-radius:8px;padding:7px 12px}.fs-t{font-size:11px;font-weight:500;color:#9a3412}@keyframes fspin{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:1;transform:scale(1.2)}}</style><div class="fs"><div class="fs-map"><svg style="position:absolute;inset:0;opacity:.25" viewBox="0 0 80 90"><path d="M0 30h80M0 60h80M27 0v90M53 0v90" stroke="#fed7aa" stroke-width="0.5"/></svg><div class="fs-pin fs-p1"><svg width="14" height="14" viewBox="0 0 24 24" fill="#ea580c"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg></div><div class="fs-pin fs-p2"><svg width="12" height="12" viewBox="0 0 24 24" fill="#fb923c"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg></div><div class="fs-pin fs-p3"><svg width="10" height="10" viewBox="0 0 24 24" fill="#fdba74"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg></div></div><div class="fs-info"><div class="fs-row"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c2410c" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M9 7h6M9 11h6M9 15h3"/></svg><span class="fs-t">WO-2241 open</span></div><div class="fs-row"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c2410c" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span class="fs-t">Geo-tagged</span></div><div class="fs-row"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c2410c" stroke-width="2"><path d="M15 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V9z"/><polyline points="15 3 15 9 21 9"/></svg><span class="fs-t">Signed · posted</span></div></div></div>',
      },
      {
        title: 'Sales & Distribution Execution',
        description: 'Mobile order creation, lead and opportunity tracking, collection capture, customer visit logging, and real-time SAP sync. Sales reps create orders in the field with live SAP pricing and inventory — no duplicate entry, no ERP customization required.',
        image: '<style>.sl{width:100%;height:100%;background:#f5f3ff;display:flex;align-items:center;justify-content:center;padding:14px;gap:18px}.sl-phone{width:58px;height:96px;border-radius:12px;border:2.5px solid #7c3aed;background:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;padding:5px}.sl-order{width:42px;background:#ede9fe;border-radius:5px;padding:4px 5px}.sl-ol{height:2.5px;border-radius:1px;background:#7c3aed;margin-bottom:2px}.sl-total{font-size:9px;font-weight:700;color:#6d28d9;text-align:right}.sl-btn{width:40px;height:13px;background:#7c3aed;border-radius:4px}.sl-steps{display:flex;flex-direction:column;gap:7px}.sl-step{display:flex;align-items:center;gap:8px;background:#fff;border:0.5px solid #ddd6fe;border-radius:8px;padding:7px 11px;animation:slstep 4s ease-in-out infinite}.sl-step:nth-child(2){animation-delay:.6s}.sl-step:nth-child(3){animation-delay:1.2s}.sl-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}.sl-t{font-size:11px;font-weight:500;color:#4c1d95}@keyframes slstep{0%,10%{opacity:.4}25%,80%{opacity:1}95%,100%{opacity:.4}}</style><div class="sl"><div class="sl-phone"><div class="sl-order"><div class="sl-ol" style="width:70%"></div><div class="sl-ol" style="width:90%"></div><div class="sl-ol" style="width:55%"></div><div class="sl-total">₹4,200</div></div><div class="sl-btn"></div></div><div class="sl-steps"><div class="sl-step"><div class="sl-dot" style="background:#7c3aed"></div><span class="sl-t">Visit logged</span></div><div class="sl-step"><div class="sl-dot" style="background:#6366f1"></div><span class="sl-t">Order created</span></div><div class="sl-step"><div class="sl-dot" style="background:#22c55e"></div><span class="sl-t">SAP SD synced</span></div></div></div>',
      },
      {
