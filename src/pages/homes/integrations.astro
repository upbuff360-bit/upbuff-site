---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';

import LogoBar from '~/components/widgets/LogoBar.astro';
import ContentSplitCard from '~/components/widgets/ContentSplitCard.astro';
import FeaturesHighlights from '~/components/widgets/FeaturesHighlights.astro';
import FeaturesBento from '~/components/widgets/FeaturesBento.astro';
import FeaturesCarousel from '~/components/widgets/FeaturesCarousel.astro';
import FeaturesGrid from '~/components/widgets/FeaturesGrid.astro';
import ProblemSplit from '~/components/widgets/ProblemSplit.astro';
import ToolsMarquee from '~/components/widgets/ToolsMarquee.astro';
import FeaturesEnterprise from '~/components/widgets/FeaturesEnterprise.astro';
import TestimonialsGrid from '~/components/widgets/TestimonialsGrid.astro';
import FaqAccordion from '~/components/widgets/FaqAccordion.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';

import { headerData } from '~/navigation';

const metadata = {
  title: 'ERP Integrations with SAP, Epicor & Oracle | Clean Core Execution Platform | UpBuff',
  description:
    'UpBuff integrates with SAP S/4HANA, ECC, Business One, Epicor, and Oracle ERP without modifying the core. API-based, upgrade-safe execution layer architecture.',
  canonical: 'https://www.upbuff.com/integrations/',
  robots: { index: true, follow: true },
  openGraph: {
    type: 'website',
    url: 'https://www.upbuff.com/integrations/',
    title: 'ERP Integrations with SAP, Epicor & Oracle | UpBuff',
    description: 'API-based ERP integration platform extending SAP, Epicor, and Oracle environments without customization risk.',
    image: 'https://www.upbuff.com/images/erp-integration-architecture.png',
    site_name: 'UpBuff',
    locale: 'en_US',
  },
  twitter: {
    cardType: 'summary_large_image',
    title: 'ERP Integrations | UpBuff Clean Core Execution Platform',
    description: 'Integrate SAP, Oracle, and Epicor ERP without core modifications — API-first, upgrade-safe architecture.',
    site: '@upbufftech',
  },
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <!-- ── Core meta ──────────────────────────────────────── -->
    <meta name="author"   content="UpBuff Technologies" />
    <meta name="keywords" content="ERP integration, SAP integration, SAP S/4HANA API, SAP Business One Service Layer, Oracle ERP integration, Epicor ERP REST API, Clean Core strategy, ERP execution layer, upgrade-safe SAP extension, no ERP customization" />
    <meta name="robots"   content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

    <!-- ── Open Graph (full set) ─────────────────────────── -->
    <meta property="og:site_name"     content="UpBuff" />
    <meta property="og:locale"        content="en_US" />
    <meta property="og:image:width"   content="1200" />
    <meta property="og:image:height"  content="630" />
    <meta property="og:image:alt"     content="UpBuff ERP integration architecture — SAP, Oracle, Epicor Clean Core execution platform" />

    <!-- ── Twitter Card (full set) ──────────────────────── -->
    <meta name="twitter:site"    content="@upbufftech" />
    <meta name="twitter:creator" content="@upbufftech" />
    <meta name="twitter:image"   content="https://www.upbuff.com/images/erp-integration-architecture.png" />

    <!-- ── Preconnect for performance ───────────────────── -->
    <link rel="preconnect" href="http://4.151.8.142:4000" />

    <!-- ── Schema: Organization ─────────────────────────── -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "UpBuff Technologies",
      "url": "https://www.upbuff.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.upbuff.com/logo.png",
        "width": 200,
        "height": 60
      },
      "description": "UpBuff is an ERP Execution Platform integrating with SAP, Epicor, and Oracle without modifying ERP core systems.",
      "sameAs": [
        "https://www.linkedin.com/company/upbuff"
      ],
      "areaServed": "Worldwide",
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "sales",
        "url": "https://www.upbuff.com/contact"
      }
    })} />

    <!-- ── Schema: WebSite ───────────────────────────────── -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "UpBuff ERP Execution Platform",
      "url": "https://www.upbuff.com",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://www.upbuff.com/?s={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- ── Schema: WebPage ───────────────────────────────── -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "ERP Integrations with SAP, Epicor & Oracle | Clean Core Execution Platform | UpBuff",
      "description": "UpBuff integrates with SAP S/4HANA, ECC, Business One, Epicor, and Oracle ERP without modifying the core. API-based, upgrade-safe execution layer architecture.",
      "url": "https://www.upbuff.com/integrations/",
      "inLanguage": "en-US",
      "isPartOf": { "@type": "WebSite", "url": "https://www.upbuff.com" },
      "about": {
        "@type": "Thing",
        "name": "ERP Integration Platform"
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",        "item": "https://www.upbuff.com" },
          { "@type": "ListItem", "position": 2, "name": "Integrations","item": "https://www.upbuff.com/integrations/" }
        ]
      }
    })} />

    <!-- ── Schema: BreadcrumbList (standalone for SERP sitelinks) ── -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",         "item": "https://www.upbuff.com" },
        { "@type": "ListItem", "position": 2, "name": "Integrations", "item": "https://www.upbuff.com/integrations/" }
      ]
    })} />

    <!-- ── Schema: SoftwareApplication ──────────────────── -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "UpBuff ERP Execution Platform",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web, Android, iOS",
      "url": "https://www.upbuff.com/integrations/",
      "description": "Execution layer platform integrating with SAP S/4HANA, ECC, Business One, Epicor ERP, and Oracle ERP without modifying the core.",
      "featureList": [
        "SAP S/4HANA OData & Standard API integration",
        "SAP ECC RFC/BAPI integration",
        "SAP Business One Service Layer integration",
        "Epicor ERP REST API & Service Connect",
        "Oracle ERP REST API & Oracle Integration Cloud (OIC)",
        "Clean Core architecture — no ERP core modifications",
        "Upgrade-safe API-only integration",
        "Mobile-first execution layer",
        "Real-time bidirectional ERP synchronization",
        "Offline capability for warehouse and field teams"
      ],
      "softwareRequirements": "SAP S/4HANA, SAP ECC, SAP Business One, Epicor ERP, or Oracle ERP",
      "provider": {
        "@type": "Organization",
        "name": "UpBuff Technologies",
        "url": "https://www.upbuff.com"
      }
    })} />

    <!-- ── Schema: ItemList — ERP platforms covered ──────── -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "ERP Platforms supported by UpBuff",
      "description": "Enterprise ERP systems that UpBuff integrates with using a Clean Core, API-first architecture.",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "SAP S/4HANA",     "url": "https://www.upbuff.com/integrations/sap-s4hana/" },
        { "@type": "ListItem", "position": 2, "name": "SAP ECC",          "url": "https://www.upbuff.com/integrations/sap-ecc/" },
        { "@type": "ListItem", "position": 3, "name": "SAP Business One", "url": "https://www.upbuff.com/integrations/sap-business-one/" },
        { "@type": "ListItem", "position": 4, "name": "Epicor ERP",       "url": "https://www.upbuff.com/integrations/epicor/" },
        { "@type": "ListItem", "position": 5, "name": "Oracle ERP",       "url": "https://www.upbuff.com/integrations/oracle/" }
      ]
    })} />

    <!-- ── Schema: FAQPage — all 6 FAQs ─────────────────── -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Does UpBuff modify ERP core systems?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. UpBuff integrates using official APIs and service layers — SAP Service Layer, OData, RFC/BAPI, Oracle REST APIs, Epicor Service Connect — following a Clean Core strategy without modifying ERP core systems, database tables, or core business logic." }
        },
        {
          "@type": "Question",
          "name": "Which ERP systems does UpBuff integrate with?",
          "acceptedAnswer": { "@type": "Answer", "text": "UpBuff integrates with SAP S/4HANA (OData, Standard APIs, BTP), SAP ECC (RFC/BAPI, OData extensions), SAP Business One (Service Layer, DI-API), Epicor ERP (REST, Service Connect), and Oracle ERP including Oracle Cloud (REST APIs, OIC)." }
        },
        {
          "@type": "Question",
          "name": "How long does a typical ERP integration take?",
          "acceptedAnswer": { "@type": "Answer", "text": "Standard integrations with SAP Business One or S/4HANA are typically live in 4–8 weeks depending on module scope and workflow complexity. Complex multi-instance or multi-ERP deployments are scoped individually with dedicated integration engineering support." }
        },
        {
          "@type": "Question",
          "name": "Is UpBuff compatible with SAP upgrade roadmaps including S/4HANA migration?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. UpBuff follows SAP Clean Core principles and integrates exclusively via official SAP APIs. This makes it fully compatible with S/4HANA upgrade strategies, SAP ECC to S/4HANA migrations, RISE with SAP, and SAP BTP environments." }
        },
        {
          "@type": "Question",
          "name": "Can UpBuff connect to Oracle Cloud ERP?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. UpBuff integrates with Oracle Cloud ERP via Oracle REST APIs and Oracle Integration Cloud (OIC). On-premise Oracle ERP environments use secure web service connectors. Both deployment models are supported with the same Clean Core, no-modification approach." }
        },
        {
          "@type": "Question",
          "name": "Can UpBuff integrate with third-party platforms as well as ERP?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Beyond ERP integration, UpBuff connects with WhatsApp Business, Shopify, Salesforce, Zapier, Tally, Unicommerce, IndiaMART, Zoho, and other enterprise platforms — creating a fully connected digital ecosystem with ERP at the core." }
        }
      ]
    })} />
  </Fragment>

  <Fragment slot="announcement" />

  <Fragment slot="header">
    <Header
      {...headerData}
      theme="white"
      actions={[
        { variant: 'secondary', text: 'Login',  href: '#' },
        { variant: 'primary',   text: 'Request Assessment', href: '/contact' },
      ]}
      isSticky
    />
  </Fragment>

  <!-- ══════════════════════════════════════════════════════════
       1. HERO
       ══════════════════════════════════════════════════════════ -->
  <Hero2
    tagline="ERP Integrations"
    actions={[
      { variant: 'primary', text: 'Request ERP Integration Assessment', href: '/contact', icon: 'tabler:plug-connected' },
      { text: 'Speak to Our SAP Architects', href: '/contact', icon: 'tabler:message-circle' },
    ]}
    image={{
      src: 'http://4.151.8.142:4000/uploads/UpBuff-ERP-Extension-Process.png',
      alt: 'UpBuff ERP Integrations — SAP, Oracle, Epicor API-based execution layer',
    }}
  >
    <Fragment slot="title">
      ERP Integrations with SAP, Epicor, and{' '}
      <span class="text-accent dark:text-white">Oracle</span>
    </Fragment>
    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <strong>Extend your ERP. Preserve the core. Accelerate execution.</strong><br /><br />
        UpBuff integrates with leading enterprise ERP platforms without modifying their core architecture. Whether you
        operate on SAP S/4HANA, SAP ECC, SAP Business One, Epicor ERP, or Oracle ERP — UpBuff acts as an
        <strong>Execution Layer</strong> built on secure APIs, service layers, and a
        <strong>Clean Core Integration Strategy</strong>.
      </span>
      <span class="block sm:hidden">
        API-based execution layer for SAP, Oracle, and Epicor — Clean Core, upgrade-safe, no core modifications.
      </span>
    </Fragment>
  </Hero2>

  <!-- ══════════════════════════════════════════════════════════
       2. LOGO BAR
       ══════════════════════════════════════════════════════════ -->
  <LogoBar
    label="Enterprise ERP Integration Solutions for Scalable Operations"
    logos={[
      { src: 'http://4.151.8.142:4000/uploads/logo/sap-s4-hanna-integration-with-upbuff-crm.png', alt: 'SAP S/4HANA' },
      { src: 'http://4.151.8.142:4000/uploads/logo/sap-integration-with-upbuff-crm.png',          alt: 'SAP Business One' },
      { src: 'http://4.151.8.142:4000/uploads/logo/oracle-integration-with-upbuff-crm.png',       alt: 'Oracle ERP' },
      { src: 'http://4.151.8.142:4000/uploads/logo/epicore-integration-with-upbuff-crm.png',      alt: 'Epicor ERP' },
      { src: 'http://4.151.8.142:4000/uploads/logo/zoho-integration-with-upbuff-crm.png',         alt: 'Zoho' },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       3. INTEGRATION PHILOSOPHY — ContentSplitCard
       ══════════════════════════════════════════════════════════ -->
  <ContentSplitCard
    tagline="Integration Philosophy"
    title="Clean Core integration — not traditional ERP customization"
    cardTitle="ERP remains the System of Record. UpBuff becomes the System of Execution."
    cardDescription="Traditional ERP extensions rely on core modifications, user-defined field overloads, direct database interventions, and heavy add-on customization. UpBuff avoids all of these. Instead, we integrate using official ERP APIs, service layers, OData services, RESTful architecture, and middleware compatibility — keeping your ERP upgrade-safe, audit-ready, and compliant at every step."
    cardImage="http://4.151.8.142:4000/uploads/upbuff-ERP-CRM-integrations-for-WhatsApp-Tally-Shopify-SAP.png"
    cardGradient="linear-gradient(135deg, #003f7c 0%, #0070c0 50%, #1d4ed8 100%)"
    testimonial={{
      quote: 'UpBuff connected our SAP Business One to the field team in weeks using the Service Layer. Real-time pricing, credit control, and order sync — without touching SAP core. Our upgrade path stayed completely intact.',
      name: 'IT Director',
      company: 'Opal',
      avatar: '/logos/opal.svg',
    }}
    features={[
      {
        icon: 'tabler:database-off',
        title: 'No direct database manipulation',
        description: 'All integration flows through official API and service layer endpoints — never direct DB writes.',
      },
      {
        icon: 'tabler:rocket',
        title: 'Upgrade-safe by architecture',
        description: 'Clean Core compliance means every ERP upgrade cycle is low-risk and free of execution-layer breakage.',
      },
      {
        icon: 'tabler:shield-check',
        title: 'Audit-ready from day one',
        description: 'Every transaction logged, every API call traceable — full compliance readiness built in.',
      },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       4. ERP PLATFORM DEEP-DIVES — FeaturesHighlights
       ══════════════════════════════════════════════════════════ -->
  <FeaturesHighlights
    tagline="ERP Platforms"
    title="Deep integration across every major ERP"
    subtitle="UpBuff is ERP-agnostic by design — each integration is built using that platform's officially endorsed API and service layer, not workarounds or database hooks."
    items={[
      {
        title: 'SAP S/4HANA, SAP ECC & SAP Business One',
        description: 'S/4HANA: OData services, Standard APIs, SAP BTP compatibility, secure authentication layers. ECC: RFC/BAPI integration, OData extensions, middleware connectors. Business One: SAP Service Layer, DI-API compatibility, secure REST connectors. All three are Clean Core compliant — upgrade-safe and fully auditable.',
        image: '<div class="w-full flex flex-col items-center gap-4"><div class="bg-white rounded-2xl shadow px-5 py-3 flex items-center gap-2 text-sm font-medium"><span class="w-5 h-5 rounded-full bg-gray-900 flex items-center justify-center text-white text-xs">✓</span>Live SAP Data Synchronization!</div><div class="flex items-center gap-3 mt-2"><div class="w-16 h-9 rounded-full bg-gradient-to-r from-purple-400 to-pink-400"></div><div class="w-14 h-14 rounded-full bg-white border border-gray-200 flex items-center justify-center overflow-hidden"><img src="http://4.151.8.142:4000/uploads/logo/sap-integration-with-upbuff.png" class="w-1/2 h-full object-contain mx-auto" alt="SAP logo" /></div><div class="w-16 h-9 rounded-full bg-gradient-to-r from-orange-400 to-red-400"></div></div></div>',
      },
      {
        title: 'Epicor ERP',
        description: 'UpBuff integrates with Epicor ERP environments using REST APIs, Epicor Service Connect, and middleware connectors. Supported execution areas include shopfloor execution, warehouse mobility, field service capture, and sales execution — all without core customization or upgrade risk.',
        image: '<div class="w-full flex flex-col items-center gap-4"><div class="bg-white rounded-2xl shadow px-5 py-3 flex items-center gap-2 text-sm font-medium"><span class="w-5 h-5 rounded-full bg-gray-900 flex items-center justify-center text-white text-xs">✓</span>Epicor Execution & Workflow Integration!</div><div class="flex items-center gap-3 mt-2"><div class="w-16 h-9 rounded-full bg-gradient-to-r from-purple-400 to-pink-400"></div><div class="w-14 h-14 rounded-full bg-white border border-gray-200 flex items-center justify-center overflow-hidden"><img src="http://4.151.8.142:4000/uploads/logo/epicore-integration-with-upbuff-crm.png" class="w-1/2 h-full object-contain mx-auto" alt="Epicor logo" /></div><div class="w-16 h-9 rounded-full bg-gradient-to-r from-orange-400 to-red-400"></div></div></div>',
      },
      {
        title: 'Oracle ERP & Oracle Cloud',
        description: 'UpBuff supports integration with Oracle ERP (including Oracle Cloud ERP) via Oracle REST APIs, Oracle Integration Cloud (OIC), and secure web service connectors. Supported execution areas include manufacturing mobility, warehouse workflows, field operations, and sales execution — cloud-native compatible.',
        image: '<div class="w-full flex flex-col items-center gap-4"><div class="bg-white rounded-2xl shadow px-5 py-3 flex items-center gap-2 text-sm font-medium"><span class="w-5 h-5 rounded-full bg-gray-900 flex items-center justify-center text-white text-xs">✓</span>Oracle Cloud ERP Connectivity!</div><div class="flex items-center gap-3 mt-2"><div class="w-16 h-9 rounded-full bg-gradient-to-r from-purple-400 to-pink-400"></div><div class="w-14 h-14 rounded-full bg-white border border-gray-200 flex items-center justify-center overflow-hidden"><img src="http://4.151.8.142:4000/uploads/logo/oracle-integration-with-upbuff-crm.png" class="w-1/2 h-full object-contain mx-auto" alt="Oracle logo" /></div><div class="w-16 h-9 rounded-full bg-gradient-to-r from-orange-400 to-red-400"></div></div></div>',
      },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       5. PER-ERP CAPABILITIES — FeaturesBento
       ══════════════════════════════════════════════════════════ -->
  <FeaturesBento
    tagline="Integration Coverage"
    title="What UpBuff delivers across each ERP platform"
    subtitle="Every integration is purpose-built for its ERP platform — using that platform's officially endorsed API patterns, not generic middleware workarounds."
    items={[
      {
        wide: true,
        title: 'SAP S/4HANA — Clean Core execution for enterprise SAP',
        description: 'OData services and standard APIs for real-time master data access. SAP BTP compatibility for cloud-first deployments. Supported execution areas: manufacturing execution, warehouse mobility, field service workflows, and sales mobility. Benefits: Clean Core compliance, upgrade-safe architecture, real-time transactional sync, enterprise-grade security.',
        image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-100 p-8"><div class="text-center"><div class="w-20 h-20 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg" style="background:linear-gradient(135deg,#003f7c,#0070c0)"><span class="text-white font-black text-xl">SAP</span></div><p class="text-sm font-bold text-blue-900">S/4HANA</p><p class="text-xs text-blue-600 mt-1">OData · Standard APIs · BTP · Clean Core</p></div></div>',
      },
      {
        wide: true,
        title: 'Oracle ERP & Oracle Cloud — cloud-native execution',
        description: 'Oracle REST APIs and Oracle Integration Cloud (OIC) for seamless connectivity. Secure web service connectors for on-premise Oracle environments. Supported execution areas: manufacturing mobility, warehouse workflows, field operations, sales execution. Benefits: enterprise-grade security, cloud-native compatibility, upgrade-safe architecture.',
        image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-red-50 to-orange-100 p-8"><div class="text-center"><div class="w-20 h-20 rounded-2xl bg-white border-2 border-red-200 flex items-center justify-center mx-auto mb-4 shadow-lg"><span class="font-black text-lg" style="color:#f80000">ORACLE</span></div><p class="text-sm font-bold text-red-900">Oracle ERP · Cloud</p><p class="text-xs text-red-600 mt-1">REST APIs · OIC · Web Services</p></div></div>',
      },
      {
        title: 'SAP ECC — legacy SAP modernization',
        description: 'RFC/BAPI integration, OData extensions, middleware connectors. Preserves ECC stability, avoids risky enhancements, and provides a gradual modernization path toward S/4HANA.',
        image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-50 to-slate-100 p-4"><div class="text-center"><div class="w-14 h-14 rounded-xl flex items-center justify-center mx-auto mb-2 shadow" style="background:linear-gradient(135deg,#003f7c,#0070c0)"><span class="text-white font-black text-sm">ECC</span></div><p class="text-xs font-bold text-slate-700">SAP ECC</p><p class="text-[9px] text-slate-500 mt-0.5">RFC · BAPI · Middleware</p></div></div>',
      },
      {
        title: 'SAP Business One — SME & mid-market execution',
        description: 'SAP Service Layer, DI-API compatibility, secure REST connectors. Ideal for manufacturing enterprises, distribution companies, and field service SMBs.',
        image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-blue-50 to-blue-100 p-4"><div class="text-center"><div class="w-14 h-14 rounded-xl bg-white border-2 border-blue-200 flex items-center justify-center mx-auto mb-2 shadow"><span class="font-black text-[10px] text-blue-900 text-center leading-tight">SAP<br>B1</span></div><p class="text-xs font-bold text-blue-800">Business One</p><p class="text-[9px] text-blue-600 mt-0.5">Service Layer · DI-API · REST</p></div></div>',
      },
      {
        title: 'Epicor ERP — manufacturing & distribution',
        description: 'REST APIs, Epicor Service Connect, middleware connectors. Shopfloor execution, warehouse mobility, field service, and sales — no core customization.',
        image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-red-50 to-red-100 p-4"><div class="text-center"><div class="w-14 h-14 rounded-xl bg-white border-2 border-red-200 flex items-center justify-center mx-auto mb-2 shadow"><span class="font-black text-sm" style="color:#e00000">epic</span></div><p class="text-xs font-bold text-red-800">Epicor ERP</p><p class="text-[9px] text-red-600 mt-0.5">REST · Service Connect</p></div></div>',
      },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       6. CLEAN CORE ARCHITECTURE — FeaturesCarousel (4 layers)
       ══════════════════════════════════════════════════════════ -->
  <FeaturesCarousel
    tagline="Clean Core Architecture"
    title="How the integration architecture works"
    subtitle="Every UpBuff integration follows the same four-layer Clean Core architecture — from ERP platform to frontline user, with no direct database writes at any point."
    items={[
      {
        badge: 'Layer 1 — Foundation',
        title: 'ERP Platform — your system of record',
        description: 'SAP S/4HANA, SAP ECC, SAP Business One, Epicor ERP, or Oracle ERP remains the authoritative system of record. All master data, financials, inventory, and transactions live here. UpBuff never replaces or bypasses ERP — it extends it. The ERP core stays untouched, upgrade-safe, and fully compliant.',
        image: '<div class="w-full h-full flex items-center justify-center p-6"><svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="1.2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.657 4.03 3 9 3s9-1.343 9-3V5"/><path d="M3 12c0 1.657 4.03 3 9 3s9-1.343 9-3"/></svg></div>',
      },
      {
