---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';

import HeroPanels from '~/components/widgets/HeroPanels.astro';
import LogoBar from '~/components/widgets/LogoBar.astro';
import ContentSplitCard from '~/components/widgets/ContentSplitCard.astro';
import ProblemSplit from '~/components/widgets/ProblemSplit.astro';
import FeaturesHighlights from '~/components/widgets/FeaturesHighlights.astro';
import FeaturesCarousel from '~/components/widgets/FeaturesCarousel.astro';
import FeaturesBento from '~/components/widgets/FeaturesBento.astro';
import FeaturesGrid from '~/components/widgets/FeaturesGrid.astro';
import SecuritySplit from '~/components/widgets/SecuritySplit.astro';
import ToolsMarquee from '~/components/widgets/ToolsMarquee.astro';
import TestimonialsGrid from '~/components/widgets/TestimonialsGrid.astro';
import FaqAccordion from '~/components/widgets/FaqAccordion.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';

import { headerData } from '~/navigation';

const metadata = {
  title: 'Why UpBuff | Clean Core ERP Execution Platform for SAP & Enterprise ERP',
  description:
    'Discover why UpBuff is the ERP execution layer of choice for SAP S/4HANA, SAP Business One, Epicor, and Oracle. Upgrade-safe, Clean Core, API-first architecture that reduces ERP customization risk and lowers long-term TCO.',
  canonical: 'https://www.upbuff.com/why-upbuff/',
  robots: { index: true, follow: true },
  openGraph: {
    type: 'website',
    url: 'https://www.upbuff.com/why-upbuff/',
    title: 'Why UpBuff | ERP Execution Layer for Enterprise ERP',
    description: 'Reduce ERP customization risk. Adopt a Clean Core execution platform designed for SAP and enterprise ERP landscapes.',
    image: 'https://www.upbuff.com/images/why-upbuff.png',
  },
  twitter: {
    cardType: 'summary_large_image',
    title: 'Why UpBuff | Clean Core ERP Execution Platform',
    description: 'Upgrade-safe, API-first ERP execution layer for SAP, Oracle, and Epicor environments.',
  },
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <meta name="author" content="UpBuff Technologies" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "UpBuff ERP Execution Platform",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web, Android, iOS",
      "description": "Clean Core ERP execution platform integrating with SAP S/4HANA, SAP Business One, Epicor, and Oracle using API-based architecture.",
      "url": "https://www.upbuff.com/why-upbuff/",
      "provider": { "@type": "Organization", "name": "UpBuff Technologies", "url": "https://www.upbuff.com" }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How is UpBuff different from ERP add-ons?", "acceptedAnswer": { "@type": "Answer", "text": "UpBuff operates as an external execution layer using official ERP APIs rather than embedding customization inside ERP core systems." } },
        { "@type": "Question", "name": "Why not just customize ERP for execution?", "acceptedAnswer": { "@type": "Answer", "text": "ERP customization increases upgrade risk, maintenance cost, and technical debt. UpBuff preserves ERP stability while enabling execution agility." } },
        { "@type": "Question", "name": "Is UpBuff suitable for SAP upgrade roadmaps?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. UpBuff aligns with Clean Core strategies and integrates via official SAP APIs." } },
        { "@type": "Question", "name": "Can UpBuff replace existing custom ERP workflows?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Many enterprises migrate custom execution logic out of ERP into UpBuff to reduce risk and improve scalability." } }
      ]
    })} />
  </Fragment>

  <!-- White header — bright conviction page, white nav fits -->
  <Fragment slot="header">
    <Header
      {...headerData}
      theme="black"
      actions={[
        { variant: 'secondary', text: 'Login',  href: '#' },
        { variant: 'primary',   text: 'Sign Up', href: '#' },
      ]}
      isSticky
    />
  </Fragment>

  <!-- ══════════════════════════════════════════════════════════
       1. HERO — dark panel hero
       ══════════════════════════════════════════════════════════ -->
  <HeroPanels
    theme="dark"
    tagline="Why UpBuff"
    title="Because ERP Should Stay Stable and Execution Should Stay Agile"
    subtitle="Most enterprises extend ERP the wrong way. The default response to growing operational needs is to customize the ERP — which silently accumulates upgrade delays, technical debt, and compliance risks. UpBuff is an ERP Execution Layer designed to preserve ERP integrity while enabling full operational agility."
    actions={[
      { variant: 'primary',   text: 'Explore Platform Overview', href: '/platform/overview' },
      { variant: 'secondary', text: 'Request Demo',              href: '/contact' },
    ]}
    panels={[
      {
        accent: 'linear-gradient(160deg, #7c3aed 0%, #4f46e5 100%)',
        html: `
          <div style="padding: 32px 28px; display: flex; flex-direction: column; gap: 14px; height: 100%;">
            <div style="display:flex; align-items:center; gap:10px;">
              <div style="width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
              </div>
              <span style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.9);">Field Sales Rep — European Territory</span>
            </div>
            <div style="display:flex; flex-direction:column; gap:10px; flex:1; justify-content:center;">
              <div style="align-self:flex-end;background:rgba(255,255,255,0.9);color:#1a1a1a;font-size:12.5px;font-weight:500;padding:10px 14px;border-radius:14px 14px 3px 14px;max-width:80%;">
                Is there stock available for SKU-4821?
              </div>
              <div style="align-self:flex-start;background:rgba(255,255,255,0.15);color:#fff;font-size:12.5px;font-weight:500;padding:10px 14px;border-radius:14px 14px 14px 3px;max-width:85%;">
                ✓ 240 units available · SAP MM confirmed
              </div>
              <div style="align-self:flex-end;background:rgba(255,255,255,0.9);color:#1a1a1a;font-size:12.5px;font-weight:500;padding:10px 14px;border-radius:14px 14px 3px 14px;max-width:80%;">
                Create order for 50 units at list price.
              </div>
              <div style="align-self:flex-start;background:rgba(255,255,255,0.15);color:#fff;font-size:12.5px;font-weight:500;padding:10px 14px;border-radius:14px 14px 14px 3px;max-width:85%;">
                ✓ SO-100423 posted to SAP SD
              </div>
            </div>
          </div>
        `,
      },
      {
        html: `
          <div style="padding: 22px 20px; background:#1a1a1a; height:100%;">
            <p style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.85);margin-bottom:14px;">Live SAP Data Sources</p>
            ${[
              ['Sales Orders · SAP SD',    'Real-time · OData',   'spin',  '#6366f1'],
              ['Customer Master Data',      '2,341 records',       'spin',  '#f472b6'],
              ['Inventory · SAP MM',        '182 SKUs synced',     'check', null    ],
              ['Pricing Conditions',        '3 condition types',   'check', null    ],
              ['Work Orders · SAP PP',      '323 open orders',     'check', null    ],
            ].map(([name, meta, state, color]) => `
              <div style="display:flex;align-items:center;gap:10px;padding:10px 0;border-top:0.5px solid rgba(255,255,255,0.06);">
                <div style="width:30px;height:30px;border-radius:7px;background:rgba(255,255,255,0.07);flex-shrink:0;display:flex;align-items:center;justify-content:center;">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.2"><rect x="2" y="2" width="12" height="12" rx="2"/><path d="M5 6h6M5 9h4"/></svg>
                </div>
                <div style="flex:1;">
                  <div style="font-size:12px;font-weight:500;color:rgba(255,255,255,0.8);">${name}</div>
                  <div style="font-size:11px;color:rgba(255,255,255,0.3);">${meta}</div>
                </div>
                ${state === 'spin'
                  ? `<div style="width:16px;height:16px;border-radius:50%;border:2px solid rgba(255,255,255,0.1);border-top-color:${color};animation:spin 0.9s linear infinite;flex-shrink:0;"></div>`
                  : `<div style="width:16px;height:16px;border-radius:50%;background:rgba(74,222,128,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M1.5 4l2 2 3-3" stroke="#4ade80" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></div>`
                }
              </div>
            `).join('')}
          </div>
          <style>@keyframes spin{to{transform:rotate(360deg)}}</style>
        `,
      },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       2. LOGO BAR — ERP platforms supported
       ══════════════════════════════════════════════════════════ -->
  <LogoBar
    label="Trusted across leading enterprise ERP platforms"
    logos={[
      { src: 'http://4.151.8.142:4000/uploads/logo/sap-s4-hanna-integration-with-upbuff-crm.png', alt: 'SAP S/4HANA' },
      { src: 'http://4.151.8.142:4000/uploads/logo/sap-integration-with-upbuff-crm.png',          alt: 'SAP Business One' },
      { src: 'http://4.151.8.142:4000/uploads/logo/oracle-integration-with-upbuff-crm.png',       alt: 'Oracle ERP' },
      { src: 'http://4.151.8.142:4000/uploads/logo/epicore-integration-with-upbuff-crm.png',      alt: 'Epicor ERP' },
      { src: 'http://4.151.8.142:4000/uploads/logo/zoho-integration-with-upbuff-crm.png',         alt: 'Zoho' },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       3. CONTENT SPLIT CARD — core "why" argument
       ══════════════════════════════════════════════════════════ -->
  <ContentSplitCard
    tagline="ERP Execution Layer"
    title="Enterprise ERP Execution Layer Built for SAP, Oracle & Modern Systems"
    cardTitle="UpBuff exists to solve the ERP customization problem differently"
    cardDescription="The default response to growing operational needs is to customize ERP — which silently accumulates upgrade delays, technical debt, and compliance risks. UpBuff is not an ERP add-on. It is an ERP Execution Layer that preserves ERP integrity while enabling full operational agility. No direct database writes. No core modifications. No upgrade risk."
    cardImage="http://4.151.8.142:4000/uploads/upbuff-ERP-CRM-integrations-for-WhatsApp-Tally-Shopify-SAP.png"
    cardGradient="linear-gradient(135deg, #7c3aed 0%, #6366f1 50%, #3b82f6 100%)"
    testimonial={{
      quote: 'We evaluated five ERP extension platforms. UpBuff was the only one that truly respected our SAP governance model — API-first, role-controlled, and fully auditable. It was the only defensible choice for our CIO.',
      name: 'CIO',
      company: 'IHG Hotels & Resorts',
      avatar: 'http://4.151.8.142:4000/uploads/spartan-client.png',
    }}
    features={[
      {
        icon: 'tabler:shield-check',
        title: 'Clean Core by design',
        description: 'No database manipulation, API-based integration only — upgrade-safe by architecture.',
      },
      {
        icon: 'tabler:rocket',
        title: 'Upgrade-safe architecture',
        description: 'When ERP upgrades, the core remains untouched and execution continues with minimal disruption.',
      },
      {
        icon: 'tabler:coin-off',
        title: 'Lower long-term TCO',
        description: 'Reduces custom ERP code, consultant dependency, and rework costs at every upgrade cycle.',
      },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       4. PROBLEM SPLIT — the ERP customization failure
       ══════════════════════════════════════════════════════════ -->
  <ProblemSplit
    tagline="The Problem"
    title="ERP customization creates compounding long-term risk"
    subtitle="When operational needs grow — field mobility, warehouse scanning, shopfloor execution — the default response is to customize ERP core. Over time, that creates problems that compound silently with every release cycle."
    items={[
      {
        title: 'Upgrade delays accumulate',
        description: 'Every customization becomes a blocker when an ERP upgrade begins. What should be a routine cycle turns into a costly, multi-month re-implementation project.',
      },
      {
        title: 'Technical debt compounds',
        description: 'Custom code inside ERP core compounds silently — increasing regression risk, test complexity, and maintenance burden with every iteration.',
      },
      {
        title: 'Consultant dependency grows',
        description: 'Bespoke ERP logic creates reliance on the same niche consultants to maintain, debug, and extend it — making your operations hostage to external expertise.',
      },
      {
        title: 'Performance instability & compliance exposure',
        description: 'Core-level modifications degrade ERP performance unpredictably. Undocumented changes break audit trails and introduce regulatory risk that is hard to reverse.',
      },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       5. FEATURES HIGHLIGHTS — first 3 reasons (deep-dive)
       ══════════════════════════════════════════════════════════ -->
  <FeaturesHighlights
    tagline="Core Architecture"
    title="The foundational principles"
    subtitle="Clean Core, upgrade safety, and purpose-built operational interfaces — the three architectural decisions that make UpBuff fundamentally different from ERP add-ons or core customization tools."
    items={[
      {
        title: 'Clean Core by Design',
        description: 'SAP S/4HANA, SAP ECC, SAP Business One, Epicor, and Oracle ERP are built as systems of record — not optimized for mobile execution, warehouse scanning, or distributed field teams. UpBuff keeps ERP clean: no direct database manipulation, API-based integration only, no hidden core enhancements. Upgrade-safe by architecture.',
        image: '<div class="w-full h-full flex items-center justify-center bg-gray-50 p-6"><div class="bg-white rounded-2xl shadow-md w-64 p-5 flex flex-col items-center gap-4"><div class="text-xs font-semibold text-gray-700">Clean Core Architecture</div><div class="relative flex items-center justify-center w-full h-28"><div class="w-16 h-16 rounded-2xl bg-gray-900 text-white flex items-center justify-center text-xs font-bold shadow-lg z-10">ERP</div><div class="absolute w-28 h-28 border-2 border-dashed border-green-300 rounded-full animate-[spin_8s_linear_infinite]"></div><div class="absolute top-2 left-2 w-8 h-8 bg-green-100 text-green-700 rounded-lg flex items-center justify-center text-[9px] font-semibold">API</div><div class="absolute top-2 right-2 w-8 h-8 bg-blue-100 text-blue-700 rounded-lg flex items-center justify-center text-[9px] font-semibold">APP</div><div class="absolute bottom-2 left-2 w-8 h-8 bg-purple-100 text-purple-700 rounded-lg flex items-center justify-center text-[9px] font-semibold">WMS</div><div class="absolute bottom-2 right-2 w-8 h-8 bg-orange-100 text-orange-700 rounded-lg flex items-center justify-center text-[9px] font-semibold">Field</div></div><div class="text-center"><p class="text-sm font-semibold text-gray-800">No direct DB writes</p><p class="text-xs text-green-600 font-medium mt-1">API only · No core mods · Upgrade-safe</p></div></div></div>',
      },
      {
        title: 'Upgrade-Safe Architecture',
        description: 'ERP upgrades should not feel like re-implementation projects. Traditional customization causes regression testing cycles, integration breakage, rework costs, and long freeze periods. UpBuff integrates via official APIs and service layers — when ERP upgrades, the core remains untouched and execution continues with minimal disruption.',
        image: '<div class="w-full h-full flex items-center justify-center bg-gray-50 p-6"><div class="bg-white rounded-2xl shadow-md w-64 p-5 flex flex-col items-center"><div class="relative flex flex-col items-center"><div class="text-[10px] text-blue-600 font-medium animate-pulse">ERP Upgrade</div><div class="w-[2px] h-6 bg-gray-200 relative overflow-hidden"><div class="absolute inset-0 bg-blue-400 animate-[flowY_1.5s_linear_infinite]"></div></div><div class="w-16 h-16 rounded-2xl bg-gray-900 text-white flex items-center justify-center text-xs font-bold shadow-lg">ERP</div><div class="w-[2px] h-6 bg-gray-200 relative overflow-hidden"><div class="absolute inset-0 bg-green-400 animate-[flowY_1.5s_linear_infinite]"></div></div><div class="w-28 h-10 bg-green-100 text-green-700 rounded-lg flex items-center justify-center text-[10px] font-semibold shadow-sm animate-pulse">Execution Running</div></div><div class="text-center mt-3"><p class="text-sm font-semibold text-gray-800">No disruption during upgrades</p><p class="text-xs text-blue-600 font-medium mt-1">API-based · No rework · Upgrade-safe</p></div></div></div>',
      },
      {
        title: 'Built for Operational Users',
        description: 'ERP screens were designed for administrative users — not warehouse operators, field technicians, production supervisors, or sales representatives. Execution users need mobile-first interfaces, scanning-friendly workflows, minimal clicks, and real-time validation. UpBuff delivers exactly that, while keeping ERP governance intact at every step.',
        image: '<div class="w-full h-full flex items-center justify-center bg-gray-50 p-6"><div class="bg-white rounded-2xl shadow-md w-72 p-5 flex flex-col items-center gap-4"><div class="flex items-center justify-between w-full"><div class="bg-gray-100 rounded-lg p-3 w-24 flex flex-col gap-2"><div class="h-2 bg-gray-300 rounded w-full"></div><div class="h-2 bg-gray-200 rounded w-5/6"></div><div class="h-2 bg-gray-200 rounded w-4/6"></div><div class="h-2 bg-gray-300 rounded w-full"></div></div><div class="text-gray-400 text-xs animate-pulse">→</div><div class="bg-purple-50 rounded-lg p-3 w-24 flex flex-col items-center gap-2 border border-purple-100"><div class="w-10 h-10 bg-purple-600 text-white rounded-xl flex items-center justify-center text-[10px] font-bold shadow">Scan</div><div class="h-2 bg-purple-200 rounded w-3/4"></div></div></div><div class="text-center"><p class="text-sm font-semibold text-gray-800">Mobile-First ERP Execution</p><p class="text-xs text-purple-600 font-medium mt-1">Mobile-first · Fast · Scan-friendly</p></div></div></div>',
      },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       6. FEATURES CAROUSEL — reasons 4, 5 & 7
       ══════════════════════════════════════════════════════════ -->
  <FeaturesCarousel
    tagline="5 Reasons to Choose UpBuff"
    title="The strategic and financial case"
    subtitle="The business, financial, and architectural reasons enterprises choose UpBuff as their long-term ERP execution strategy — without customization risk."
    items={[
      {
        gradient: 'linear-gradient(135deg, #166534 0%, #15803d 100%)',
        badge: 'Reason 1 — Clean Core',
        title: 'Clean Core by design — upgrade-safe by architecture',
        description: 'No database manipulation, API-based integration only, no hidden core enhancements. UpBuff keeps ERP clean across SAP S/4HANA, ECC, Business One, Epicor, and Oracle ERP — protecting every future upgrade cycle and keeping compliance intact without a single line written inside ERP core.',
        image: '<div class="w-full h-full flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24 text-white opacity-80" viewBox="0 0 24 24" fill="none" stroke="#000000" stroke-width="1"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></div>',
      },
      {
        gradient: 'linear-gradient(135deg, #0f766e 0%, #0ea5e9 100%)',
        badge: 'Reason 2 — Lower TCO',
        title: 'Lower long-term total cost of ownership',
        description: 'Customization appears cheaper initially. But over time it accumulates higher maintenance costs, external consultant reliance, upgrade complexity, and technical debt. UpBuff reduces custom code inside ERP, dependency on niche consultants, and rework during upgrades — improving long-term cost predictability.',
        image: '<div class="w-full h-full flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24 text-white opacity-80" viewBox="0 0 24 24" fill="none" stroke="#000000" stroke-width="1"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div>',
      },
      {
        gradient: 'linear-gradient(135deg, #dc2626 0%, #f97316 100%)',
        badge: 'Reason 3 — Security',
        title: 'Enterprise-grade security & compliance',
        description: 'Security is architecture — not a checkbox. UpBuff uses encrypted API communication, supports role-based access control, maintains full transaction audit logs, and preserves ERP compliance integrity. Every permission traces back to ERP user roles. Every action is logged and auditable.',
        image: '<div class="w-full h-full flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24 text-white opacity-80" viewBox="0 0 24 24" fill="none" stroke="#000000" stroke-width="1"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/><circle cx="12" cy="16" r="1"/></svg></div>',
      },
      {
        gradient: 'linear-gradient(135deg, #1d4ed8 0%, #0891b2 100%)',
        badge: 'Reason 4 — ERP Compatibility',
        title: 'Works across every major ERP landscape',
        description: 'SAP S/4HANA, SAP ECC, SAP Business One, Epicor, and Oracle ERP — on-premise, private cloud, public cloud, and hybrid. A single execution platform that adapts to your ERP environment rather than forcing a replacement or a re-architecture of your enterprise system landscape.',
        image: '<div class="w-full h-full flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24 text-white opacity-80" viewBox="0 0 24 24" fill="none" stroke="#000000" stroke-width="1"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M7 8h10M7 11h6"/></svg></div>',
      },
      {
        gradient: 'linear-gradient(135deg, #7c3aed 0%, #ec4899 100%)',
        badge: 'Reason 5 — Strategic Advantage',
        title: 'Strategic advantage — not just functional extension',
        description: 'This is architectural maturity. UpBuff helps enterprises modernize execution, reduce ERP risk exposure, improve upgrade readiness, increase operational agility, and align with SAP Clean Core strategies — delivering long-term system health and ERP investment protection that compounds over time.',
        image: '<div class="w-full h-full flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24 text-white opacity-80" viewBox="0 0 24 24" fill="none" stroke="#000000" stroke-width="1"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg></div>',
      },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       7. FEATURES BENTO — reason 6 expanded + who chooses
       ══════════════════════════════════════════════════════════ -->
  <FeaturesBento
    tagline="ERP Compatibility"
    title="Designed for enterprise ERP landscapes & the people who run them"
    subtitle="UpBuff integrates with the ERP platforms enterprises depend on — and is chosen by the leaders responsible for keeping those platforms stable, upgradeable, and aligned with business goals."
    items={[
      {
        wide: true,
        title: 'SAP S/4HANA, SAP ECC & SAP Business One',
        description: 'Full integration with SAP S/4HANA via OData and RFC, SAP ECC via BAPI, and SAP Business One via Service Layer. Clean Core compliant — no core modifications, no upgrade risk, no regression testing of custom ERP code. Supports all SAP deployment models: on-premise, private cloud, RISE, and hybrid.',
        image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-100 p-8"><div class="text-center"><div class="flex gap-4 justify-center flex-wrap mb-4"><div class="flex flex-col items-center gap-1"><div class="w-20 h-14 rounded-xl bg-white flex items-center justify-center shadow border p-2"><img src="http://4.151.8.142:4000/uploads/logo/sap-s4-hanna-integration-with-upbuff-crm.png" alt="SAP S/4HANA" class="w-full h-full object-contain" /></div><span class="text-xs text-gray-500">SAP S/4HANA</span></div><div class="flex flex-col items-center gap-1"><div class="w-20 h-14 rounded-xl bg-white flex items-center justify-center shadow border p-2"><img src="http://4.151.8.142:4000/uploads/logo/sap-integration-with-upbuff-crm.png" alt="SAP ECC" class="w-full h-full object-contain" /></div><span class="text-xs text-gray-500">SAP ECC</span></div><div class="flex flex-col items-center gap-1"><div class="w-20 h-14 rounded-xl bg-white flex items-center justify-center shadow border p-2"><img src="http://4.151.8.142:4000/uploads/logo/sap-integration-with-upbuff-crm.png" alt="SAP Business One" class="w-full h-full object-contain" /></div><span class="text-xs text-gray-500">SAP Business One</span></div></div><p class="text-xs text-blue-600">OData · BAPI · Service Layer · Clean Core</p></div></div>',
      },
      {
        wide: true,
