---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';

import { headerData } from '~/navigation';
import FAQs from '~/components/widgets/FAQs.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'ERP Execution Platform for SAP | CRM, FSM, Warehouse, Manufacturing & Product Configuration | UpBuff',
  description:
    'Discover the ERP Execution Platform that extends SAP S/4HANA, ECC, and Business One into CRM, field service, warehouse, manufacturing, product configuration, and partner operations without customization.',
  canonical: 'https://www.upbuff.com/erp-execution-platform',
  openGraph: {
    type: 'website',
    url: 'https://www.upbuff.com/erp-execution-platform',
    title: 'ERP Execution Platform for SAP Enterprises | UpBuff',
    description:
      'Enterprise ERP Execution Platform integrating CRM, FSM, Warehouse, Manufacturing, Product Configuration, and Partner Portals with SAP.',
    image: 'https://www.upbuff.com/images/erp-execution-platform-og.jpg',
    siteName: 'UpBuff Technologies',
  },
};
---

<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        {
          variant: 'secondary',
          text: 'Login',
          href: '#',
        },
        {
          variant: 'primary',
          text: 'Sign Up',
          href: '#',
        },
      ]}
      isSticky
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline="ERP Execution Platform"
    actions={[
      { variant: 'primary', text: 'Request Demo', href: '/contact' },
      { text: 'Talk to ERP Expert', href: '/contact', icon: 'tabler:message-circle' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'UpBuff ERP Execution Platform for SAP Enterprises',
    }}
  >
    <Fragment slot="title">
      Extend SAP Into Real-Time <span class="text-accent dark:text-white">Operational Execution</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        SAP powers enterprise governance — but operational execution rarely happens inside SAP. Field teams, warehouse
        operators, sales engineers, distributors, and manufacturing planners rely on disconnected tools, spreadsheets,
        emails, or manual SAP entries. This creates what we define as <strong>The ERP Execution Gap</strong>. UpBuff
        solves this gap through a structured ERP Execution Platform that extends Oracle, Epicor, SAP S/4HANA, ECC, and
        SAP Business One into operational domains — without modifying ERP core.
      </span>
      <span class="block sm:hidden">
        Close the ERP Execution Gap — extend SAP, Oracle, and Epicor into field service, warehouse, manufacturing, and
        partner operations without customization.
      </span>
    </Fragment>
  </Hero2>

  <!-- Features3 Widget — What Is an ERP Execution Platform? (Definition Block) ************** -->

  <Features3
    id="definition"
    title="What Is an ERP Execution Platform?"
    subtitle="An ERP Execution Platform is an integration-driven execution layer that connects operational users directly to ERP — without modifying core systems."
    tagline="Definition"
    columns={3}
    items={[
      {
        title: 'Extends SAP Operationally',
        description: 'Push SAP capabilities into real-time operational workflows beyond SAP GUI.',
        icon: 'tabler:arrows-maximize',
      },
      {
        title: 'Real-Time Execution Workflows',
        description: 'Enable live field, warehouse, sales, and manufacturing execution.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Secure Transaction Sync',
        description: 'Sync every transaction securely back to ERP in real time.',
        icon: 'tabler:refresh',
      },
      {
        title: 'SAP as System of Record',
        description: 'Maintain SAP as the single source of truth for all enterprise data.',
        icon: 'tabler:database',
      },
      {
        title: 'Eliminates Heavy Customization',
        description: 'Integrate externally via APIs — no SAP core modification required.',
        icon: 'tabler:code-off',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features3>

  <!-- Content Widget — Execution Flow Diagram **************** -->

  <Content
    id="flow"
    items={[
      {
        title: 'Operational Users',
        description: 'Field teams, warehouse operators, sales engineers, distributors, and manufacturing planners.',
        icon: 'tabler:users',
      },
      {
        title: 'UpBuff ERP Execution Platform',
        description: 'Integration-driven execution layer with modular extensions across seven enterprise domains.',
        icon: 'tabler:layers-intersect',
      },
      {
        title: 'SAP ERP Core',
        description: 'SAP S/4HANA, SAP ECC, SAP Business One, Oracle, and Epicor — system of record.',
        icon: 'tabler:server',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'ERP Execution Platform Architecture Flow',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        How It Connects: <br /><span class="text-2xl">Operational Users → UpBuff → SAP ERP Core</span>
      </h3>
      <p class="text-muted mt-2">
        The platform sits between your operational teams and your ERP core, enabling real-time execution while keeping
        SAP as the system of record. Every transaction flows securely from the field back into ERP.
      </p>
    </Fragment>
  </Content>

  <!-- Content Widget — The SAP Execution Gap: What SAP Excels At **************** -->

  <Content
    id="execution-gap"
    title="The SAP Execution Gap"
    subtitle="SAP excels at enterprise governance — but operational execution requires a different approach."
    isReversed
    items={[
      {
        title: 'FI/CO — Financial Control',
        icon: 'tabler:report-money',
      },
      {
        title: 'MM — Procurement & Inventory',
        icon: 'tabler:package',
      },
      {
        title: 'SD — Sales & Distribution',
        icon: 'tabler:shopping-cart',
      },
      {
        title: 'PP — Production Planning',
        icon: 'tabler:calendar-event',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504868584819-f8e8b4b6d7e3?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2076&q=80',
      alt: 'SAP Core Modules',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Where SAP Excels: <br /><span class="text-2xl">Enterprise Governance & Structured Transactions</span>
      </h3>
      <p class="text-muted mt-2">
        SAP delivers world-class financial governance, procurement, sales, and production planning. These modules form
        the backbone of enterprise operations — but they were designed for structured transactions, not real-time
        operational execution.
      </p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget — What SAP GUI Is NOT Built For **************** -->

  <Content
    isAfterContent={true}
    items={[
      {
        title: 'Mobile-first field service',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Warehouse barcode scanning',
        icon: 'tabler:barcode',
      },
      {
        title: 'Distributor automation',
        icon: 'tabler:truck-delivery',
      },
      {
        title: 'Shopfloor execution capture',
        icon: 'tabler:building-factory',
      },
      {
        title: 'Rule-based product configuration',
        icon: 'tabler:settings-automation',
      },
      {
        title: 'Partner self-service portals',
        icon: 'tabler:door',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1581092160607-ee22621dd758?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'What SAP GUI Is Not Built For',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        What SAP GUI Is NOT Built For: <br /><span class="text-2xl">The Operational Execution Gaps</span>
      </h3>
      <p class="text-muted mt-2">
        SAP GUI was never designed for mobile-first field operations, warehouse barcode scanning, or partner
        self-service. These are the operational domains where the execution gap lives — and where UpBuff delivers.
      </p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget — How Enterprises Typically Respond **************** -->

  <Content
    isReversed
    isAfterContent={true}
    items={[
      {
        title: 'Heavy SAP customization',
        description: 'Leads to upgrade risks and long-term maintenance burden.',
        icon: 'tabler:alert-triangle',
      },
      {
        title: 'Disconnected SaaS tools',
        description: 'Creates data silos and integration instability across systems.',
        icon: 'tabler:unlink',
      },
      {
        title: 'Manual coordination processes',
        description: 'Results in high operational costs, delays, and human errors.',
        icon: 'tabler:file-spreadsheet',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Common Enterprise Responses to Execution Gap',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        How Enterprises Typically Respond: <br /><span class="text-2xl">And Why It Fails</span>
      </h3>
      <p class="text-muted mt-2">
        Enterprises often respond with heavy SAP customization, disconnected SaaS tools, or manual coordination —
        resulting in upgrade risks, data silos, integration instability, and high maintenance costs. UpBuff eliminates
        these problems by integrating externally via APIs.
      </p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Features Widget — 7 Execution Domains *************** -->

  <Features
    id="features"
    title="The UpBuff ERP Execution Platform"
    subtitle="Modular execution extensions across seven enterprise domains — each operating independently yet sharing a common integration architecture."
    columns={2}
    items={[
      {
        title: 'ERP-Integrated CRM',
        description:
          'Customer engagement synced with SAP master data. Empower frontline sales teams with real-time order capture, pricing sync, and ERP-controlled workflows.',
        icon: 'tabler:users',
        callToAction: {
          text: 'Learn more',
          href: '/erp-integrated-crm',
        },
      },
      {
        title: 'ERP-Integrated Field Service Management',
        description:
          'Mobile workforce execution aligned with SAP SD and service modules. Enable real-time job scheduling, tracking, and service order completion.',
        icon: 'tabler:map-pin',
        callToAction: {
          text: 'Learn more',
          href: '/erp-integrated-field-service',
        },
      },
      {
        title: 'ERP-Integrated Warehouse & Inventory',
        description:
          'Real-time stock visibility and goods movement integration with SAP MM. Barcode scanning, putaway, picking, and inventory reconciliation.',
        icon: 'tabler:building-warehouse',
        callToAction: {
          text: 'Learn more',
          href: '/erp-integrated-warehouse',
        },
      },
      {
        title: 'ERP-Integrated Sales & Distribution Execution',
        description:
          'Distributor automation, order capture, and SAP SD synchronization. Manage secondary sales, stock transfers, and collection tracking.',
        icon: 'tabler:truck-delivery',
        callToAction: {
          text: 'Learn more',
          href: '/erp-integrated-sales-distribution',
        },
      },
      {
        title: 'ERP-Integrated Manufacturing & Shopfloor Touchpoints',
        description:
          'Production reporting and operational control outside SAP GUI. Capture shopfloor data, track work orders, and sync with SAP PP.',
        icon: 'tabler:building-factory',
        callToAction: {
          text: 'Learn more',
          href: '/erp-integrated-manufacturing',
        },
      },
      {
        title: 'ERP-Integrated Product Configurator',
        description:
          'Rule-based product configuration integrated with SAP SD & PP — enabling automated quotations, pricing validation, and structured BOM generation.',
        icon: 'tabler:settings-automation',
        callToAction: {
          text: 'Learn more',
          href: '/products/erp-integrated-product-configurator',
        },
      },
      {
        title: 'Enterprise & Partner Portals',
        description:
          'Secure collaboration for distributors, suppliers, customers, and stakeholders — fully integrated with SAP data and workflows.',
        icon: 'tabler:door',
        callToAction: {
          text: 'Learn more',
          href: '/enterprise-partner-portals',
        },
      },
    ]}
  />

  <!-- Content Widget — Why Product Configuration Strengthens Execution **************** -->

  <Content
    title="Why Product Configuration Strengthens Execution"
    subtitle="Closing the gap between sales engineering and production execution."
    isReversed
    items={[
      {
        title: 'Validates configuration rules',
        icon: 'tabler:check',
      },
      {
        title: 'Generates structured BOMs',
        icon: 'tabler:list-tree',
      },
      {
        title: 'Syncs quotations to SAP SD',
        icon: 'tabler:refresh',
      },
      {
        title: 'Eliminates manual re-entry',
        icon: 'tabler:automation',
      },
      {
        title: 'Reduces production planning errors',
        icon: 'tabler:bug-off',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Product Configuration Strengthens Execution',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Product Configuration: <br /><span class="text-2xl">Closing the Sales-to-Production Gap</span>
      </h3>
      <p class="text-muted mt-2">
        Manufacturing and engineering enterprises struggle with manual BOM creation, pricing inconsistencies, quote
        delays, and sales-engineering dependency. The ERP-Integrated Product Configurator closes the gap between sales
        engineering and production execution.
      </p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget — ERP Core vs ERP Execution Platform **************** -->

  <Content
    isAfterContent={true}
    items={[
      {
        title: 'Financial governance → Operational workflows',
        icon: 'tabler:arrows-exchange',
      },
      {
        title: 'Structured transactions → Real-time execution',
        icon: 'tabler:arrows-exchange',
      },
      {
        title: 'SAP GUI → Modern web & mobile interfaces',
        icon: 'tabler:arrows-exchange',
      },
      {
        title: 'Master data control → Execution data capture',
        icon: 'tabler:arrows-exchange',
      },
      {
        title: 'System of record → Execution enablement layer',
        icon: 'tabler:arrows-exchange',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2015&q=80',
      alt: 'ERP Core vs ERP Execution Platform Comparison',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        ERP Core vs Execution Platform: <br /><span class="text-2xl">Both Are Required</span>
      </h3>
      <p class="text-muted mt-2">
        ERP Core handles financial governance, structured transactions, and master data control. The ERP Execution
        Platform enables real-time operational workflows, modern interfaces, and execution data capture. Together, they
        deliver complete enterprise coverage.
      </p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Features3 Widget — Architecture Overview ************** -->

  <Features3
    id="architecture"
    title="Architecture Overview"
    subtitle="Secure, standards-based integration with SAP, Oracle, and Epicor — no core modification required."
    columns={4}
    items={[
      {
        title: 'SAP S/4HANA',
        description: 'Native integration with SAP S/4HANA APIs and services.',
        icon: 'tabler:database',
      },
      {
        title: 'SAP ECC',
        description: 'Full support for SAP ECC environments via BAPI and IDoc.',
        icon: 'tabler:server',
      },
      {
        title: 'SAP Business One',
        description: 'Integration via Service Layer APIs for SME enterprises.',
        icon: 'tabler:building',
      },
      {
        title: 'Oracle & Epicor',
        description: 'Extended support for Oracle ERP and Epicor through secure API integration.',
        icon: 'tabler:plug-connected',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features3>

  <!-- Features3 Widget — Integration Methods ************** -->

  <Features3
    title="Integration Methods"
    subtitle="Standards-based integration protocols ensuring secure and reliable ERP connectivity."
    columns={4}
    items={[
      {
        title: 'OData',
        description: 'RESTful API protocol for SAP S/4HANA and modern SAP systems.',
        icon: 'tabler:api',
      },
      {
        title: 'IDoc',
        description: 'SAP Intermediate Document format for asynchronous data exchange.',
        icon: 'tabler:file-export',
      },
      {
        title: 'BAPI',
        description: 'Business Application Programming Interfaces for direct SAP function calls.',
        icon: 'tabler:code',
      },
      {
        title: 'Service Layer APIs',
        description: 'SAP Business One Service Layer for real-time data integration.',
        icon: 'tabler:layers-intersect',
      },
    ]}
  />

  <!-- Features3 Widget — Security & Governance ************** -->

  <Features3
    title="Enterprise Security & Governance"
    subtitle="Enterprise-grade security ensuring data integrity and compliance across all execution touchpoints."
    columns={4}
    items={[
      {
        title: 'Role-Based Access Control',
        description: 'Granular permission management aligned with enterprise security policies.',
        icon: 'tabler:lock',
      },
      {
        title: 'SAP Authorization Alignment',
        description: 'Respect and enforce SAP authorization objects and user roles.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Encrypted API Communication',
        description: 'All data exchange encrypted in transit and at rest.',
        icon: 'tabler:key',
      },
      {
        title: 'Audit Logging',
        description: 'Complete audit trail for every transaction and data access.',
        icon: 'tabler:clipboard-check',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features3>

  <!-- Stats Widget — Measurable Impact ****************** -->

  <Stats
    title="Measurable Enterprise Impact"
    subtitle="Organizations implementing the UpBuff ERP Execution Platform typically achieve:"
    stats={[
      { amount: '30-50%', title: 'Reduction in Manual Coordination', icon: 'tabler:arrows-minimize' },
      { amount: '40-60%', title: 'Faster Quotation Cycles', icon: 'tabler:clock-bolt' },
      { amount: '↓', title: 'Reduced Configuration Errors', icon: 'tabler:bug-off' },
      { amount: '↑', title: 'Improved Warehouse Productivity', icon: 'tabler:trending-up' },
      { amount: '↑', title: 'Faster Order-to-Delivery Cycles', icon: 'tabler:rocket' },
      { amount: '↓', title: 'Lower SAP Customization Costs', icon: 'tabler:coin-off' },
    ]}
  />

  <!-- Features3 Widget — Global Deployment ************** -->

  <Features3
    title="Global Deployment Capability"
    subtitle="Serving enterprises across India, North America, and the Middle East."
    columns={4}
    items={[
      {
        title: 'Multi-Country Operations',
        description: 'Support region-specific business processes and compliance.',
        icon: 'tabler:world',
      },
      {
        title: 'Multi-Currency Pricing',
        description: 'Handle transactions across multiple currencies with ERP sync.',
        icon: 'tabler:currency-dollar',
      },
      {
        title: 'Multi-Entity Enterprises',
        description: 'Support complex organizational structures and entities.',
        icon: 'tabler:hierarchy-3',
      },
      {
        title: 'Cloud / Hybrid / On-Prem',
        description: 'Flexible deployment models to suit enterprise requirements.',
        icon: 'tabler:cloud-computing',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features3>

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Get answers to common questions about the UpBuff ERP Execution Platform and how it extends SAP into operational execution."
    tagline="FAQs"
    classes={{ container: 'max-w-5xl' }}
    items={[
      {
        title: 'What is an ERP Execution Platform?',
        description:
          'An ERP Execution Platform extends SAP systems into operational environments such as field service, warehouse, manufacturing, product configuration, and partner collaboration while keeping SAP as the system of record.',
      },
      {
        title: 'Is it the same as SAP customization?',
        description:
          'No. Customization modifies SAP core. An ERP Execution Platform integrates externally via APIs, preserving upgrade stability and reducing maintenance costs.',
      },
      {
        title: 'Does it replace SAP?',
        description:
          'No. It enhances SAP operationally. SAP remains the system of record for financial governance, master data, and structured transactions.',
      },
      {
        title: 'How does Product Configuration integrate with SAP?',
        description:
          'It connects with SAP SD and PP to automate quotations, pricing validation, and BOM generation — enabling rule-based product configuration without manual re-entry.',
      },
      {
        title: 'Which SAP systems are supported?',
        description:
          'UpBuff integrates with SAP S/4HANA, SAP ECC, and SAP Business One using OData, IDoc, BAPI, and Service Layer APIs.',
      },
      {
        title: 'Does it support Oracle and Epicor?',
        description:
          'Yes. In addition to SAP systems, UpBuff also extends Oracle ERP and Epicor into operational execution domains through secure API-based integration.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Ready to Close the ERP Execution Gap?"
    subtitle="Talk to UpBuff experts today and discover how the ERP Execution Platform extends SAP into real-time operational execution."
    actions={[
      {
        variant: 'primary',
        text: 'Request Demo',
        href: '/contact',
      },
    ]}
  />

  <!-- Content Widget — Internal Links / Explore More **************** -->

  <Content
    title="Explore More"
    subtitle="Discover related UpBuff solutions and resources for your enterprise."
    items={[
      {
        title: 'SAP Integration Services',
        description: 'Learn how UpBuff integrates with SAP S/4HANA, ECC, and Business One.',
        callToAction: {
          text: 'Explore',
          href: '/sap-integration-services',
        },
      },
      {
        title: 'Industries — Manufacturing',
        description: 'See how UpBuff serves the manufacturing industry with ERP execution solutions.',
        callToAction: {
          text: 'Explore',
          href: '/industries/manufacturing',
        },
      },
      {
        title: 'Case Studies',
        description: 'Read real-world success stories from enterprises using the UpBuff platform.',
        callToAction: {
          text: 'Read case studies',
          href: '/case-studies',
        },
      },
      {
        title: 'Security & Compliance',
        description: 'Understand how UpBuff ensures enterprise-grade security and compliance.',
        callToAction: {
          text: 'Learn more',
          href: '/security-compliance',
        },
      },
