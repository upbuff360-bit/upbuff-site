---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Content from '~/components/widgets/Content.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { headerData } from '~/navigation';

const metadata = {
  title: 'Why UpBuff | Clean Core ERP Execution Platform for SAP & Enterprise ERP',
  description:
    'Discover why UpBuff is the ERP execution layer of choice for SAP, Epicor, and Oracle environments. Upgrade-safe, Clean Core, API-based architecture.',
  canonical: 'https://www.upbuff.com/why-upbuff/',
  openGraph: {
    type: 'website',
    url: 'https://www.upbuff.com/why-upbuff/',
    title: 'Why UpBuff | ERP Execution Layer for Enterprise ERP',
    description:
      'Reduce ERP customization risk. Adopt a Clean Core execution platform designed for SAP and enterprise ERP landscapes.',
    image: 'https://www.upbuff.com/images/why-upbuff.png',
  },
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <meta name="author" content="UpBuff Technologies" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "UpBuff",
      "url": "https://www.upbuff.com",
      "logo": "https://www.upbuff.com/logo.png"
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "UpBuff ERP Execution Platform",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web, Android, iOS",
      "description": "Clean Core ERP execution platform integrating with SAP, Epicor, and Oracle using API-based architecture."
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How is UpBuff different from ERP add-ons?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "UpBuff operates as an external execution layer instead of embedding heavy customization inside ERP core systems."
          }
        },
        {
          "@type": "Question",
          "name": "Why not just customize ERP for execution?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ERP customization increases upgrade risk, long-term maintenance cost, and technical debt. UpBuff preserves ERP stability while enabling execution agility."
          }
        },
        {
          "@type": "Question",
          "name": "Is UpBuff suitable for SAP upgrade roadmaps?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. UpBuff aligns with Clean Core strategies and integrates via official APIs."
          }
        }
      ]
    })} />
  </Fragment>

  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        { variant: 'secondary', text: 'Login', href: '#' },
        { variant: 'primary', text: 'Sign Up', href: '#' },
      ]}
      isSticky
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline="Why UpBuff"
    actions={[
      { variant: 'primary', text: 'Explore Platform Overview', href: '/platform/overview' },
      { text: 'Request Demo', href: '/contact', icon: 'tabler:message-circle' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'Why UpBuff — Clean Core ERP Execution Layer',
    }}
  >
    <Fragment slot="title">
      Because ERP Should Stay Stable — <br />
      <span class="text-accent dark:text-white">And Execution Should Stay Agile</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        Most enterprises extend ERP the wrong way. When operational needs grow, the default response is to customize
        the ERP — leading to upgrade delays, technical debt, and compliance risks. UpBuff exists to solve this problem
        differently. We are not an ERP add-on. We are not a core modification tool. UpBuff is an
        <strong>ERP Execution Layer</strong> designed to preserve ERP integrity while enabling operational agility.
      </span>
    </Fragment>
  </Hero2>

  <!-- The Problem With ERP Customization **************** -->

  <Content
    title="The Problem With ERP Customization"
    subtitle="When operational needs grow, the default response is: Let's customize the ERP."
    isReversed
    items={[
      { title: 'Upgrade delays' },
      { title: 'Technical debt' },
      { title: 'Consultant dependency' },
      { title: 'Performance instability' },
      { title: 'Compliance risks' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'ERP Customization Problems',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Over time, that leads to:</h3>
      <p class="text-muted mt-2">UpBuff exists to solve this problem differently.</p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Seven Reasons **************** -->

  <Features3
    title="Seven Reasons Enterprises Choose UpBuff"
    subtitle="A principled architecture built for long-term ERP stability and operational excellence."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Clean Core by Design',
        description:
          'No direct database manipulation. API-based integration only. No hidden core enhancements. Upgrade-safe architecture aligned with modern Clean Core ERP strategies.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Upgrade-Safe Architecture',
        description:
          'UpBuff integrates via official APIs and service layers. When ERP upgrades, the core remains untouched and your execution layer continues operating with minimal disruption.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Built for Operational Users',
        description:
          'Mobile-first interfaces, scanning-friendly workflows, minimal clicks, and real-time validation — designed for warehouse operators, production supervisors, and field technicians.',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Lower Long-Term TCO',
        description:
          'Reduces custom code inside ERP, dependency on niche consultants, and rework during upgrades — improving long-term cost predictability.',
        icon: 'tabler:coin-off',
      },
      {
        title: 'Enterprise-Grade Security',
        description:
          'Encrypted API communication, role-based access control, transaction audit logs, and preserved ERP compliance integrity.',
        icon: 'tabler:lock',
      },
      {
        title: 'Designed for Enterprise ERP Landscapes',
        description:
          'Integrates seamlessly with SAP S/4HANA, SAP ECC, SAP Business One, Epicor ERP, and Oracle ERP across on-premise, hybrid, and private cloud deployments.',
        icon: 'tabler:layers-intersect',
      },
    ]}
  />

  <!-- Clean Core by Design ****************** -->

  <Content
    title=" Clean Core by Design"
    subtitle="Enterprise platforms like SAP S/4HANA, SAP ECC, SAP Business One, Epicor ERP, and Oracle ERP are built as systems of record. They are not optimized for high-frequency mobile execution."
    isReversed
    items={[
      { title: 'No direct database manipulation' },
      { title: 'API-based integration only' },
      { title: 'No hidden core enhancements' },
      { title: 'Upgrade-safe architecture' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2034&q=80',
      alt: 'Clean Core by Design',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">UpBuff keeps ERP clean:</h3>
      <p class="text-muted mt-2">This aligns with modern Clean Core ERP strategies.</p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Upgrade-Safe Architecture ****************** -->

  <Content
    title="Upgrade-Safe Architecture"
    subtitle="ERP upgrades should not feel like re-implementation projects."
    isAfterContent={true}
    items={[
      { title: 'Regression testing cycles' },
      { title: 'Integration breakage' },
      { title: 'Rework costs' },
      { title: 'Long freeze periods' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Upgrade-Safe Architecture',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Traditional customization causes:
      </h3>
      <p class="text-muted mt-2">
        UpBuff integrates via official APIs and service layers. When ERP upgrades, the core remains untouched. Your
        execution layer continues operating with minimal disruption.
      </p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Built for Operational Users ****************** -->

  <Content
    title="Built for Operational Users — Not Just Back Office"
    subtitle="ERP screens were designed for administrative users. Execution users need something different."
    isReversed
    isAfterContent={true}
    items={[
      { title: 'Warehouse operators' },
      { title: 'Production supervisors' },
      { title: 'Field technicians' },
      { title: 'Sales representatives' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Built for Operational Users',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">UpBuff is designed for:</h3>
      <p class="text-muted mt-2">
        Operational speed improves without compromising ERP governance.
      </p>
    </Fragment>
  </Content>

  <!-- TCO & Security ****************** -->

  <Features3
    title="Lower TCO & Enterprise-Grade Security"
    subtitle="Two critical dimensions that define the long-term value of choosing UpBuff."
    columns={2}
    items={[
      {
        title: ' Lower Long-Term Total Cost of Ownership',
        description:
          'Customization often appears cheaper initially. But over time it leads to higher maintenance costs, external consultant reliance, upgrade complexity, and accumulated technical debt. UpBuff reduces custom code inside ERP, dependency on niche consultants, and rework during upgrades.',
        icon: 'tabler:coin-off',
      },
      {
        title: 'Enterprise-Grade Security & Compliance',
        description:
          'Security is architecture — not a checkbox. UpBuff uses encrypted API communication, supports role-based access control, maintains transaction audit logs, and preserves ERP compliance integrity.',
        icon: 'tabler:shield-lock',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features3>

  <!-- ERP Landscape ****************** -->

  <Content
    title="Designed for Enterprise ERP Landscapes"
    subtitle="UpBuff integrates seamlessly with the enterprise ERP platforms your organization depends on."
    isReversed
    items={[
      { title: 'SAP S/4HANA' },
      { title: 'SAP ECC' },
      { title: 'SAP Business One' },
      { title: 'Epicor ERP' },
      { title: 'Oracle ERP' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1555949963-ff9fe0c870eb?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Enterprise ERP Landscapes',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Supporting:</h3>
      <ul class="text-muted mt-2 space-y-1 list-disc list-inside">
        <li>On-premise</li>
        <li>Hybrid</li>
        <li>Private cloud deployments</li>
      </ul>
    </Fragment>
  </Content>

  <!-- Strategic Advantage ****************** -->

  <Steps2
    title="Strategic Advantage — Not Just Functional Extension"
    subtitle="This is not just technical improvement. It is architectural maturity."
    items={[
      {
        title: 'Modernize execution',
        description: 'Replace fragile custom ERP workflows with clean, mobile-first execution layer capabilities.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Reduce ERP risk exposure',
        description: 'Eliminate the customization-driven vulnerabilities that accumulate silently inside ERP core systems.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Improve upgrade readiness',
        description: 'Ensure every ERP upgrade cycle is predictable, low-risk, and free of execution-layer breakage.',
        icon: 'tabler:refresh',
      },
      {
        title: 'Increase operational agility',
        description: 'Deliver new operational workflows faster without waiting for ERP release cycles.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Align with Clean Core strategies',
        description: 'Stay aligned with SAP Clean Core and enterprise ERP best practices for long-term system health.',
        icon: 'tabler:circle-check',
      },
    ]}
  />

  <!-- Who Chooses UpBuff **************** -->

  <Features
    title="Who Chooses UpBuff?"
    columns={2}
    items={[
      { title: 'CIOs implementing Clean Core ERP strategies', icon: 'tabler:user-star' },
      { title: 'IT architects reducing customization exposure', icon: 'tabler:device-desktop-analytics' },
      { title: 'Operations leaders modernizing execution', icon: 'tabler:settings' },
      { title: 'Enterprises preparing ERP upgrades', icon: 'tabler:rocket' },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <!-- Internal Links **************** -->

  <Features3
    title="Explore UpBuff"
    subtitle="Browse related pages to understand the full UpBuff platform."
    columns={3}
    items={[
      {
        title: 'Platform Overview',
        icon: 'tabler:layout-dashboard',
        callToAction: { text: 'Explore', href: '/platform/overview', variant: 'link' },
      },
      {
        title: 'Security & Compliance',
        icon: 'tabler:shield-lock',
        callToAction: { text: 'Learn more', href: '/security-compliance', variant: 'link' },
      },
      {
        title: 'All Integrations',
        icon: 'tabler:plug-connected',
        callToAction: { text: 'Explore', href: '/integrations', variant: 'link' },
      },
      {
        title: 'Industry Solutions',
        icon: 'tabler:briefcase',
        callToAction: { text: 'Explore', href: '/solutions', variant: 'link' },
      },
      {
        title: 'Manufacturing & Shopfloor',
        icon: 'tabler:tool',
        callToAction: { text: 'Explore', href: '/products/manufacturing-shopfloor', variant: 'link' },
      },
      {
        title: 'Warehouse & Inventory',
        icon: 'tabler:package',
        callToAction: { text: 'Explore', href: '/products/warehouse-inventory', variant: 'link' },
      },
    ]}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    tagline="FAQs"
    classes={{ container: 'max-w-5xl' }}
    items={[
      {
        title: 'How is UpBuff different from ERP add-ons?',
        description:
          'UpBuff operates as an external execution layer instead of embedding heavy customization inside ERP core systems.',
      },
      {
        title: 'Why not just customize ERP for execution?',
        description:
          'ERP customization increases upgrade risk, long-term maintenance cost, and technical debt. UpBuff preserves ERP stability while enabling execution agility.',
      },
      {
        title: 'Is UpBuff suitable for SAP upgrade roadmaps?',
        description:
          'Yes. UpBuff aligns with Clean Core strategies for environments such as SAP S/4HANA and supports upgrade-safe integration.',
      },
      {
        title: 'Can UpBuff replace existing custom workflows?',
        description:
          'Yes. Many enterprises migrate custom execution logic out of ERP into UpBuff to reduce risk and improve scalability.',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </FAQs>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Ready to modernize ERP execution without compromising stability?"
    actions={[
      { variant: 'primary', text: 'Explore Platform Overview', href: '/platform/overview' },
      { text: 'Request Demo', href: '/contact', icon: 'tabler:message-circle' },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </CallToAction>
</Layout>
