---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features from '~/components/widgets/Features.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Content from '~/components/widgets/Content.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { headerData } from '~/navigation';

const metadata = {
  title: 'About UpBuff | Clean Core ERP Execution & Generative AI Platform',
  description:
    'Learn about UpBuff — a Clean Core ERP Execution Platform extending SAP Business One with secure API integration and Generative AI-powered ERP intelligence.',
  canonical: 'https://www.upbuff.com/about/',
  openGraph: {
    type: 'website',
    url: 'https://www.upbuff.com/about/',
    title: 'About UpBuff | ERP Execution & Generative AI Platform',
    description:
      'UpBuff extends SAP Business One and other ERP systems with Clean Core architecture and Generative AI-powered execution workflows.',
    image: 'https://www.upbuff.com/images/upbuff-platform.png',
  },
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <meta name="author" content="UpBuff Technologies" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "UpBuff",
      "url": "https://www.upbuff.com",
      "logo": "https://www.upbuff.com/logo.png",
      "description": "UpBuff is a Clean Core ERP Execution and Generative AI platform extending SAP Business One and enterprise ERP environments without modifying the ERP core.",
      "sameAs": ["https://www.linkedin.com/company/upbuff"]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": "https://www.upbuff.com",
      "name": "UpBuff ERP Execution Platform"
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "UpBuff ERP Execution Platform",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web, Android, iOS",
      "description": "ERP Execution and Generative AI platform integrating with SAP Business One and enterprise ERP systems using Clean Core architecture."
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a Clean Core ERP strategy?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A Clean Core ERP strategy avoids modifying ERP core logic and instead extends functionality through APIs and integration layers."
          }
        },
        {
          "@type": "Question",
          "name": "Does UpBuff only support SAP Business One?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "While we have strong expertise in SAP Business One, our execution platform architecture is designed for API-based ERP ecosystems."
          }
        }
      ]
    })} />
  </Fragment>

  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        { variant: 'secondary', text: 'Login', href: '#' },
        { variant: 'primary', text: 'Sign Up', href: '#' },
      ]}
      isSticky
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline="About UpBuff"
    actions={[
      { variant: 'primary', text: 'Request a Platform Walkthrough', href: '/contact' },
      { text: 'Talk to Our Integration Experts', href: '/contact', icon: 'tabler:message-circle' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'UpBuff ERP Execution and Intelligence Platform',
    }}
  >
    <Fragment slot="title">
      ERP Execution and Intelligence Platform. <br />
      <span class="text-accent dark:text-white">Without Touching Your Core.</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        UpBuff is an <strong>ERP Execution and Intelligence Platform</strong> built to extend enterprise ERP systems
        without modifying their core. We specialize in <strong>Clean Core ERP strategy</strong>, enabling organizations
        to modernize operational workflows while preserving upgrade safety and long-term scalability. Our primary
        expertise lies in extending <strong>SAP Business One</strong> environments through secure API-based integration
        and Generative AI-powered intelligence.
      </span>
    </Fragment>
  </Hero2>

  <!-- Stats Widget ****************** -->

  <Stats
    title="UpBuff at a Glance"
    stats={[
      { title: 'ERP Integrations', amount: 'API-First' },
      { title: 'Core Modified', amount: '0' },
      { title: 'Industries Served', amount: '5+' },
      { title: 'Platforms Supported', amount: 'Web, Android, iOS' },
    ]}
  />

  <!-- Our Mission ****************** -->

  <Content
    title="Our Mission"
    subtitle="To help enterprises execute faster without breaking their ERP core."
    isReversed
    items={[
      { title: 'Systems of Record' },
      { title: 'Financial Authorities' },
      { title: 'Compliance Backbones' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'UpBuff Mission — Clean Core ERP',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        We believe ERP systems should remain:
      </h3>
      <p class="mt-3 text-muted">
        Execution agility, mobility, and AI intelligence should exist <strong>outside the core</strong> — not inside
        it. That philosophy drives everything we build.
      </p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- What Makes UpBuff Different ****************** -->

  <Features3
    title="What Makes UpBuff Different"
    subtitle="Three core principles set UpBuff apart from conventional ERP extension approaches."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Clean Core First',
        description:
          'No direct database manipulation. Our architecture ensures API-first integration, upgrade-safe deployment, and long-term ERP stability — without risky customization.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Execution-Layer Architecture',
        description:
          'Instead of embedding complexity inside ERP, we create a dedicated Execution Layer for manufacturing, warehouse, field service, and sales & distribution operations.',
        icon: 'tabler:layers-intersect',
      },
      {
        title: 'Generative AI-Driven Intelligence',
        description:
          'We integrate secure Generative AI capabilities into ERP environments — enabling conversational reporting, context-aware KPI summaries, and intelligent anomaly detection.',
        icon: 'tabler:brain',
      },
    ]}
  />

  <!-- Clean Core Detail ****************** -->

  <Content
    title="1. Clean Core First"
    subtitle="We do not believe in risky ERP customization."
    isReversed
    items={[
      { title: 'No direct database manipulation' },
      { title: 'API-first integration' },
      { title: 'Upgrade-safe deployment' },
      { title: 'Long-term ERP stability' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2034&q=80',
      alt: 'Clean Core ERP Architecture',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Our architecture ensures:</h3>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Execution Layer Detail ****************** -->

  <Content
    title="2. Execution-Layer Architecture"
    subtitle="Instead of embedding complexity inside ERP, we create a dedicated Execution Layer."
    isAfterContent={true}
    items={[
      { title: 'Manufacturing & shopfloor mobility' },
      { title: 'Warehouse workflows' },
      { title: 'Field service operations' },
      { title: 'Sales & distribution execution' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1565043666747-69f6646db940?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1974&q=80',
      alt: 'UpBuff Execution Layer Architecture',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        ERP remains stable. Execution becomes agile.
      </h3>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Generative AI Detail ****************** -->

  <Content
    title="3. Generative AI-Driven ERP Intelligence"
    subtitle="UpBuff integrates secure Generative AI capabilities into ERP environments."
    isReversed
    isAfterContent={true}
    items={[
      { title: 'Conversational reporting' },
      { title: 'Context-aware KPI summaries' },
      { title: 'Operational insights' },
      { title: 'Intelligent anomaly detection' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1677442135703-1787eea5ce01?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Generative AI ERP Intelligence',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        We transform ERP from a transactional system into an intelligent decision engine.
      </h3>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Our Focus Areas ****************** -->

  <Features
    title="Our Focus Areas"
    subtitle="We serve enterprises operating across high-execution industries, with strong expertise in SAP-centric environments."
    columns={3}
    items={[
      { title: 'Manufacturing', icon: 'tabler:tool' },
      { title: 'Distribution', icon: 'tabler:truck' },
      { title: 'Warehouse-Intensive Industries', icon: 'tabler:package' },
      { title: 'Field Service Organizations', icon: 'tabler:map-pin' },
      { title: 'Sales-Driven Operations', icon: 'tabler:trending-up' },
      { title: 'SAP Business One Environments', icon: 'tabler:database' },
    ]}
  />

  <!-- Who We Work With ****************** -->

  <Steps2
    title="Who We Work With"
    subtitle="UpBuff is built for the leaders and partners who understand that ERP evolution must not come at the cost of stability."
    items={[
      {
        title: 'CIOs implementing Clean Core ERP strategy',
        description:
          'Decision-makers driving long-term ERP architecture who need execution capability without compromising upgrade paths.',
        icon: 'tabler:user-star',
      },
      {
        title: 'IT Heads reducing customization risk',
        description:
          'Technology leaders looking to eliminate fragile ERP modifications and reduce total cost of ownership.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Operations leaders driving execution excellence',
        description:
          'Operational teams in manufacturing, warehouse, field service, and sales who need mobile-first, real-time ERP-connected workflows.',
        icon: 'tabler:settings',
      },
      {
        title: 'SAP implementation partners',
        description:
          'System integrators and SAP partners who need a proven execution layer to complement their ERP implementations.',
        icon: 'tabler:users',
      },
    ]}
  />

  <!-- Our Philosophy ****************** -->

  <Steps2
    title="Our Philosophy"
    subtitle="UpBuff exists to balance stability, agility, and intelligence across the enterprise ERP landscape."
    isReversed={true}
    callToAction={{
      text: 'Explore the Platform',
      href: '/platform/overview',
    }}
    items={[
      {
        title: 'ERP should evolve without becoming fragile',
        description: 'Every upgrade, every change must strengthen the system — not create new risks or technical debt.',
        icon: 'tabler:refresh',
      },
      {
        title: 'Innovation should not block upgrades',
        description:
          'New capabilities must be layered outside the core so ERP upgrade paths remain clean and predictable.',
        icon: 'tabler:rocket',
      },
      {
        title: 'AI should empower decisions — not compromise data security',
        description:
          'Generative AI capabilities are integrated with enterprise-grade security, keeping sensitive ERP data protected.',
        icon: 'tabler:brain',
      },
    ]}
  />

  <!-- Looking Ahead ****************** -->

  <Features3
    title="Looking Ahead"
    subtitle="As ERP ecosystems evolve toward API-first, cloud-native, and AI-augmented architectures, UpBuff continues to invest in the next layer of enterprise ERP execution."
    columns={2}
    isAfterContent={true}
    items={[
      {
        title: 'Secure Integration Frameworks',
        description:
          'Expanding API-first connectivity across ERP ecosystems including SAP S/4HANA, SAP ECC, and SAP Business One.',
        icon: 'tabler:plug-connected',
      },
      {
        title: 'Generative AI Capabilities',
        description:
          'Deepening AI-powered ERP intelligence with conversational interfaces, predictive insights, and context-aware decision support.',
        icon: 'tabler:sparkles',
      },
      {
        title: 'Scalable Execution Platforms',
        description:
          'Building multi-location, multi-entity execution layers that grow with enterprise operations across industries.',
        icon: 'tabler:world',
      },
      {
        title: 'Upgrade-Resilient ERP Extensions',
        description:
          'Continuously validating our architecture against ERP upgrade cycles to ensure long-term compatibility and stability.',
        icon: 'tabler:shield-check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2072&q=80',
      alt: 'UpBuff Future Platform Roadmap',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    tagline="FAQs"
    classes={{ container: 'max-w-5xl' }}
    items={[
      {
        title: 'What is a Clean Core ERP strategy?',
        description:
          'A Clean Core strategy avoids modifying ERP core logic and instead extends functionality using APIs and integration layers, preserving upgrade paths and long-term ERP stability.',
      },
      {
        title: 'Does UpBuff only support SAP Business One?',
        description:
          'While we have strong expertise in SAP Business One, our execution platform architecture is designed for API-based ERP ecosystems and can extend other SAP environments as well.',
      },
      {
        title: 'What is an ERP Execution Platform?',
        description:
          'An ERP Execution Platform is a dedicated layer that sits outside the ERP core, enabling mobile workflows, real-time data capture, and operational agility — without modifying the ERP system itself.',
      },
      {
        title: 'How does UpBuff integrate Generative AI with ERP?',
        description:
          'UpBuff integrates Generative AI through secure API layers, enabling conversational reporting, KPI summaries, and anomaly detection without exposing sensitive ERP data or compromising compliance.',
      },
    ]}
  />

  <!-- Internal Links **************** -->

  <Features3
    title="Explore UpBuff"
    subtitle="Learn more about the platform, integrations, and solutions that extend your ERP safely."
    columns={3}
    items={[
      {
        title: 'Platform Overview',
        icon: 'tabler:layout-dashboard',
        callToAction: { text: 'Explore', href: '/platform/overview', variant: 'link' },
      },
      {
        title: 'Solutions by Industry',
        icon: 'tabler:briefcase',
        callToAction: { text: 'Explore', href: '/solutions', variant: 'link' },
      },
      {
        title: 'SAP Business One Integration',
        icon: 'tabler:building-store',
        callToAction: { text: 'Explore', href: '/integrations/sap-business-one', variant: 'link' },
      },
      {
        title: 'Security & Compliance',
        icon: 'tabler:shield-lock',
        callToAction: { text: 'Learn more', href: '/security-compliance', variant: 'link' },
      },
      {
        title: 'Why UpBuff',
        icon: 'tabler:star',
        callToAction: { text: 'Learn more', href: '/why-upbuff', variant: 'link' },
      },
      {
        title: 'All Integrations',
        icon: 'tabler:plug-connected',
        callToAction: { text: 'Explore', href: '/integrations', variant: 'link' },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features3>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Want to explore how UpBuff can extend your ERP safely?"
    subtitle="Request a platform walkthrough or speak directly with our integration experts."
    actions={[
      { variant: 'primary', text: 'Request a Platform Walkthrough', href: '/contact' },
      { text: 'Talk to Our Integration Experts', href: '/contact', icon: 'tabler:message-circle' },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </CallToAction>
</Layout>
