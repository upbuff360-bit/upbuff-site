---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import { headerData } from '~/navigation';

const metadata = {
  title: 'Privacy Policy | UpBuff Technologies',
  description:
    'Read the UpBuff Technologies Privacy Policy. Learn how we collect, use, protect, and manage your personal data across our ERP Execution Platform and services.',
  canonical: 'https://www.upbuff.com/privacy/',
  robots: { index: true, follow: true },
};

const lastUpdated = '01 April 2026';
---

<Layout metadata={metadata}>

  <Fragment slot="announcement" />

  <Fragment slot="header">
    <Header
      {...headerData}
      theme="white"
      actions={[
        { variant: 'secondary', text: 'Login',        href: '#' },
        { variant: 'primary',   text: 'Get in Touch', href: '/contact' },
      ]}
      isSticky
    />
  </Fragment>

  <!-- ── Page hero ─────────────────────────────────────────── -->
  <section class="bg-gray-50 border-b border-gray-200 not-prose">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-14 md:py-20">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-gray-200 bg-white shadow-sm mb-5">
        <span class="w-2 h-2 rounded-full bg-indigo-500 shrink-0"></span>
        <span class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Legal</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 tracking-tight leading-tight mb-4">
        Privacy Policy
      </h1>
      <p class="text-gray-500 text-base">Last updated: <time datetime="2023-08-27">{lastUpdated}</time></p>
    </div>
  </section>

  <!-- ── Policy body ───────────────────────────────────────── -->
  <section class="not-prose bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-14 md:py-20">

      <!-- Intro -->
      <div class="mb-12 p-6 md:p-8 rounded-2xl bg-indigo-50 border border-indigo-100">
        <p class="text-gray-700 text-base leading-relaxed">
          At UpBuff, safeguarding your data privacy is our paramount commitment. The trust between you —
          the user — and UpBuff forms the bedrock of our relationship. Central to fostering this trust is our
          dedication to transparently explaining how we use your data and uphold your privacy rights.
        </p>
      </div>

      <!-- Definitions -->
      <div class="mb-10">
        <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Definitions</h2>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">What these terms mean</h3>
        <p class="text-gray-500 text-base leading-relaxed mb-4">
          This policy describes how <strong class="text-gray-900">UpBuff Technologies Pvt. Ltd.</strong>
          (&ldquo;UpBuff&rdquo;, &ldquo;Company&rdquo;, &ldquo;we&rdquo;, &ldquo;us&rdquo;, or &ldquo;our&rdquo;)
          collects, protects, and uses personally identifiable information
          (&ldquo;Personal Information&rdquo; or &ldquo;Personal Data&rdquo;) you
          (&ldquo;Customer&rdquo;, &ldquo;you&rdquo;, or &ldquo;your&rdquo;) may provide through our website
          or any of its products or services (collectively, &ldquo;Website&rdquo;, &ldquo;Products&rdquo;,
          or &ldquo;Application&rdquo;).
        </p>
        <p class="text-gray-500 text-base leading-relaxed">
          It also describes the choices available to you regarding our use of your Personal Information
          and how you can access and update this information. This Policy does not apply to the practices
          of third-party companies that we do not own or control, or to individuals that we do not employ
          or manage.
        </p>
      </div>

      <hr class="border-gray-100 mb-10" />

      <!-- Section 1 -->
      <div class="mb-10">
        <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 1</h2>
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Information collection and use</h3>

        <h4 class="text-base font-bold text-gray-900 mb-3">1.1 Information you choose to give us</h4>
        <p class="text-gray-500 text-base leading-relaxed mb-5">
          You can choose to provide us with additional personal information. This information includes:
        </p>

        <div class="space-y-4 mb-6">
          <div class="flex gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100">
            <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-indigo-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-sm mb-1">Geo-location</p>
              <p class="text-gray-500 text-sm leading-relaxed">Precise or approximate location determined from your IP address or mobile device GPS, depending on your device settings. We may also collect this information when you&rsquo;re not using the app if you enable this through your settings or device permissions.</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100">
            <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-indigo-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-sm mb-1">Contact Information &amp; Profile Data</p>
              <p class="text-gray-500 text-sm leading-relaxed">When you fill in a form, add information to your profile (name, email, contact number, IP address), respond to surveys, participate in promotions, communicate with our team, or share your experience with us.</p>
            </div>
          </div>
        </div>

        <h4 class="text-base font-bold text-gray-900 mb-3">1.2 Information collected automatically</h4>
        <p class="text-gray-500 text-base leading-relaxed mb-4">This information may include:</p>
        <div class="space-y-4 mb-6">
          <div class="flex gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100">
            <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-indigo-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-sm mb-1">Usage Data</p>
              <p class="text-gray-500 text-sm leading-relaxed">Pages or content you view and other actions on the UpBuff Platform.</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100">
            <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-indigo-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-sm mb-1">Log Data &amp; Device Details</p>
              <p class="text-gray-500 text-sm leading-relaxed">Details about how you&rsquo;ve used the UpBuff website (including links to third-party applications), IP address, access dates and times, hardware and software information, device information, unique identifiers, crash data, cookie data, and pages you&rsquo;ve viewed before or after.</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100">
            <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-indigo-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14v-4H7l5-8v4h4l-5 8z"/></svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-sm mb-1">Cookies</p>
              <p class="text-gray-500 text-sm leading-relaxed">As described in our Cookie Policy. Cookies help us understand user behaviour and improve your experience on our platform.</p>
            </div>
          </div>
        </div>

        <h4 class="text-base font-bold text-gray-900 mb-3">1.3 Information from Third Parties</h4>
        <p class="text-gray-500 text-base leading-relaxed">
          <strong class="text-gray-700">Referrals.</strong> If you are invited to the UpBuff platform,
          the person who invited you may submit personal information about you such as your email address
          or other contact information.
        </p>
      </div>

      <hr class="border-gray-100 mb-10" />

      <!-- Section 2 -->
      <div class="mb-10">
        <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 2</h2>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">How we use your information</h3>
        <p class="text-gray-500 text-base leading-relaxed mb-5">
          If you submit your details and give us your consent, we may use your data to:
        </p>
        <ul class="space-y-3">
          {[
            'Send promotional messages, marketing communications, advertising emails, and newsletters.',
            'Re-target or re-market our services using third-party platforms such as Google and Meta.',
            'Invite you to events, webinars, and relevant opportunities aligned with your interests.',
            'Improve our platform, personalise your experience, and develop new features.',
            'Respond to your enquiries and provide customer support.',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <span class="w-5 h-5 rounded-full bg-indigo-100 flex items-center justify-center shrink-0 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-indigo-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              <span class="text-gray-500 text-base leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <hr class="border-gray-100 mb-10" />

      <!-- Section 3 -->
      <div class="mb-10">
        <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 3</h2>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Disclosure to third parties</h3>
        <p class="text-gray-500 text-base leading-relaxed mb-4">
          Depending on the requested services or as necessary to provide any service you have requested,
          we may share your information with trusted third parties that work with us, including affiliates
          and subsidiaries we rely upon to assist in operating the website and services.
        </p>
        <p class="text-gray-500 text-base leading-relaxed mb-4">
          We do not share Personal Information with unaffiliated third parties for their own marketing
          or other purposes. These service providers are not authorised to use or disclose your information
          except as necessary to perform services on our behalf or comply with legal requirements.
        </p>
        <p class="text-gray-500 text-base leading-relaxed">
          Third parties are given only the Personal Information they need to perform their designated
          functions, and we do not authorise them to use or disclose Personal Information for their
          own purposes.
        </p>
      </div>

      <hr class="border-gray-100 mb-10" />

      <!-- Section 4 -->
      <div class="mb-10">
        <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 4</h2>
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Your rights over your data</h3>
        <p class="text-gray-500 text-base leading-relaxed mb-6">
          You can exercise any of the rights described in this section consistent with applicable law.
          We may ask you to verify your identity before taking further action on your request.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {[
            { title: 'Manage your information', body: 'You can access and update some of your personal information through your account settings. You are responsible for keeping your personal information up to date.' },
            { title: 'Data access & portability', body: 'In some jurisdictions, applicable law may entitle you to request copies of your personal information in a structured, commonly used, and machine-readable format.' },
            { title: 'Data deletion', body: 'In certain jurisdictions, you can request that your personal information be deleted. Note that we may retain information for legitimate business interests or legal compliance obligations.' },
          ].map((item) => (
            <div class="rounded-xl border border-gray-100 bg-gray-50 p-5">
              <h4 class="font-bold text-gray-900 text-sm mb-2">{item.title}</h4>
              <p class="text-sm text-gray-500 leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>

      <hr class="border-gray-100 mb-10" />

      <!-- Sections 5–12 as clean prose -->
      <div class="space-y-10">

        <div>
          <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 5</h2>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Privacy of children</h3>
          <p class="text-gray-500 text-base leading-relaxed">
            We do not knowingly collect any Personal Information from children under the age of 18.
            If you are under 18, please do not submit any Personal Information through our website or
            services. We encourage parents and legal guardians to monitor their children&rsquo;s internet
            usage and help enforce this Policy. If you have reason to believe that a child under 18 has
            provided Personal Information to us, please contact us immediately.
          </p>
        </div>

        <hr class="border-gray-100" />

        <div>
          <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 6</h2>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Security of personal information</h3>
          <p class="text-gray-500 text-base leading-relaxed mb-4">
            We implement industry-standard technical and organisational measures using a variety of
            security technologies and procedures to help protect your data from unauthorised access,
            use, loss, destruction, or disclosure. When we collect particularly sensitive data (such
            as geo-location), it is encrypted using industry-standard SSL (Secure Socket Layer).
          </p>
          <p class="text-gray-500 text-base leading-relaxed">
            Your password is your first line of defence once you set up an UpBuff account. We recommend
            setting a strong password that you never share with anyone and signing out of your account
            after each session.
          </p>
        </div>

        <hr class="border-gray-100" />

        <div>
          <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 7</h2>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Third-party links</h3>
          <p class="text-gray-500 text-base leading-relaxed">
            We may display links to third-party websites or applications on our website for advertising
            or to provide you with relevant content. We are not responsible for such third-party
            websites or applications if you choose to access them. If you provide data to such a
            website or application, please review their own privacy policies — you will no longer be
            bound by this Policy in doing so.
          </p>
        </div>

        <hr class="border-gray-100" />

        <div>
          <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 8</h2>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Business transfer</h3>
          <p class="text-gray-500 text-base leading-relaxed">
            If UpBuff undertakes or is involved in any merger, acquisition, reorganisation, sale of
            assets, bankruptcy, or insolvency event, we may sell, transfer, or share some or all of
            our assets — including your information — in connection with such a transaction. In this
            event, we will notify you before your personal information is transferred and becomes
            subject to a different privacy policy.
          </p>
        </div>

        <hr class="border-gray-100" />

        <div>
          <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 9</h2>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Disclosure</h3>
          <p class="text-gray-500 text-base leading-relaxed mb-4">
            We will disclose any Personal Information we collect, use, or receive if required or
            permitted by law — such as to comply with a subpoena or similar legal process — and when
            we believe in good faith that disclosure is necessary to protect our rights, protect your
            safety or the safety of others, investigate fraud, or respond to a government request.
          </p>
          <p class="text-gray-500 text-base leading-relaxed">
            Where appropriate, we may notify users about legal requests unless prohibited by the
            legal process itself, by court order, or by applicable law, or if we believe providing
            notice would be futile or create a risk of harm.
          </p>
        </div>

        <hr class="border-gray-100" />

        <div>
          <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 10</h2>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Data breach</h3>
          <p class="text-gray-500 text-base leading-relaxed">
            In the event we become aware that the security of the website has been compromised or
            users&rsquo; Personal Information has been disclosed to unrelated third parties as a result
            of external activity — including security attacks or fraud — we reserve the right to take
            reasonably appropriate measures, including investigation, reporting, and cooperation with
            law enforcement. We will make reasonable efforts to notify affected individuals if we
            believe there is a reasonable risk of harm as a result of the breach, or if notice is
            otherwise required by law.
          </p>
        </div>

        <hr class="border-gray-100" />

        <div>
          <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 11</h2>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Changes to this policy</h3>
          <p class="text-gray-500 text-base leading-relaxed">
            We reserve the right to modify this Privacy Policy at any time in accordance with
            applicable law. If we do so, we will post the revised Privacy Policy and update the
            &ldquo;Last Updated&rdquo; date at the top of this page. In case of material changes, we will
            also provide you with notice by email at least thirty (30) days before the effective date.
            Your continued use of the UpBuff Platform after the date the revised Privacy Policy
            becomes effective will constitute your acceptance of those changes.
          </p>
        </div>

        <hr class="border-gray-100" />

        <div>
          <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 12</h2>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Acceptance of this policy</h3>
          <p class="text-gray-500 text-base leading-relaxed">
            You acknowledge that you have read this Policy and agree to all its terms and conditions.
            By using the website or its services you agree to be bound by this Policy. If you do not
            agree to abide by the terms of this Policy, you are not authorised to use or access the
            website and its products.
          </p>
        </div>

        <hr class="border-gray-100" />

        <!-- Contact -->
        <div class="rounded-2xl bg-gray-50 border border-gray-200 p-6 md:p-8">
          <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Section 13</h2>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Contact information</h3>
          <p class="text-gray-500 text-base leading-relaxed mb-5">
            For questions or complaints about this Privacy Policy or how UpBuff handles your
            personal information, please reach out to us:
          </p>
          <div class="flex flex-col gap-3">
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-500 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              <span class="text-gray-700 text-base">
                UpBuff Technologies Pvt. Ltd., 5th Floor, CDAC, Technopark,
                Thiruvananthapuram, Kerala, India &ndash; 695582
              </span>
            </div>
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <a href="mailto:support@upbuff.com" class="text-indigo-600 hover:underline text-base font-medium">
                support@upbuff.com
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>