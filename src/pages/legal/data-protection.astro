---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import { headerData } from '~/navigation';

const metadata = {
  title: 'Data Protection | UpBuff Technologies',
  description:
    'Learn how UpBuff Technologies protects your data through five-layer security architecture, cloud infrastructure, network controls, and responsible disclosure practices.',
  canonical: 'https://www.upbuff.com/data-protection/',
  robots: { index: false, follow: false },
};

const lastUpdated = '01 April 2026';

const layers = [
  {
    number: '01',
    title: 'Secure Socket Layer (SSL)',
    description: 'All data in transit is encrypted via SSL/TLS, providing an essential barrier against interception and man-in-the-middle attacks across every connection to the UpBuff platform.',
    color: 'bg-blue-50 border-blue-100',
    iconColor: 'text-blue-600',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>',
  },
  {
    number: '02',
    title: 'Cloud Firewall Protection',
    description: 'Infrastructure hosted on AWS, Microsoft Azure, and DigitalOcean is protected by cloud-native firewalls that monitor and block network-level intrusions before they reach application layers.',
    color: 'bg-indigo-50 border-indigo-100',
    iconColor: 'text-indigo-600',
    icon: '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>',
  },
  {
    number: '03',
    title: 'Web Application Firewall (WAF)',
    description: 'A dedicated WAF monitors all incoming traffic, filters malicious IPs, blocks spam and injection attacks, and protects application endpoints from exploitation at the HTTP layer.',
    color: 'bg-purple-50 border-purple-100',
    iconColor: 'text-purple-600',
    icon: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  },
  {
    number: '04',
    title: 'Role-Based Access Control (RBAC)',
    description: 'Every user is granted access only to the data and functions their role requires. Administrators enforce industry-standard password policies, and access privileges are reviewed on a regular cadence.',
    color: 'bg-green-50 border-green-100',
    iconColor: 'text-green-600',
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
  {
    number: '05',
    title: 'API Security Framework',
    description: 'All integrations with third-party platforms — including SAP, Salesforce, and WhatsApp — are mediated through a secure API framework that validates, parses, and governs data exchange at every boundary.',
    color: 'bg-orange-50 border-orange-100',
    iconColor: 'text-orange-600',
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  },
];
---

<Layout metadata={metadata}>

  <Fragment slot="announcement" />

  <Fragment slot="header">
    <Header
      {...headerData}
      theme="white"
      actions={[
        { variant: 'secondary', text: 'Login',        href: '#' },
        { variant: 'primary',   text: 'Get in Touch', href: '/contact' },
      ]}
      isSticky
    />
  </Fragment>

  <!-- ── Page hero ─────────────────────────────────────────── -->
  <section class="bg-gray-50 border-b border-gray-200 not-prose">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-14 md:py-20">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-gray-200 bg-white shadow-sm mb-5">
        <span class="w-2 h-2 rounded-full bg-indigo-500 shrink-0"></span>
        <span class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Security</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 tracking-tight leading-tight mb-4">
        Data Protection
      </h1>
      <p class="text-xl text-gray-600 font-medium mb-3">Your data, our responsibility.</p>
      <p class="text-gray-500 text-base">Last updated: <time datetime="2023-08-27">{lastUpdated}</time></p>
    </div>
  </section>

  <!-- ── Body ──────────────────────────────────────────────── -->
  <section class="not-prose bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-14 md:py-20">

      <!-- Intro -->
      <div class="mb-12 p-6 md:p-8 rounded-2xl bg-indigo-50 border border-indigo-100">
        <p class="text-gray-700 text-base leading-relaxed">
          At UpBuff, securing and protecting your data is a prime responsibility — not an afterthought.
          Every layer of our product architecture, every deployment decision, and every access control
          exists to ensure your data remains yours: private, secure, and under your control at all times.
          The following describes the security practices, controls, and standards we maintain across
          the UpBuff platform.
        </p>
      </div>

      <!-- Product Architecture -->
      <div class="mb-12">
        <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Architecture</h2>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Five-layer security protection</h3>
        <p class="text-gray-500 text-base leading-relaxed mb-8">
          UpBuff products are built on a five-layer security model. Each layer addresses a distinct
          attack surface — from encrypted transit at the network edge to governed API boundaries
          at the integration layer. No single layer is sufficient on its own; all five work together
          to provide defence in depth.
        </p>

        <div class="space-y-4">
          {layers.map((layer) => (
            <div class={`flex gap-5 p-5 rounded-2xl border ${layer.color}`}>
              <div class="shrink-0">
                <div class="w-10 h-10 rounded-xl bg-white shadow-sm flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class={`w-5 h-5 ${layer.iconColor}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={layer.icon} />
                </div>
              </div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs font-bold font-mono text-gray-400">{layer.number}</span>
                  <h4 class="font-bold text-gray-900 text-sm">{layer.title}</h4>
                </div>
                <p class="text-sm text-gray-500 leading-relaxed">{layer.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Cloud data model -->
      <div class="mb-12 p-6 md:p-8 rounded-2xl border border-gray-200 bg-gray-50">
        <h4 class="font-bold text-gray-900 mb-3">Customer data isolation</h4>
        <p class="text-gray-500 text-base leading-relaxed">
          UpBuff adheres to a cloud data model in which each customer has their own dedicated
          database — ensuring that data retrieved at any point belongs exclusively to that customer.
          Individual customers can access only their own data. All data is secured, controlled,
          and maintained with access logging for subsequent audit by the UpBuff team.
        </p>
      </div>

      <hr class="border-gray-100 mb-12" />

      <!-- Three security columns -->
      <div class="mb-12">
        <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Controls</h2>
        <h3 class="text-2xl font-bold text-gray-900 mb-8">Security controls in practice</h3>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {[
            {
              title: 'Product security',
              body: 'UpBuff cloud platforms are maintained across multiple regions on AWS, Microsoft Azure, and DigitalOcean. Our integrated architectural approach ensures compliance from engineering to deployment, with cloud security built into every stage of the delivery pipeline.',
              icon: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>',
            },
            {
              title: 'Data security',
              body: 'All customer data is encrypted in transit over SSL-secured connections for every individual account. Access to production servers is restricted to authorised UpBuff resources only, enforced through multi-factor authentication at every entry point.',
              icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>',
            },
            {
              title: 'Network security',
              body: 'The UpBuff network is monitored by industry-grade firewalls. Production and testing environments are hosted on SSL-certified servers across AWS, DigitalOcean, and Azure. Remote access to production servers is restricted exclusively to secured office networks.',
              icon: '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>',
            },
          ].map((item) => (
            <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
              <div class="w-9 h-9 rounded-lg bg-indigo-50 flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 text-indigo-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={item.icon} />
              </div>
              <h4 class="font-bold text-gray-900 text-sm mb-2">{item.title}</h4>
              <p class="text-sm text-gray-500 leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>

      <hr class="border-gray-100 mb-12" />

      <!-- Change control -->
      <div class="mb-12">
        <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Change Management</h2>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Changes, merging and release requests</h3>
        <p class="text-gray-500 text-base leading-relaxed mb-4">
          Our internal change control process diligently tracks all application, infrastructure, and
          content modifications. UpBuff conducts routine deployment reviews on a quarterly basis,
          with oversight and direction provided by senior management.
        </p>
        <p class="text-gray-500 text-base leading-relaxed">
          Access to development environments is strictly governed and limited solely to the authorised
          UpBuff team. This bars any access from the customer side, ensuring an environment that
          effectively prevents potential malfunctions and maintains the integrity of production systems.
        </p>
      </div>

      <hr class="border-gray-100 mb-12" />

      <!-- Data deletion -->
      <div class="mb-12">
        <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Data Lifecycle</h2>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Data deletion</h3>
        <div class="flex gap-5 p-6 rounded-2xl bg-green-50 border border-green-100">
          <div class="w-10 h-10 rounded-xl bg-white shadow-sm flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-gray-900 text-sm mb-1">15-day guaranteed deletion</h4>
            <p class="text-sm text-gray-600 leading-relaxed">
              If you withdraw from our service or terminate your account, we will transfer all your
              data to you and permanently delete all data from UpBuff servers within <strong>15 days</strong>
              of account closure. No residual data is retained beyond this window unless required
              by applicable law.
            </p>
          </div>
        </div>
      </div>

      <hr class="border-gray-100 mb-12" />

      <!-- Reporting and disclosure -->
      <div class="mb-12">
        <h2 class="text-sm font-bold uppercase tracking-widest text-indigo-500 mb-2">Responsible Disclosure</h2>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Responding to issues and threats</h3>
        <p class="text-gray-500 text-base leading-relaxed mb-5">
          If you discover any issues or potential threats to the security or privacy of UpBuff,
          please reach out to us promptly at:
        </p>
        <div class="flex items-center gap-3 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href="mailto:security@upbuff.com" class="text-indigo-600 hover:underline text-base font-semibold">security@upbuff.com</a>
        </div>
        <p class="text-gray-500 text-base leading-relaxed mb-4">
          Your cooperation is vital in addressing security concerns promptly and effectively.
          We kindly request that you refrain from disclosing any unresolved vulnerabilities in
          public domains to maintain the confidentiality and integrity of our security efforts.
        </p>
        <p class="text-gray-500 text-base leading-relaxed">
          We greatly value your assistance in identifying and rectifying vulnerabilities within
          UpBuff products. Your efforts do not go unnoticed — we will formally recognise your
          contribution as soon as the issue has been successfully mitigated.
        </p>
      </div>

      <hr class="border-gray-100 mb-12" />

      <!-- Non-disclosure and fine print -->
      <div class="space-y-6 mb-12">

        <div class="p-5 rounded-xl bg-red-50 border border-red-100 flex gap-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-500 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <div>
            <h4 class="font-bold text-gray-900 text-sm mb-1">Public Non-Disclosure Policy</h4>
            <p class="text-sm text-gray-600 leading-relaxed">This programme does not allow public disclosure. Any individual who posts or publicly releases a vulnerability discovered through this programme shall be liable for legal penalties under applicable law.</p>
          </div>
        </div>

        <div class="p-5 rounded-xl bg-gray-50 border border-gray-100">
          <h4 class="font-bold text-gray-900 text-sm mb-2">The fine print</h4>
          <ul class="space-y-2">
            {[
              'UpBuff may modify the terms of or terminate this programme at any time.',
              'We will not apply any changes to these programme terms retroactively.',
              'UpBuff employees and their immediate family members are not eligible for any bounties or recognition rewards under this programme.',
            ].map((item) => (
              <li class="flex items-start gap-2.5">
                <span class="w-1.5 h-1.5 rounded-full bg-gray-400 shrink-0 mt-2"></span>
                <span class="text-sm text-gray-500 leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Contact card -->
      <div class="rounded-2xl bg-gray-50 border border-gray-200 p-6 md:p-8">
        <h3 class="text-xl font-bold text-gray-900 mb-4">Contact us</h3>
        <p class="text-gray-500 text-base leading-relaxed mb-5">
          For security-related enquiries or to report a vulnerability, contact our security team:
        </p>
        <div class="flex flex-col gap-3">
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-500 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span class="text-gray-700 text-base">
              UpBuff Technologies Pvt. Ltd., 5th Floor, CDAC, Technopark,
              Thiruvananthapuram, Kerala, India &ndash; 695582
            </span>
          </div>
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:security@upbuff.com" class="text-indigo-600 hover:underline text-base font-medium">security@upbuff.com</a>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>