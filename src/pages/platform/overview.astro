---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import LogoBar from '~/components/widgets/LogoBar.astro';
import Stats from '~/components/widgets/Stats.astro';
import FeaturesHighlights from '~/components/widgets/FeaturesHighlights.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';
import FaqAccordion from '~/components/widgets/FaqAccordion.astro';

import { headerData } from '~/navigation';

const metadata = {
  title: 'About UpBuff | Clean Core ERP Execution & Generative AI Platform',
  description:
    'UpBuff was built on one conviction: enterprise ERP should never need to be modified to support execution. Learn our story, mission, and the principles behind every product decision.',
  canonical: 'https://www.upbuff.com/platform/overview/',
  robots: { index: true, follow: true },
  openGraph: {
    type: 'website',
    url: 'https://www.upbuff.com/about/',
    title: 'About UpBuff | ERP Execution Platform',
    description: 'UpBuff extends SAP, Oracle, and Epicor without touching the core. Learn the story behind the platform.',
    image: 'https://www.upbuff.com/images/upbuff-platform.png',
  },
  twitter: {
    cardType: 'summary_large_image',
    title: 'About UpBuff | Clean Core ERP Execution',
    description: 'The story, mission, and principles behind UpBuff — the ERP Execution Platform built to keep your ERP core clean.',
  },
};

const leaders = [
  {
    name: 'Shiburaj Krishnapillai',
    role: 'Founder & CEO',
    img: '/uploads/common-male.svg',
    linkedin: 'https://www.linkedin.com/in/shiburaj-krishnapillai',
    bio: 'Founded UpBuff in 2017 with a clear conviction — ERP execution should never require core modification. Leads product vision, customer strategy, and the architectural principles that every UpBuff deployment is built on.',
  },
  {
    name: 'To be updated',
    role: 'Chief Technology Officer',
    img: '/uploads/common-male.svg',
    linkedin: '#',
    bio: 'Leads the engineering and platform architecture teams. Responsible for the API-first integration framework, Clean Core compliance, and the technical roadmap across all ERP platforms.',
  },
  {
    name: 'To be updated',
    role: 'Chief Marketing Officer',
    img: '/uploads/common-female.svg',
    linkedin: '#',
    bio: 'Drives UpBuff go-to-market strategy, brand, and demand generation across enterprise ERP markets. Focused on communicating the Clean Core advantage to CIOs, IT heads, and operations leaders.',
  },
];

const linkedinSvg = '<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>';

const leaderItems = leaders.map((p) => {
  const roleTag = '<span class="block text-xs font-semibold uppercase tracking-widest text-indigo-500 mb-2">' + p.role + '</span>';
  const bioTag  = '<p class="text-sm text-muted leading-relaxed mb-3">' + p.bio + '</p>';
  const linkTag = '<a href="' + p.linkedin + '" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#0A66C2] hover:underline">' + linkedinSvg + 'LinkedIn</a>';
  const imgTag  = '<img src="' + p.img + '" alt="' + p.name + '" class="w-full h-full object-cover object-top" loading="lazy" />';
  return {
    title:       p.name,
    description: roleTag + bioTag + linkTag,
    image:       imgTag,
    classes:     { image: '!p-0 !bg-gray-100' },
  };
});
---

<Layout metadata={metadata}>

  <Fragment slot="head">
    <meta name="author" content="UpBuff Technologies" />
    <meta property="og:site_name" content="UpBuff Technologies" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "UpBuff Technologies",
      "url": "https://www.upbuff.com",
      "logo": "https://www.upbuff.com/logo.png",
      "description": "UpBuff is a Clean Core ERP Execution Platform extending SAP, Oracle, and Epicor without modifying ERP core.",
      "sameAs": ["https://www.linkedin.com/company/upbuff"]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is a Clean Core ERP strategy?", "acceptedAnswer": { "@type": "Answer", "text": "A Clean Core ERP strategy avoids modifying ERP core logic and instead extends functionality through APIs and integration layers — keeping ERP stable, auditable, and upgrade-safe." } },
        { "@type": "Question", "name": "Does UpBuff only support SAP Business One?", "acceptedAnswer": { "@type": "Answer", "text": "While we have deep expertise in SAP Business One, UpBuff integrates with SAP S/4HANA, SAP ECC, Oracle ERP, and Epicor Kinetic via official APIs." } }
      ]
    })} />
  </Fragment>

  <Fragment slot="announcement" />

  <!-- ══════════════════════════════════════════════════════════
       1. HERO — dark, centered story headline + team photo
       ══════════════════════════════════════════════════════════ -->
  <section class="relative not-prose md:-mt-[76px] bg-[#0a0a0a] text-white overflow-hidden">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] pointer-events-none"
      aria-hidden="true"
      style="background:radial-gradient(ellipse at 50% 0%,rgba(99,102,241,0.13) 0%,transparent 70%);"
    />
    <div class="absolute inset-0 pointer-events-none noise-overlay opacity-30" aria-hidden="true" />

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <div class="pt-0 md:pt-[76px] pointer-events-none" />

      <div class="py-20 md:py-28">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tight tracking-tight font-heading mb-8">
          Our story
        </h1>

        <p class="text-lg md:text-xl text-white/75 leading-relaxed max-w-3xl mx-auto mb-5">
          In 2017, a founder and a handful of technology passionates set out to solve a problem
          that every enterprise running SAP already lived with — the gap between what ERP recorded
          and what operations teams could actually execute in the field.
        </p>
        <p class="text-base md:text-lg text-white/50 leading-relaxed max-w-2xl mx-auto mb-16">
          What started as a single service management solution has grown into an ERP Execution Platform
          trusted by operations teams across five industries — all without ever modifying an ERP core.
        </p>

        <!-- Team hero image -->
        <div class="rounded-2xl overflow-hidden shadow-2xl border border-white/10">
          <img
            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
            alt="UpBuff team"
            class="w-full h-auto object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       2. TAGLINE STATEMENT
       ══════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20 not-prose">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 leading-tight tracking-tight mb-6">
        We listen. We challenge.<br />We work collaboratively.<br />We make things.
      </h2>
      <p class="text-base md:text-lg text-gray-500 leading-relaxed max-w-2xl mx-auto">
        UpBuff makes it fast and smooth for businesses to satisfy their users, customers, employees,
        and mentors. We adopted a fresh approach to building and delivering software-as-a-service
        that&rsquo;s affordable, quick to implement, and designed for the end-user.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       3. STORY NARRATIVE — alternating two-column sections
       ══════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-24 not-prose">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 space-y-24 md:space-y-32">

      <!-- Row 1 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-indigo-500 mb-4">Where It All Began</p>
          <p class="text-gray-900 text-base md:text-lg leading-relaxed mb-5">
            In 2017, under the leadership of our founder Mr. Shiburaj Krishnapillai,
            a small team of deeply committed technologists launched a service management solution
            that created a groundbreaking impact for their first client.
          </p>
          <p class="text-gray-500 text-base leading-relaxed">
            What started as a focused field service tool was gradually revamped — expanded with updated
            architecture, new modules, and deeper ERP integrations — delivering better customer
            experiences with every iteration and laying the foundation for what UpBuff would become.
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img
            src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80"
            alt="UpBuff engineering team at work"
            class="w-full h-72 object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Row 2 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="rounded-2xl overflow-hidden shadow-lg order-last md:order-first">
          <img
            src="https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80"
            alt="Building the UpBuff platform"
            class="w-full h-72 object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-indigo-500 mb-4">Building the Faith</p>
          <p class="text-gray-900 text-base md:text-lg leading-relaxed mb-5">
            We adopted one formula for earning trust — and only one: build relationships that last.
            Over half a decade, that approach scaled our products, our team, and our reputation
            across some of the world&rsquo;s most critical businesses, governments, and organisations.
          </p>
          <p class="text-gray-500 text-base leading-relaxed">
            Trust is a valuable commodity. Relationships are gold. Those two beliefs have never
            changed from the first deployment in 2017 to every enterprise we run today —
            and they never will.
          </p>
        </div>
      </div>

      <!-- Row 3 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-indigo-500 mb-4">What It Looks Like in Practice</p>
          <p class="text-gray-900 text-base md:text-lg leading-relaxed mb-5">
            Field technicians at a drone manufacturer logging service orders from a jobsite
            in Rajasthan. Warehouse operators at a chemical distributor scanning goods receipts
            that sync to SAP in under a second. Van sales reps capturing orders offline and
            pushing them to ERP the moment connectivity returns.
          </p>
          <p class="text-gray-500 text-base leading-relaxed">
            Every one of those deployments runs on UpBuff. Every one of them runs without a
            single modification to ERP core. And every one of them survived an ERP upgrade
            without a day of re-testing.
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img
            src="https://images.unsplash.com/photo-1565688534245-05d6b5be184a?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80"
            alt="UpBuff in the field"
            class="w-full h-72 object-cover"
            loading="lazy"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       3. CEO QUOTE
       ══════════════════════════════════════════════════════════ -->
  <section class="bg-[#0a0a0a] py-20 md:py-28 not-prose relative overflow-hidden">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] pointer-events-none"
      aria-hidden="true"
      style="background:radial-gradient(ellipse at 50% 0%,rgba(99,102,241,0.1) 0%,transparent 70%);"
    />
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <div class="text-indigo-500 text-8xl font-serif leading-none mb-2 select-none" aria-hidden="true">&ldquo;</div>
      <blockquote>
        <p class="text-xl md:text-2xl lg:text-3xl font-medium text-white leading-snug md:leading-snug mb-10">
          Our team spans ERP architects, mobile engineers, and integration specialists
          across India and beyond — but our commitment has never changed:
          <span class="text-indigo-400">every enterprise deserves execution speed
          without paying for it with ERP instability.</span>
        </p>
        <footer class="flex items-center justify-center gap-4">
          <div class="w-12 h-12 rounded-xl overflow-hidden ring-2 ring-white/20 shrink-0 bg-gray-800">
            <img
              src="/uploads/common-male.svg"
              alt="Shiburaj Krishnapillai"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="text-left">
            <p class="text-white font-semibold text-sm">Shiburaj Krishnapillai</p>
            <p class="text-white/40 text-xs mt-0.5">Founder &amp; CEO, UpBuff</p>
          </div>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       4. VISION & MISSION CARDS
       ══════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20 not-prose">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div class="rounded-2xl border border-gray-200 bg-white p-8 md:p-10 shadow-sm">
          <div class="w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Our Vision</h3>
          <p class="text-gray-500 text-base leading-relaxed">
            A world where &ldquo;we had to customise ERP&rdquo; is never the answer to an operational problem.
            Where every enterprise can extend its ERP capabilities safely — without modification risk,
            without upgrade anxiety, and without trading long-term platform health for short-term speed.
            Clean Core is not a constraint. It is the only sustainable foundation for enterprise technology.
          </p>
        </div>

        <div class="rounded-2xl border border-gray-200 bg-white p-8 md:p-10 shadow-sm">
          <div class="w-10 h-10 rounded-xl bg-purple-50 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Our Mission</h3>
          <p class="text-gray-500 text-base leading-relaxed">
            To build the ERP Execution Platform that eliminates the false choice between
            operational agility and ERP stability — by connecting field teams, warehouse operators,
            and sales reps to live ERP data through official APIs, with zero core modifications,
            full audit traceability, and an architecture that stays upgrade-safe for the lifetime
            of your ERP investment.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       5. STATS
       ══════════════════════════════════════════════════════════ -->
  <Stats
    tagline="Platform Scale"
    title="UpBuff at a glance"
    subtitle="Real numbers from production deployments across industries and ERP environments."
    stats={[
      { amount: '5+',    title: 'Active Verticals',       icon: 'tabler:layout-grid' },
      { amount: '5k+',   title: 'Active Devices',         icon: 'tabler:device-mobile' },
      { amount: '4+',    title: 'Platform Integrations',  icon: 'tabler:plug-connected' },
      { amount: '100k+', title: 'Active Users',            icon: 'tabler:users' },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       6. PHOTO STRIP — marquee
       ══════════════════════════════════════════════════════════ -->
  <section class="not-prose overflow-hidden h-64 md:h-72">
    <div class="flex h-full marquee-track">
      {[
        { src: 'https://images.unsplash.com/photo-1556761175-4b46a572b786?w=600&q=80', alt: 'Team collaboration',  w: 'w-80',  h: 'h-full',     mt: 'mt-0' },
        { src: 'https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=600&q=80', alt: 'Workshop session', w: 'w-52',  h: 'h-4/5',      mt: 'mt-auto' },
        { src: 'https://images.unsplash.com/photo-1531482615713-2afd69097998?w=600&q=80', alt: 'Strategy meeting', w: 'w-72',  h: 'h-full',     mt: 'mt-0' },
        { src: 'https://images.unsplash.com/photo-1573497620053-ea5300f94f21?w=600&q=80', alt: 'Engineering team', w: 'w-60',  h: 'h-3/4',      mt: 'mt-4' },
        { src: 'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&q=80', alt: 'Product demo',     w: 'w-96',  h: 'h-full',     mt: 'mt-0' },
        { src: 'https://images.unsplash.com/photo-1556761175-4b46a572b786?w=600&q=80', alt: 'Team collaboration',  w: 'w-56',  h: 'h-4/5',      mt: 'mt-auto' },
        { src: 'https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=600&q=80', alt: 'Workshop session', w: 'w-80',  h: 'h-full',     mt: 'mt-0' },
        { src: 'https://images.unsplash.com/photo-1531482615713-2afd69097998?w=600&q=80', alt: 'Strategy meeting', w: 'w-64',  h: 'h-3/4',      mt: 'mt-2' },
        { src: 'https://images.unsplash.com/photo-1573497620053-ea5300f94f21?w=600&q=80', alt: 'Engineering team', w: 'w-72',  h: 'h-full',     mt: 'mt-0' },
        { src: 'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&q=80', alt: 'Product demo',     w: 'w-48',  h: 'h-4/5',      mt: 'mt-4' },
      ].map((photo) => (
        <div class={`shrink-0 ${photo.w} ${photo.h} ${photo.mt} overflow-hidden rounded-lg`}>
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </section>

  <style>
    .marquee-track {
      gap: 6px;
      align-items: flex-end;
      animation: marquee-scroll 35s linear infinite;
      width: max-content;
    }
    .marquee-track:hover {
      animation-play-state: paused;
    }
    @keyframes marquee-scroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>

  <!-- ══════════════════════════════════════════════════════════
       7. LEADERSHIP
       ══════════════════════════════════════════════════════════ -->
  <FeaturesHighlights
    tagline="Leadership"
    title="The team behind the platform"
    subtitle="The people who set the direction, make the calls, and stay accountable to every customer deployment."
    items={leaderItems}
  />

  <!-- ══════════════════════════════════════════════════════════
       8. LOGO BAR
       ══════════════════════════════════════════════════════════ -->
  <LogoBar
    label="Operations teams running on UpBuff today"
    logos={[
      { src: '/uploads/ideaForge-logo.svg',         alt: 'ideaForge Technology' },
      { src: '/uploads/jnk-chemdist-logo.svg',       alt: 'JNK Chemdist' },
      { src: '/uploads/molygraph-logo.svg',          alt: 'Molygraph' },
      { src: '/uploads/ncc-streetscape-logo.svg',    alt: 'NCC Streetscape' },
      { src: '/uploads/roofsol-logo.svg',            alt: 'Roofsol' },
      { src: '/uploads/the-wine-source-logo.svg',    alt: 'The Wine Source' },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       8. JOIN OUR TEAM
       ══════════════════════════════════════════════════════════ -->
  <section class="bg-white py-10 not-prose">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="rounded-2xl bg-[#0a0a0a] px-8 py-10 md:px-12 md:py-14 flex flex-col md:flex-row md:items-center justify-between gap-6 relative overflow-hidden">
        <div
          class="absolute -left-20 top-1/2 -translate-y-1/2 w-72 h-72 rounded-full pointer-events-none blur-3xl opacity-40"
          style="background:radial-gradient(circle,#a855f7,transparent 70%);"
          aria-hidden="true"
        />
        <div
          class="absolute -right-20 top-1/2 -translate-y-1/2 w-72 h-72 rounded-full pointer-events-none blur-3xl opacity-30"
          style="background:radial-gradient(circle,#6366f1,transparent 70%);"
          aria-hidden="true"
        />
        <div class="relative z-10">
          <p class="text-white text-xl md:text-2xl font-bold mb-2">Join our team</p>
          <p class="text-white/60 text-sm md:text-base max-w-lg">
            We are a small team solving a large problem. If you understand enterprise ERP, care deeply about
            clean software architecture, and want to build tools that real operations teams use every day —
            we want to hear from you.
          </p>
        </div>
        <a
          href="/careers"
          class="relative z-10 shrink-0 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-white text-gray-900 text-sm font-semibold hover:bg-gray-100 transition-colors"
        >
          See open roles
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       9. ENGINEERING CULTURE
       ══════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-24 not-prose">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">Our Engineering Culture</h2>
      <p class="text-gray-400 text-center text-base md:text-lg max-w-2xl mx-auto mb-14">
        Six commitments that govern how we build, ship, and stand behind the UpBuff platform.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
        {[
          {
            number: '01',
            title: 'Clean Core is non-negotiable',
            body: 'No feature ships if it requires a core ERP modification to work. That constraint is not a limitation — it is the reason our customers can upgrade their ERP without fear.',
          },
          {
            number: '02',
            title: 'Build fast. Break nothing.',
