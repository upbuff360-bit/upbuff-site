---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import HeroPanels from '~/components/widgets/HeroPanels.astro';

import LogoBar from '~/components/widgets/LogoBar.astro';
import SecuritySplit from '~/components/widgets/SecuritySplit.astro';
import FeaturesGrid from '~/components/widgets/FeaturesGrid.astro';
import ContentSplitCard from '~/components/widgets/ContentSplitCard.astro';
import FeaturesCarousel from '~/components/widgets/FeaturesCarousel.astro';
import FeaturesHighlights from '~/components/widgets/FeaturesHighlights.astro';
import FeaturesBento from '~/components/widgets/FeaturesBento.astro';
import FeaturesEnterprise from '~/components/widgets/FeaturesEnterprise.astro';
import TestimonialsGrid from '~/components/widgets/TestimonialsGrid.astro';
import FaqAccordion from '~/components/widgets/FaqAccordion.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';

import { headerData } from '~/navigation';

const metadata = {
  title: 'Security & Compliance | UpBuff ERP Execution Platform',
  description:
    'Enterprise-grade encryption, role-based access control, audit traceability, and Clean Core ERP security built into every layer of the UpBuff platform.',
  canonical: 'https://www.upbuff.com/platform/security-compliance/',
  robots: { index: true, follow: true },
  openGraph: {
    type: 'website',
    url: 'https://www.upbuff.com/security-compliance/',
    title: 'Security & Compliance | UpBuff ERP Execution Platform',
    description: 'Enterprise-grade security for SAP and enterprise ERP execution environments — encryption, RBAC, audit logs, and data boundary enforcement built in.',
    image: 'https://www.upbuff.com/images/security-compliance.png',
  },
  twitter: {
    cardType: 'summary_large_image',
    title: 'Security & Compliance | UpBuff',
    description: 'Enterprise-grade security for SAP, Oracle, and Epicor ERP execution environments.',
  },
};
---

<Layout metadata={metadata} headerTheme="white">
  <Fragment slot="head">
    <meta name="author" content="UpBuff Technologies" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Does UpBuff store ERP data externally?", "acceptedAnswer": { "@type": "Answer", "text": "No. UpBuff never stores ERP master data externally. All ERP data is accessed via scoped API calls and never duplicated outside your ERP boundary." } },
        { "@type": "Question", "name": "How does UpBuff handle data encryption?", "acceptedAnswer": { "@type": "Answer", "text": "All data in transit is encrypted using TLS 1.3. API credentials and secrets are managed with industry-standard secret management and never exposed in application code or logs." } },
        { "@type": "Question", "name": "How does UpBuff enforce access control?", "acceptedAnswer": { "@type": "Answer", "text": "UpBuff uses role-based access control mapped directly to ERP user roles. Every user permission is governed by ERP authorization logic — no permission exists outside ERP governance." } },
        { "@type": "Question", "name": "Can UpBuff be deployed on-premise?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. UpBuff supports full on-premise deployment within your own infrastructure. No data leaves your network perimeter." } }
      ]
    })} />
  </Fragment>

  <Fragment slot="announcement" />

  <!-- ══════════════════════════════════════════════════════════
       1. HERO — HeroPanels white theme
       ══════════════════════════════════════════════════════════ -->
  <HeroPanels
    theme="white"
    tagline="Security & Compliance"
    title="Security is architecture, not a feature added on top."
    subtitle="UpBuff is designed for enterprise security, compliance, and data governance at scale. Every security control is built into the platform architecture, not bolted on after deployment. Because ERP data deserves enterprise-grade protection at every layer, every API call, and every transaction."
    actions={[
      { variant: 'primary',   text: 'Request Security Review',    href: '/contact' },
      { variant: 'secondary', text: 'Download Security Overview', href: '/docs/security-overview.pdf' },
    ]}
    panels={[
      {
        accent: 'linear-gradient(160deg, #0f172a 0%, #1e3a5f 100%)',
        html: `
          <div style="padding: 32px 28px; display: flex; flex-direction: column; gap: 14px; height: 100%;">
            <div style="display:flex; align-items:center; gap:10px;">
              <div style="width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.12);display:flex;align-items:center;justify-content:center;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
              </div>
              <span style="font-size:15px;font-weight:600;color:rgba(255,255,255,0.9);">Security Posture — Live Status</span>
            </div>
            <div style="display:flex;flex-direction:column;gap:10px;flex:1;justify-content:center;">
              <div style="background:rgba(255,255,255,0.08);border:0.5px solid rgba(255,255,255,0.12);border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:10px;">
                <div style="width:8px;height:8px;border-radius:50%;background:#4ade80;flex-shrink:0;box-shadow:0 0 6px #4ade80;"></div>
                <span style="font-size:14.5px;color:rgba(255,255,255,0.85);font-weight:500;">TLS 1.3 — All connections encrypted</span>
              </div>
              <div style="background:rgba(255,255,255,0.08);border:0.5px solid rgba(255,255,255,0.12);border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:10px;">
                <div style="width:8px;height:8px;border-radius:50%;background:#4ade80;flex-shrink:0;box-shadow:0 0 6px #4ade80;"></div>
                <span style="font-size:14.5px;color:rgba(255,255,255,0.85);font-weight:500;">Role-Based Access — ERP governed</span>
              </div>
              <div style="background:rgba(255,255,255,0.08);border:0.5px solid rgba(255,255,255,0.12);border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:10px;">
                <div style="width:8px;height:8px;border-radius:50%;background:#4ade80;flex-shrink:0;box-shadow:0 0 6px #4ade80;"></div>
                <span style="font-size:14.5px;color:rgba(255,255,255,0.85);font-weight:500;">Audit Logs — Tamper-evident</span>
              </div>
              <div style="background:rgba(255,255,255,0.08);border:0.5px solid rgba(255,255,255,0.12);border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:10px;">
                <div style="width:8px;height:8px;border-radius:50%;background:#4ade80;flex-shrink:0;box-shadow:0 0 6px #4ade80;"></div>
                <span style="font-size:14.5px;color:rgba(255,255,255,0.85);font-weight:500;">Zero ERP data stored externally</span>
              </div>
            </div>
          </div>
        `,
      },
      {
        html: `
          <div style="padding: 22px 20px; background:#f8fafc; height:100%; border:0.5px solid rgba(0,0,0,0.07);">
            <p style="font-size:15px;font-weight:600;color:#09090b;margin-bottom:14px;">Security Controls</p>
            ${[
              ['End-to-End TLS Encryption',    'Transport layer · TLS 1.3'],
              ['Role-Based Access Control',     'Mapped to ERP user roles'],
              ['Secret & Credential Vault',     'Auto-rotation · No plaintext'],
              ['Transaction Audit Logs',        'Tamper-evident · Exportable'],
              ['ERP Data Boundary Enforcement', 'API-only · No external store'],
            ].map(([name, meta]) => `
              <div style="display:flex;align-items:center;gap:10px;padding:10px 0;border-top:0.5px solid rgba(0,0,0,0.06);">
                <div style="width:30px;height:30px;border-radius:7px;background:rgba(0,0,0,0.04);flex-shrink:0;display:flex;align-items:center;justify-content:center;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(0,0,0,0.4)" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div style="flex:1;">
                  <div style="font-size:14px;font-weight:500;color:#09090b;">${name}</div>
                  <div style="font-size:15px;color:rgba(0,0,0,0.4);">${meta}</div>
                </div>
                <div style="width:16px;height:16px;border-radius:50%;background:rgba(74,222,128,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M1.5 4l2 2 3-3" stroke="#16a34a" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              </div>
            `).join('')}
          </div>
        `,
      },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       2. LOGO BAR
       ══════════════════════════════════════════════════════════ -->
  <LogoBar
    label="Enterprise-Grade Security for SAP and Enterprise ERP Environments"
    logos={[
      { src: '/uploads/logo/sap-s4-hanna-integration-with-upbuff-crm.png', alt: 'SAP S/4HANA' },
      { src: '/uploads/logo/sap-integration-with-upbuff-crm.png',          alt: 'SAP Business One' },
      { src: '/uploads/logo/oracle-integration-with-upbuff-crm.png',       alt: 'Oracle ERP' },
      { src: '/uploads/logo/epicore-integration-with-upbuff-crm.png',      alt: 'Epicor ERP' },
      { src: '/uploads/logo/zoho-integration-with-upbuff-crm.png',         alt: 'Zoho' },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       3. SECURITY PHILOSOPHY — ContentSplitCard
       ══════════════════════════════════════════════════════════ -->
  <ContentSplitCard
    tagline="Security Philosophy"
    title="Built secure from the ground up — not secured after the fact"
    cardTitle="Every design decision starts with security"
    cardDescription="Most platforms add security features after the product is built. UpBuff is different — security is the foundation on which every feature is designed. From the first API call to the final ERP posting, every action is encrypted, authenticated, authorized, and logged. There are no exceptions."
    cardImage="/uploads/upbuff-ERP-CRM-integrations-for-WhatsApp-Tally-Shopify-SAP.png"
    cardGradient="linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #1d4ed8 100%)"
    testimonial={{
      quote: 'UpBuff was the only ERP extension platform that could satisfy our enterprise security review. API-first, fully auditable, and role-controlled — it passed every checkpoint our InfoSec team set.',
      name: 'CEO',
      company: 'Spartan Engineering Industries Pvt. Ltd',
      avatar: '/uploads/spartan-client.png',
    }}
    features={[
      {
        icon: 'tabler:lock',
        title: 'TLS 1.3 encryption in transit',
        description: 'All data moving between UpBuff, ERP systems, and mobile clients is encrypted with TLS 1.3.',
      },
      {
        icon: 'tabler:shield-check',
        title: 'API-only ERP integration',
        description: 'No direct database writes. All ERP integration flows through official APIs — SAP Service Layer, OData, BAPI. Upgrade-safe and audit-clean.',
      },
      {
        icon: 'tabler:clipboard-check',
        title: 'Full transaction audit trail',
        description: 'Every action is logged with timestamp, user ID, and transaction reference — nothing is anonymous.',
      },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       4. CORE SECURITY CAPABILITIES — FeaturesGrid 2×3
       ══════════════════════════════════════════════════════════ -->
  <FeaturesGrid
    tagline="Core Security"
    title="Six foundational security capabilities"
    subtitle="Every capability listed here is built into the platform architecture — not available as an optional add-on or enterprise-tier upgrade."
    items={[
      {
        icon: 'tabler:lock',
        title: 'End-to-End TLS Encryption',
        description: 'All data in transit between UpBuff, ERP systems, mobile clients, and third-party integrations uses TLS 1.3 — the current industry gold standard for transport encryption.',
      },
      {
        icon: 'tabler:key',
        title: 'Secret & Credential Management',
        description: 'API keys, ERP service credentials, and integration secrets are stored using vault-based secret management — never in application code, config files, or logs.',
      },
      {
        icon: 'tabler:users',
        title: 'Role-Based Access Control',
        description: 'Granular RBAC mapped directly to ERP user roles and organizational structures. Field reps see only their territory. Warehouse operators access only their warehouse. No permission exists outside ERP governance.',
      },
      {
        icon: 'tabler:clipboard-list',
        title: 'Full Transaction Audit Logs',
        description: 'Every user action, API call, data access, and ERP transaction is logged with timestamp, user identifier, session context, and transaction reference — providing complete audit traceability.',
      },
      {
        icon: 'tabler:git-merge',
        title: 'Multi-Level Approval Workflows',
        description: 'Configurable approval chains for credit, pricing, discounts, and order authorization — integrated with ERP business logic to ensure no transaction bypasses governance controls.',
      },
      {
        icon: 'tabler:database-export',
        title: 'ERP Data Boundary Enforcement',
        description: 'UpBuff never stores ERP master data externally. All data is accessed via scoped API calls and never duplicated outside your ERP boundary — preserving data sovereignty and governance.',
      },
    ]}
  />

  <!-- ══════════════════════════════════════════════════════════
       5. THREE SECURITY LAYERS — FeaturesHighlights
       ══════════════════════════════════════════════════════════ -->
  <FeaturesHighlights
    tagline="Security Layers"
    title="Three layers of enterprise security"
    subtitle="UpBuff security is structured in three independent layers — each protecting a different surface area of the ERP integration. A vulnerability at one layer is isolated and cannot cascade to the others."
    items={[
      {
        title: 'Layer 1 — API & Transport Security',
        description: 'All communication between UpBuff and ERP systems flows through official API endpoints — SAP Service Layer, OData, BAPI, REST. TLS 1.3 encryption on every request. No direct database access. No custom transport protocols. Certificate pinning on mobile clients prevents man-in-the-middle attacks.',
        image: '<style>.l1{width:100%;height:100%;background:#f8fafc;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:18px 14px;gap:14px;box-sizing:border-box}.l1-row{display:flex;align-items:center;width:100%}.l1-node{display:flex;flex-direction:column;align-items:center;gap:4px;min-width:54px}.l1-ni{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center}.l1-nl{font-size:14px;font-weight:600;color:#1e293b;text-align:center}.l1-ns{font-size:14px;color:#94a3b8}.l1-ch{flex:1;position:relative;height:36px;display:flex;align-items:center;margin:0 4px}.l1-track{position:absolute;left:0;right:0;height:1.5px;background:#bfdbfe}.l1-pkt{position:absolute;top:50%;width:7px;height:7px;border-radius:2px;transform:translateY(-50%);animation:l1move 2.4s linear infinite}.l1-p1{background:#3b82f6}.l1-p2{background:#6366f1;animation-delay:.8s}.l1-p3{background:#3b82f6;animation-delay:1.6s}.l1-lock{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);background:#fff;border:1px solid #93c5fd;border-radius:6px;padding:3px 6px;display:flex;align-items:center;gap:3px;z-index:2}.l1-lt{font-size:14px;font-weight:700;color:#1d4ed8}.l1-tags{display:flex;gap:3px;flex-wrap:wrap;justify-content:center}.l1-tag{font-size:10.5px;font-weight:600;padding:2px 5px;border-radius:4px;background:#eff6ff;color:#1e40af}.l1-tg{background:#f0fdf4;color:#15803d}@keyframes l1move{0%{left:-8px;opacity:0}8%{opacity:1}42%{left:calc(50% - 16px);opacity:0}58%{left:calc(50% + 16px);opacity:0}92%{opacity:1}100%{left:calc(100% + 8px);opacity:0}}</style><div class="l1"><div class="l1-row"><div class="l1-node"><div class="l1-ni" style="background:#eff6ff;border:0.5px solid #bfdbfe"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div><span class="l1-nl">UpBuff</span><span class="l1-ns">Client</span></div><div class="l1-ch"><div class="l1-track"></div><div class="l1-pkt l1-p1"></div><div class="l1-pkt l1-p2"></div><div class="l1-pkt l1-p3"></div><div class="l1-lock"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg><span class="l1-lt">TLS 1.3</span></div></div><div class="l1-node"><div class="l1-ni" style="background:#f0fdf4;border:0.5px solid #bbf7d0"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="1.5"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg></div><span class="l1-nl">SAP ERP</span><span class="l1-ns">System</span></div></div><div class="l1-tags"><span class="l1-tag">OData</span><span class="l1-tag">BAPI</span><span class="l1-tag">Service Layer</span><span class="l1-tag l1-tg">No direct DB</span></div></div>',
      },
      {
        title: 'Layer 2 — Identity & Access Control',
        description: 'Every user, every session, and every permission is authenticated and authorized before any ERP data is accessed. RBAC mapped to ERP roles. Multi-factor authentication supported. Session tokens are short-lived, scoped, and automatically rotated. No shared credentials between users or teams.',
        image: '<style>.l2{width:100%;height:100%;background:#f8fafc;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:18px 14px;gap:12px;box-sizing:border-box}.l2-av{width:40px;height:40px;border-radius:50%;background:#eef2ff;border:1.5px solid #c7d2fe;display:flex;align-items:center;justify-content:center;position:relative}.l2-ring{position:absolute;inset:-5px;border-radius:50%;border:1.5px solid #818cf8;animation:l2rp 2.5s ease-in-out infinite}.l2-steps{display:flex;flex-direction:column;gap:6px;width:100%}.l2-step{display:flex;align-items:center;gap:7px;background:#fff;border:0.5px solid #e2e8f0;border-radius:8px;padding:6px 9px}.l2-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}.l2-stxt{font-size:14px;font-weight:500;color:#334155;flex:1}.l2-badge{font-size:14px;font-weight:600;padding:2px 5px;border-radius:4px}.l2-d0{animation:l2d0 4.5s ease-in-out infinite}.l2-d1{animation:l2d1 4.5s ease-in-out infinite}.l2-d2{animation:l2d2 4.5s ease-in-out infinite}.l2-b0{animation:l2b0 4.5s ease-in-out infinite;background:#eef2ff;color:#4f46e5;opacity:0}.l2-b1{animation:l2b1 4.5s ease-in-out infinite;background:#eef2ff;color:#4f46e5;opacity:0}.l2-b2{animation:l2b2 4.5s ease-in-out infinite;background:#f0fdf4;color:#15803d;opacity:0}@keyframes l2rp{0%,100%{transform:scale(1);opacity:.5}50%{transform:scale(1.1);opacity:1}}@keyframes l2d0{0%,10%{background:#e5e7eb;box-shadow:none}15%,35%{background:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.2)}40%,100%{background:#6366f1;box-shadow:none}}@keyframes l2d1{0%,30%{background:#e5e7eb;box-shadow:none}35%,55%{background:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.2)}60%,100%{background:#6366f1;box-shadow:none}}@keyframes l2d2{0%,55%{background:#e5e7eb;box-shadow:none}60%,80%{background:#22c55e;box-shadow:0 0 0 3px rgba(34,197,94,.2)}85%,100%{background:#22c55e;box-shadow:none}}@keyframes l2b0{0%,14%{opacity:0}15%,100%{opacity:1}}@keyframes l2b1{0%,34%{opacity:0}35%,100%{opacity:1}}@keyframes l2b2{0%,59%{opacity:0}60%,100%{opacity:1}}</style><div class="l2"><div class="l2-av"><div class="l2-ring"></div><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div><div class="l2-steps"><div class="l2-step"><div class="l2-dot l2-d0"></div><span class="l2-stxt">Authenticate</span><span class="l2-badge l2-b0">MFA verified</span></div><div class="l2-step"><div class="l2-dot l2-d1"></div><span class="l2-stxt">Check ERP role</span><span class="l2-badge l2-b1">RBAC mapped</span></div><div class="l2-step"><div class="l2-dot l2-d2"></div><span class="l2-stxt">Issue scoped token</span><span class="l2-badge l2-b2">Access granted</span></div></div></div>',
      },
      {
        title: 'Layer 3 — Data & Audit Governance',
        description: 'Every data access, modification, approval, and ERP posting is logged immutably with full context — user, timestamp, action, transaction reference, and outcome. Logs are tamper-evident and exportable for audit teams. Data never leaves ERP boundaries without explicit authorization.',
        image: '<style>.l3{width:100%;height:100%;background:#f8fafc;display:flex;flex-direction:column;padding:14px;gap:8px;box-sizing:border-box}.l3-hd{display:flex;align-items:center;justify-content:space-between}.l3-ht{font-size:14px;font-weight:600;color:#1e293b}.l3-seal{font-size:9.5px;font-weight:700;padding:2px 6px;border-radius:4px;background:#f0fdf4;color:#15803d;border:0.5px solid #bbf7d0}.l3-entries{display:flex;flex-direction:column;gap:5px;flex:1;justify-content:center}.l3-row{display:flex;align-items:center;gap:6px;background:#fff;border:0.5px solid #e2e8f0;border-radius:7px;padding:5px 8px}.l3-ts{font-size:14px;color:#94a3b8;flex-shrink:0;font-family:monospace}.l3-av{width:17px;height:17px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;flex-shrink:0}.l3-act{font-size:15px;color:#334155;flex:1;font-weight:500}.l3-chk{width:14px;height:14px;border-radius:50%;background:#f0fdf4;border:0.5px solid #bbf7d0;display:flex;align-items:center;justify-content:center;flex-shrink:0}.l3-r1{animation:l3in 4.5s ease-in-out infinite}.l3-r2{animation:l3in 4.5s ease-in-out infinite .75s}.l3-r3{animation:l3in 4.5s ease-in-out infinite 1.5s}.l3-pills{display:flex;gap:3px;justify-content:center}.l3-pill{font-size:9.5px;font-weight:600;padding:2px 5px;border-radius:4px;background:#f1f5f9;color:#475569}.l3-pb{background:#eff6ff;color:#1d4ed8}@keyframes l3in{0%,5%{opacity:0;transform:translateY(5px)}18%,78%{opacity:1;transform:translateY(0)}92%,100%{opacity:0;transform:translateY(-3px)}}</style><div class="l3"><div class="l3-hd"><span class="l3-ht">Audit Log</span><span class="l3-seal">IMMUTABLE</span></div><div class="l3-entries"><div class="l3-row l3-r1"><span class="l3-ts">14:22:01</span><div class="l3-av" style="background:#eff6ff;color:#1d4ed8">AK</div><span class="l3-act">Order posted to SAP SD</span><div class="l3-chk"><svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M1.5 4l2 2 3-3" stroke="#16a3