    <!-- ══ 8. FAQPage ═════════════════════════════════════════════════════ -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is an Enterprise Asset Tracking System?", "acceptedAnswer": { "@type": "Answer", "text": "An Enterprise Asset Tracking System (ATS) is software that monitors and manages the complete lifecycle of physical assets — from acquisition and deployment through maintenance, auditing, and disposal. It uses barcode scanning, QR code technology, RFID tagging, and IoT sensors to provide real-time visibility of asset location, status, condition, and usage across every organizational site and department." } },
        { "@type": "Question", "name": "What is the difference between an Asset Tracking System and an EAM system?", "acceptedAnswer": { "@type": "Answer", "text": "An Asset Tracking System (ATS) focuses on real-time physical tracking, identification via barcode/QR/RFID, audit automation, and custody management. Enterprise Asset Management (EAM) is broader, covering maintenance management, reliability engineering, and long-term asset strategy. UpBuff ATS bridges both — combining real-time tracking with IoT-driven maintenance and full lifecycle management in one platform." } },
        { "@type": "Question", "name": "Does UpBuff ATS integrate with SAP?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. UpBuff ATS integrates natively with SAP Business One via Service Layer, SAP S/4HANA via OData and RFC, and SAP ECC via BAPI — enabling real-time asset valuation, depreciation synchronization, and maintenance order generation without any ERP core modification. Oracle ERP and Epicor integrations are also supported via REST and SOAP APIs." } },
        { "@type": "Question", "name": "What asset identification technologies does UpBuff ATS support?", "acceptedAnswer": { "@type": "Answer", "text": "UpBuff ATS supports three asset identification technologies: barcode scanning using handheld scanners or smartphone cameras; QR code scanning for richer data encoding and mobile-friendly verification; and RFID tagging for high-volume, hands-free scanning in warehouses, production floors, and vehicle fleets. All three methods assign a unique persistent identifier to each asset that remains consistent throughout its entire lifecycle." } },
        { "@type": "Question", "name": "How does IoT-enabled preventive maintenance work in UpBuff ATS?", "acceptedAnswer": { "@type": "Answer", "text": "IoT sensors attached to or embedded in critical assets transmit health data — temperature, vibration, runtime hours, power consumption — to the UpBuff ATS platform. When readings approach predefined risk thresholds, the system automatically diagnoses the potential issue, generates a maintenance work order, and sends alerts to the responsible team — preventing breakdowns before they occur and extending asset lifespan." } },
        { "@type": "Question", "name": "Can UpBuff ATS handle asset transfers with multi-step approval workflows?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. UpBuff ATS includes fully configurable multi-step approval workflows for asset movements between locations or custodians. Administrators define the authorization hierarchy, escalation rules, and time limits. Every transfer step is recorded in an immutable audit trail, providing documentation required for internal policy compliance and external regulatory audits." } },
        { "@type": "Question", "name": "How does UpBuff ATS improve asset audit accuracy?", "acceptedAnswer": { "@type": "Answer", "text": "UpBuff ATS replaces manual paper-based audits with intelligent barcode and QR code verification using mobile devices. Auditors follow dynamic checklists tailored to each asset type, scan assets to verify presence and condition, and see real-time audit progress on a live dashboard. Geofenced inventory counts ensure assets are verified within defined physical boundaries — delivering dramatically higher accuracy and a complete digital compliance record." } },
        { "@type": "Question", "name": "What types of physical assets can UpBuff ATS track?", "acceptedAnswer": { "@type": "Answer", "text": "UpBuff ATS tracks any category of physical enterprise asset: manufacturing machinery and production equipment; fleet vehicles such as cars, trucks, and vans; office and IT equipment including computers, printers, and scanners; furniture and fixtures; facility infrastructure including HVAC systems, lighting, and security systems; and utility assets such as power generators and transformers. The platform adapts to any industry vertical and asset classification hierarchy." } },
        { "@type": "Question", "name": "How does asset depreciation tracking work in UpBuff ATS?", "acceptedAnswer": { "@type": "Answer", "text": "UpBuff ATS tracks asset value over time using configurable depreciation methods aligned with accounting standards. Depreciation data is synchronized with connected ERP systems — SAP, Oracle, or Epicor — ensuring finance teams have accurate, real-time fixed asset valuations. Automated depreciation reports support financial reporting, tax planning, and capital replacement strategy without manual reconciliation." } },
        { "@type": "Question", "name": "Is there a mobile app for field and warehouse teams?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The UpBuff ATS mobile app is available on Android and iOS. Teams can scan assets, conduct audits, initiate and approve transfers, raise maintenance requests, view maintenance history, and receive real-time IoT alerts from any location at any time. The app uses role-based access control so each user sees only the assets and actions relevant to their responsibilities." } },
        { "@type": "Question", "name": "What reports and analytics does UpBuff ATS provide?", "acceptedAnswer": { "@type": "Answer", "text": "UpBuff ATS provides 10+ configurable reports and real-time dashboards covering asset utilization and availability rates; depreciation schedules and current valuations; maintenance history and cost per asset; audit completion status and compliance gaps; transfer logs and custodian accountability records; IoT sensor health trends and predictive maintenance insights; and asset procurement and disposal recommendations based on lifecycle data." } },
        { "@type": "Question", "name": "How long does UpBuff ATS implementation take?", "acceptedAnswer": { "@type": "Answer", "text": "A standard UpBuff ATS implementation typically takes 3 to 6 weeks depending on the size of the asset registry, number of sites, ERP integration complexity, and IoT sensor deployment scope. UpBuff's implementation team manages the full process — from asset tagging and ERP connection through mobile app deployment, team training, and go-live — with dedicated integration engineers for SAP and enterprise ERP connectivity." } }
      ]
    })} />

