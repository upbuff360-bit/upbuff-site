---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import HeroOrbital from '~/components/widgets/HeroOrbital.astro';

import LogoBar from '~/components/widgets/LogoBar.astro';
import ProblemSplit from '~/components/widgets/ProblemSplit.astro';
import FeaturesCarousel from '~/components/widgets/FeaturesCarousel.astro';
import ContentSplitCard from '~/components/widgets/ContentSplitCard.astro';
import FeaturesGrid from '~/components/widgets/FeaturesGrid.astro';
import FeaturesBento from '~/components/widgets/FeaturesBento.astro';
import FeaturesHighlights from '~/components/widgets/FeaturesHighlights.astro';
import SecuritySplit from '~/components/widgets/SecuritySplit.astro';
import ToolsMarquee from '~/components/widgets/ToolsMarquee.astro';
import TestimonialsGrid from '~/components/widgets/TestimonialsGrid.astro';
import FaqAccordion from '~/components/widgets/FaqAccordion.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';

import { headerData } from '~/navigation';

const metadata = {
  title: 'ERP Integrated CRM | SAP Business One & S/4HANA CRM Extension | UpBuff',
  description:
    'ERP Integrated CRM by UpBuff extends SAP Business One, SAP S/4HANA, Oracle, and Epicor into real-time sales execution with mobile order capture, pricing sync, and ERP-controlled workflows.',
  canonical: 'https://www.upbuff.com/products/erp-integrated-crm/',
  robots: { index: true, follow: true },
  openGraph: {
    type: 'website',
    url: 'https://www.upbuff.com/erp-integrated-crm/',
    title: 'ERP Integrated CRM for SAP & Enterprise ERP | UpBuff',
    description: 'Extend SAP Business One, S/4HANA, and enterprise ERP into frontline sales with real-time CRM integration.',
    image: 'https://www.upbuff.com/assets/og-erp-crm.jpg',
  },
  twitter: {
    cardType: 'summary_large_image',
    title: 'ERP Integrated CRM for SAP & Enterprise ERP | UpBuff',
    description: 'Real-time CRM integrated with SAP Business One, S/4HANA, Oracle and Epicor ERP systems.',
  },
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <meta name="author" content="UpBuff Technologies" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "UpBuff ERP Integrated CRM",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web, Android, iOS",
      "description": "ERP Integrated CRM that extends SAP Business One, SAP S/4HANA, Oracle, and Epicor into frontline sales execution without modifying ERP core.",
      "url": "https://www.upbuff.com/erp-integrated-crm/",
      "provider": { "@type": "Organization", "name": "UpBuff Technologies", "url": "https://www.upbuff.com" }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is an ERP Integrated CRM?", "acceptedAnswer": { "@type": "Answer", "text": "An ERP Integrated CRM connects directly with SAP Business One or S/4HANA, ensuring real-time data sync without replacing ERP as the system of record." } },
        { "@type": "Question", "name": "Does UpBuff replace SAP CRM?", "acceptedAnswer": { "@type": "Answer", "text": "No. UpBuff extends ERP into frontline sales while keeping SAP as the single source of truth." } },
        { "@type": "Question", "name": "Can field sales teams work offline?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. UpBuff supports full offline order capture with automatic synchronization to ERP once connectivity is restored." } }
      ]
    })} />
  </Fragment>

  <Fragment slot="announcement" />

  <HeroOrbital
    tagline="ERP-Integrated CRM"
    title="Extend Your ERP into Real-Time Sales Execution"
    subtitle="UpBuff ERP Integrated CRM transforms your ERP system into a real-time sales execution platform — integrated seamlessly with SAP Business One, SAP S/4HANA, Oracle, Epicor, and other enterprise ERPs. Empower frontline sales teams to operate faster without modifying ERP core systems."
    image={{
    src: '/uploads/modular-crm-software-for-small-and-mid-sized-businesses.png',
    alt: 'UpBuff ERP CRM dashboard',
  }}
  actions={[
    { text: 'Request Demo', href: '/contact', variant: 'primary' },
    { text: 'Talk to ERP Expert', href: '/contact', variant: 'secondary' },
  ]}
  />

  <LogoBar
    label="Trusted by leading enterprises &amp; SAP partners worldwide"
    logos={[
      { src: '/uploads/ideaForge-logo.svg',          alt: 'ideaForge logo' },
      { src: '/uploads/jnk-chemdist-logo.svg',        alt: 'jnk chemdist logo' },
      { src: '/uploads/molygraph-logo.svg',       alt: 'molygraph logo' },
      { src: '/uploads/ncc-streetscape-logo.svg',       alt: 'ncc streetscape logo' },
      { src: '/uploads/roofsol-logo.svg',         alt: 'roofsol logo' },
      { src: '/uploads/the-wine-source-logo.svg',        alt: 'the wine source logo' },
    ]}
  />

  <ProblemSplit
    tagline="The Problem"
    title="ERP data grows faster than your field team"
    subtitle="Frontline sales teams expect instant, accurate ERP data at every touchpoint. But as order volume scales, response times slip, reps repeat manual lookups, and data inconsistencies creep in — increasing costs, errors, and escalations."
    items={[
      {
        title: 'Manual ERP data entry',
        description: 'Field reps duplicate work between devices and ERP, burning time and introducing costly errors at every order cycle.',
      },
      {
        title: 'Stale pricing & inventory',
        description: 'Sales teams quoting from cached ERP data risk order rejections, margin leakage, and customer dissatisfaction.',
      },
      {
        title: 'No offline capability',
        description: 'Traditional ERP access requires constant connectivity — leaving field reps unable to operate in low-signal areas.',
      },
      {
        title: 'ERP customization risk',
        description: 'Customizing SAP or Oracle for field use jeopardises upgrade paths, compliance, and long-term ERP stability.',
      },
    ]}
  />

  <FeaturesCarousel
    tagline="Use Cases"
    title="How ERP-driven organizations use UpBuff CRM"
    subtitle="Discover how SAP customers and enterprise distribution companies drive execution excellence without touching ERP core."
    items={[
      {
        gradient: '#ffffff',
        title: 'Field Sales Automation for ERP & SAP Enterprises',
        description: 'Companies running SAP Business One or S/4HANA often struggle with delayed order entry and manual ERP updates. UpBuff enables field reps to create orders, collect payments, and update records in real time — synchronized directly with ERP. Reduce manual data entry by up to 40% and accelerate order booking cycles.',
        image: '<div class="w-full h-full overflow-hidden"><img src="/uploads/field-sales-automation-for-ERP-and-SAP.png" class="w-full object-top" alt="Field Sales Automation for SAP" loading="lazy" /></div>',
      },
      {
        gradient: 'linear-gradient(135deg, #0f766e 0%, #065f46 100%)',
        title: 'Distributor & Channel Management Integrated with ERP',
        description: 'Manage distributors and dealers while keeping ERP as the system of record. Every secondary order, stock movement, and collection flows seamlessly back into SAP — with real-time distributor order visibility, accurate inventory sync, improved credit monitoring, and faster order-to-cash cycles.',
        image: '<div class="w-full h-full overflow-hidden"><img src="/uploads/real-time-distributor-order-visibility.png" class="w-full object-top" alt="Distributor Order Visibility" loading="lazy" /></div>',
      },
      {
        gradient: 'linear-gradient(135deg, #7c3aed 0%, #4f46e5 100%)',
        title: 'Sales Performance Visibility Without ERP Complexity',
        description: 'Gain execution-level insights without building heavy ERP reports. Territory-wise performance tracking, geo-tagged visit monitoring, and real-time order dashboards — layered on top of live ERP data for faster management decisions.',
        image: '<div class="w-full h-full overflow-hidden"><img src="/uploads/sales-performance-visibility.png" class="w-full object-top" alt="Sales Performance Visibility" loading="lazy" /></div>',
      },
      {
        gradient: 'linear-gradient(135deg, #003f7c 0%, #0070c0 100%)',
        title: 'SAP-Ready Architecture — ERP Future-Proof',
        description: 'For companies migrating from SAP ECC to S/4HANA or upgrading SAP Business One, UpBuff reduces customization dependency while extending ERP functionality — protecting your upgrade path, minimizing ERP risk, and improving frontline user adoption.',
        image: '<div class="w-full h-full overflow-hidden"><img src="/uploads/SAP-ready-architecture.png" class="w-full object-top" alt="SAP-Ready Architecture" loading="lazy" /></div>',
      },
    ]}
  />

  <ContentSplitCard
    tagline="SAP Business One Integration"
    title="Exclusive SAP Business One integration with UpBuff CRM"
    cardTitle="Native Service Layer integration — the deepest SAP B1 connectivity available"
    cardDescription="UpBuff integrates with SAP Business One through the official SAP Service Layer API — providing real-time access to customer master data, pricing, inventory, credit limits, and order history. No add-ons. No core modifications. Clean Core compliant and upgrade-safe across all SAP Business One deployment models."
    cardImage="/uploads/upbuff-ERP-CRM-integrations-for-WhatsApp-Tally-Shopify-SAP.png"
    cardGradient="linear-gradient(135deg, #003f7c 0%, #0070c0 50%, #1d4ed8 100%)"
    testimonial={{
      quote: 'The workflows are user-friendly, easy to customize, and have been effectively serving our field sales teams for nearly two years without a single ERP incident.',
      name: 'CEO',
      company: 'Spartan Engineering Industries Pvt. Ltd',
      avatar: '/uploads/spartan-client.png',
    }}
    features={[
      {
        icon: 'tabler:database',
        title: 'SAP Service Layer API',
        description: 'Direct integration via official SAP Service Layer — no database writes, no core modifications.',
      },
      {
        icon: 'tabler:shield-check',
        title: 'Clean Core compliant',
        description: 'Upgrade-safe by design — works with SAP Business One on-premise and cloud deployments.',
      },
      {
        icon: 'tabler:refresh',
        title: 'Real-time pricing & inventory',
        description: 'Live SAP pricing rules, tax logic, credit limits, and stock applied at point of order capture.',
      },
    ]}
  />

<FeaturesBento
  tagline="ERP, IoT & Enterprise Integrations"
  title="Seamless ERP, IoT, VoIP & Business Tool Integrations"
  subtitle="UpBuff integrates SAP, Oracle, Epicor, IoT devices, VoIP systems, and enterprise applications — enabling real-time data synchronization across operations, sales, and service workflows."
  items={[
    {
      wide: true,
      title: 'SAP Business One & SAP S/4HANA ERP Integration',
      description: 'UpBuff provides enterprise-grade SAP integration for SAP Business One (SAP B1) and SAP S/4HANA using Service Layer, OData, and RFC APIs. Enable real-time synchronization of inventory, pricing, financials, and order management while maintaining Clean Core architecture and upgrade-safe SAP ERP operations.',
      image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-100 p-6"><div class="grid grid-cols-2 gap-4"><div class="flex flex-col items-center gap-2"><div class="w-20 h-16 rounded-2xl bg-white flex items-center justify-center shadow-lg border border-gray-100 p-2"><span class="text-sm font-bold text-cyan-600"><img src="/uploads/logo/sap-s4-hanna-integration-with-upbuff-crm.png"></span></div><span class="text-xs text-gray-500">SAP BusinessOne</span></div><div class="flex flex-col items-center gap-2"><div class="w-20 h-16 rounded-2xl bg-white flex items-center justify-center shadow-lg border border-gray-100 p-2"><span class="text-sm font-bold text-blue-600"><img src="/uploads/logo/sap-integration-with-upbuff-crm.png"></span></div><span class="text-xs text-gray-500">Analytics</span></div></div></div>',
    },

    {
      wide: true,
      title: 'Oracle, Epicor & Custom ERP API Integration',
      description: 'Integrate Oracle ERP via REST APIs and Oracle Integration Cloud, Epicor via REST and Service Connect, and custom ERP systems using flexible API connectors. A unified execution layer ensures consistent workflows across all enterprise systems.',
      image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-100 p-6"><div class="grid grid-cols-3 gap-4"><div class="flex flex-col items-center gap-2"><div class="w-20 h-14 rounded-xl bg-white flex items-center justify-center shadow border p-2"><span class="text-xs font-bold text-blue-600"><img src="/uploads/logo/oracle-integration-with-upbuff-crm.png"></span></div><span class="text-xs text-gray-500">Oracle ERP</span></div><div class="flex flex-col items-center gap-2"><div class="w-20 h-14 rounded-xl bg-white flex items-center justify-center shadow border p-2"><span class="text-xs font-bold text-red-500"><img src="/uploads/logo/epicore-integration-with-upbuff-crm.png"></span></div><span class="text-xs text-gray-500">Epicor ERP</span></div><div class="flex flex-col items-center gap-2"><div class="w-20 h-14 rounded-xl bg-white flex items-center justify-center shadow border p-2"><span class="text-xs font-bold text-green-600"><svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg></span></div><span class="text-xs text-gray-500">Custom API</span></div></div></div>',
    },

    {
      title: 'IoT Device Integration',
      description: 'Connect IoT sensors and industrial devices with ERP systems to capture real-time operational data. Enable predictive maintenance, asset tracking, and automation across manufacturing and field operations.',
      image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-cyan-50 to-blue-100 p-6"><div class="grid grid-cols-2 gap-4"><div class="flex flex-col items-center gap-2"><div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center shadow-lg border border-gray-100"><span class="text-sm font-bold text-cyan-600">IoT</span></div><span class="text-xs text-gray-500">Sensors</span></div><div class="flex flex-col items-center gap-2"><div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center shadow-lg border border-gray-100"><span class="text-sm font-bold text-blue-600">AI</span></div><span class="text-xs text-gray-500">Analytics</span></div></div></div>',
    },

    {
      title: 'VoIP & Telephony Integration',
      description: 'Integrate VoIP systems with ERP and CRM workflows to enable click-to-call, call logging, and customer interaction tracking — improving sales and service efficiency.',
      image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-purple-50 to-indigo-100 p-6"><div class="grid grid-cols-2 gap-4"><div class="flex flex-col items-center gap-2"><div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center shadow-lg border border-gray-100"><span class="text-sm font-bold text-indigo-600">VoIP</span></div><span class="text-xs text-gray-500">Calling</span></div><div class="flex flex-col items-center gap-2"><div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center shadow-lg border border-gray-100"><span class="text-sm font-bold text-purple-600">CRM</span></div><span class="text-xs text-gray-500">Tracking</span></div></div></div>',
    },

    {
      title: 'WhatsApp Business Integration',
      description: 'Enable real-time communication via WhatsApp Business with ERP-connected workflows including order updates, service alerts, and customer engagement.',
      image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-green-50 to-green-100 p-6"><div class="flex flex-col items-center gap-2"><div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center shadow-lg border border-gray-100"><span class="text-sm font-bold text-green-600"><img src="/uploads/logo/whatsapp-integration-with-upbuff-crm.png"></span></div><span class="text-xs text-gray-500">WhatsApp</span></div></div>',
    },

    {
      title: 'Shopify & E-Commerce Integration',
      description: 'Synchronize Shopify orders, inventory, and customer data with ERP systems for unified commerce and real-time operational visibility.',
      image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-lime-50 to-green-100 p-6"><div class="flex flex-col items-center gap-2"><div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center shadow-lg border border-gray-100"><span class="text-sm font-bold text-green-700">Shopify</span></div><span class="text-xs text-gray-500">E-commerce</span></div></div>',
    },

    {
      title: 'Outlook, Gmail & Business Productivity Integrations',
      description: 'Integrate Outlook, Gmail, Calendly, Zoho, and HR systems to automate workflows. Connect ERP with your productivity tools to streamline approvals, notifications, and cross-functional operations.',
      image: '<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-orange-50 to-red-100 p-6"><div class="grid grid-cols-3 gap-3"><div class="w-14 h-14 rounded-xl bg-white flex items-center justify-center shadow border"><span class="text-xs font-bold text-red-500"><img src="/uploads/logo/outlook-integration-with-upbuff-crm.png"></span></div><div class="w-14 h-14 rounded-xl bg-white flex items-center justify-center shadow border"><span class="text-xs font-bold text-orange-500"><img src="/uploads/logo/gmail-integration-with-upbuff-crm.png"></span></div><div class="w-14 h-14 rounded-xl bg-white flex items-center justify-center shadow border"><span class="text-xs font-bold text-gray-600"><img src="/uploads/logo/zoho-integration-with-upbuff-crm.png"></span></div></div></div>',
    },
  ]}
/>

  <FeaturesGrid
    tagline="Solution"
    title="Why choose UpBuff ERP Integrated CRM?"
    subtitle="Each capability strengthens your ERP without replacing it — preserving upgrade safety while empowering frontline teams."
    items={[
      {
        icon: 'tabler:refresh',
        title: 'Real-Time ERP Data Synchronization',
        description: 'Connect directly to ERP APIs including SAP Service Layer and S/4HANA RFC services. Access live customer master, pricing, inventory, and order status with no duplication or delay.',
      },
      {
        icon: 'tabler:shield-check',
        title: 'Sales Execution Without ERP Customization',
        description: 'Empower field and inside sales teams to create quotations and orders while preserving ERP upgrade safety — critical for SAP customers avoiding core customization risks.',
      },
      {
        icon: 'tabler:device-mobile',
        title: 'Mobile-First CRM for ERP Environments',
        description: 'Enable sales teams to capture orders, record visits, track collections, and update customer data in real time — online or offline — synchronized directly with ERP.',
      },
      {
        icon: 'tabler:receipt',
        title: 'ERP Pricing, Tax & Credit Control',
        description: 'Automatically apply ERP-configured pricing rules, discount structures, tax logic, and credit limits at point of order capture — ensuring full SAP compliance.',
      },
      {
        icon: 'tabler:git-merge',
        title: 'ERP-Governed Workflows & Approvals',
        description: 'Maintain ERP-controlled approvals, credit checks, and validations while dramatically improving usability for frontline users.',
      },
      {
        icon: 'tabler:lock',
        title: 'Enterprise-Grade Security & Data Integrity',
        description: 'ERP remains the single source of truth. Secure API-based architecture ensures auditability, data integrity, and compliance for enterprise customers.',
      },
    ]}
  />

  <FeaturesHighlights
    tagline="Core Capabilities"
    title="Three pillars of ERP-integrated sales execution"
    subtitle="UpBuff CRM is built on three architectural principles that make it fundamentally different from traditional CRM tools."
    items={[
      {
        title: 'Real-Time ERP Data Access',
        description: 'Live customer master, pricing rules, credit limits, inventory levels, and order history from SAP Business One, S/4HANA, Oracle, or Epicor — at the moment of every sales interaction. No sync delays, no cached data, no manual updates.',
        image: '<div class="flex flex-col items-center justify-center gap-4"><img src="/uploads/erp-first-architecture-upbuff.png" alt="ERP-first architecture integrating SAP Business One, Oracle ERP, and Epicor with real-time API synchronization" class="max-h-[180px] w-auto object-contain"/><p class="text-sm font-semibold text-gray-800 text-center">SAP · Oracle · Epicor</p><p class="text-xs text-blue-600 text-center">No core modification · API-native</p></div>',
      },
      {
        title: 'Mobile-First, Offline-Capable',
        description: 'Purpose-built mobile apps for field sales reps, distributors, and sales managers. Capture orders, record visits, process collections, and manage customer interactions — online or fully offline with automatic ERP synchronization when connectivity returns.',
        image: '<div class="flex flex-col items-center justify-center gap-4"><img src="/uploads/real-time-update.png" alt="Real-time ERP mobility solution for sales, field service, warehouse, and shopfloor teams with offline and online synchronization" class="max-h-[180px] w-auto object-contain"/><p class="text-sm font-semibold text-gray-800 text-center">Sales · Field · Warehouse · Shopfloor</p><p class="text-xs text-green-600 text-center">Offline-capable · Real-time sync</p></div>',
      },
      {
        title: 'ERP-Governed Compliance',
        description: 'Every order, quotation, discount, and approval flows through ERP business rules — pricing logic, tax calculation, credit control, and approval hierarchies enforced at point of capture. ERP remains the system of record. No compliance gaps.',
        image: '<div class="flex flex-col items-center justify-center gap-4"><img src="/uploads/upbuff-data-integrity-security.png" alt="ERP data integrity and governance with role-based access control, audit logs, and compliance workflows" class="max-h-[180px] w-auto object-contain"/><p class="text-sm font-semibold text-gray-800 text-center">RBAC · Audit logs · Approvals</p><p class="text-xs text-gray-500 text-center">SOC 2 · GDPR · Compliance-ready</p></div>',
      },
    ]}
  />

  <ToolsMarquee
    title="Integrates with your existing tools"
    description="UpBuff connects your ERP with the business tools your teams already use — creating unified workflows without silos."
    speed={30}
    tools={[
      { name: 'Calendar', logo: '<img src="/uploads/logo/calendar-integration-with-upbuff-crm.png" alt="Calendar integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'Epicor', logo: '<img src="/uploads/logo/epicore-integration-with-upbuff-crm.png" alt="Epicor integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'SAP', logo: '<img src="/uploads/logo/sap-integration-with-upbuff-crm.png" alt="SAP integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'Gmail', logo: '<img src="/uploads/logo/gmail-integration-with-upbuff-crm.png" alt="Gmail integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'IoT', logo: '<img src="/uploads/logo/iot-integration.png" alt="IoT integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'SAP S/4HANA', logo: '<img src="/uploads/logo/sap-integration-with-upbuff-crm.png" alt="SAP S/4HANA integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'Oracle', logo: '<img src="/uploads/logo/oracle-integration-with-upbuff-crm.png" alt="Oracle integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'Outlook', logo: '<img src="/uploads/logo/outlook-integration-with-upbuff-crm.png" alt="Outlook integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'Power BI', logo: '<img src="/uploads/logo/power-bi-integration-with-upbuff-crm.png" alt="Power BI integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'SAP Business One', logo: '<img src="/uploads/logo/sap-integration-with-upbuff-crm.png" alt="SAP Business One integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'SMS', logo: '<img src="/uploads/logo/sms-integration-with-upbuff-crm.png" alt="SMS integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'VoIP', logo: '<img src="/uploads/logo/voip-integration-with-upbuff-crm.png" alt="VoIP integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'WhatsApp', logo: '<img src="/uploads/logo/whatsapp-integration-with-upbuff-crm.png" alt="WhatsApp integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },

      { name: 'Zoho', logo: '<img src="/uploads/logo/zoho-integration-with-upbuff-crm.png" alt="Zoho integration with UpBuff CRM" class="w-10 h-10 object-contain" />' },
    ]}
  />

  <TestimonialsGrid
    title="What our customers say"
    subtitle="Trusted by <strong>10,000+</strong> businesses — from SAP Business One partners to enterprise distribution companies"
    row1={[
      {
        company: 'Molygraph',
        logo: '/uploads/molygraph-logo.svg',
        quote: 'UpBuff is a strong signal of how field operations will evolve. An early adopter of the execution-layer approach, which will become increasingly effective and trusted.',
        name: 'Marc Manara',
        role: 'Head of Startups',
      },
      {
        company: 'Ideaforge',
        logo: '/uploads/ideaForge-logo.svg',
        quote: 'The workflows are user-friendly, easy to customize, and have been effectively serving our field sales teams for nearly two years without a single ERP incident.',
        name: 'Ann Donie',
        role: 'Product Owner',
      },
    ]}
    statCard={{
      stat: '10,000+',
      label: 'businesses trust UpBuff ERP CRM',
      gradient: 'linear-gradient(135deg, #f97316 0%, #fbbf24 50%, #ec4899 100%)',
    }}
    row2={[
      {
        company: 'The Wine Source',
        logo: '/uploads/the-wine-source-logo.svg',
        quote: 'UpBuff gave us a powerful, flexible way to extend our SAP operations to field teams without the complexity we saw in other platforms. Guests report strong satisfaction.',
        name: 'Mark Kupferman',
        role: 'CMO',
      },
      {
        company: 'Roofsol',
        logo: '/uploads/roofsol-logo.svg',
        quote: 'An excellent ERP execution solution. Onboarding is fast, training is easy, and the ERP sync is accurate. It significantly reduces friction between our SAP data and frontline teams.',
        name: 'Jesús Franco',
        role: 'CTO',
      },
    ]}
  />

  <FaqAccordion
